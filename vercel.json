{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/oposiciones",
      "destination": "https://oposicioneseconomia.es/",
      "permanent": true
    },
    {
      "source": "/oposiciones/:path*",
      "destination": "https://oposicioneseconomia.es/",
      "permanent": true
    },
    {
      "source": "/oposicions.html",
      "destination": "https://oposicioneseconomia.es/",
      "permanent": true
    },
    {
      "source": "/oposicions-:path*",
      "destination": "https://oposicioneseconomia.es/",
      "permanent": true
    },

    { "source": "/index.html", "destination": "/", "permanent": true },

    { "source": "/edmn-2bach.html", "destination": "/edmn-2bach/", "permanent": true },
    { "source": "/empresa.html", "destination": "/edmn-2bach/", "permanent": true },
    { "source": "/economia-1bach.html", "destination": "/eco-1bach/", "permanent": true },
    { "source": "/economia.html", "destination": "/eco-1bach/", "permanent": true },
    { "source": "/ferramentes.html", "destination": "/eco-1bach/", "permanent": true },
    { "source": "/recerca.html", "destination": "/eco-1bach/", "permanent": true },
    { "source": "/finances.html", "destination": "/eco-1bach/", "permanent": true },
    { "source": "/economia-4eso.html", "destination": "/eco-4eso/", "permanent": true },
    { "source": "/fopp-4eso.html", "destination": "/fopp-4eso/", "permanent": true },
    { "source": "/vidapractica.html", "destination": "/fopp-4eso/", "permanent": true },
    { "source": "/professorat.html", "destination": "/herramientas/", "permanent": true },

    { "source": "/playground.html", "destination": "/juegos/", "permanent": false },
    { "source": "/concurs.html", "destination": "/juegos/", "permanent": false },
    { "source": "/stonks.html", "destination": "/juegos/", "permanent": false },
    { "source": "/insider.html", "destination": "/juegos/", "permanent": false },
    { "source": "/communist.html", "destination": "/juegos/", "permanent": false },
    { "source": "/econopoly.html", "destination": "/juegos/", "permanent": false },
    { "source": "/econrisk.html", "destination": "/juegos/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
