---
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
import { ASIGNATURA_SLUGS } from '@/lib/asignaturas';
import { jsonLdToString } from '@/lib/seo';
import '@/styles/global.css';
import '@/styles/calculadoras.css';

type Props = {
  title: string;
  description?: string;
  /** Optional Open Graph image (absolute or path under /public). */
  ogImage?: string;
  /** Open Graph type — "website" (default) for hubs, "article" for content pages. */
  ogType?: string;
  /** One or more schema.org JSON-LD objects (see src/lib/seo.ts). */
  jsonLd?: object | object[];
  /** When true, emits <meta name="robots" content="noindex,nofollow" />. */
  noindex?: boolean;
};

const { title, description, ogImage, ogType = 'website', jsonLd, noindex = false } = Astro.props;
const fullTitle = title.endsWith('profedeeconomia')
  ? title
  : `${title} — profedeeconomia`;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ldItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Google Search Console site verification. Empty by default — set the
// PUBLIC_GOOGLE_SITE_VERIFICATION env var (Vercel project env or .env) to the
// token from Search Console and the meta tag is emitted; no code change needed.
const gscVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

// Bing Webmaster Tools site verification (msvalidate.01). Same pattern: set
// PUBLIC_BING_SITE_VERIFICATION to the token from Bing Webmaster Tools.
const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;

// Open Graph image: explicit prop wins; otherwise the asignatura's branded image
// (by first URL segment) or the site-wide default. Generated by build:og.
const firstSeg = Astro.url.pathname.split('/').filter(Boolean)[0] ?? '';
const autoOgImage = (ASIGNATURA_SLUGS as readonly string[]).includes(firstSeg)
  ? `/og/${firstSeg}.png`
  : '/og/default.png';
const resolvedOgImage = new URL(ogImage ?? autoOgImage, Astro.site).toString();
---
<!doctype html>
<html lang={Astro.currentLocale ?? 'es'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {description && <meta name="description" content={description} />}
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}
    <link rel="canonical" href={canonical} />

    <!-- Favicon — monograma "p." (logo A) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Variant C type stack, self-hosted (@font-face in global.css). No
         third-party font CDN → no visitor-IP leak (GDPR). Preload only the
         LCP font (Fraunces, used by the H1); the rest load via @font-face. -->
    <link
      rel="preload"
      href="/fonts/fraunces-latin-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="profedeeconomia" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Structured data (JSON-LD) -->
    {ldItems.map((item) => (
      <script type="application/ld+json" set:html={jsonLdToString(item)} />
    ))}
  </head>
  <body class="bg-bg text-ink font-sans">
    <a href="#main" class="skip-link">Saltar al contenido principal</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
