---
/**
 * Business Model Canvas — nueve bloques distribuidos en el layout
 * canónico de Osterwalder & Pigneur (2010). Lado izquierdo: actividades,
 * recursos y socios (lo que la empresa hace). Centro: propuesta de
 * valor. Derecha: clientes, canales y relaciones. Abajo: costes
 * (interno) e ingresos (cliente).
 */
---
<svg viewBox="0 0 900 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Business Model Canvas: las nueve áreas">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .block { fill: #FFFFFF; stroke: #E5D4BD; stroke-width: 1.5; }
      .block-vp { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .block-customer { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 1.5; }
      .block-internal { fill: #F5E5BC; stroke: #D4A24C; stroke-width: 1.5; }
      .block-costs { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 1.5; }
      .block-rev { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 1.5; }
      .num { font-family: 'Fraunces', serif; font-style: italic; font-size: 13px; font-weight: 500; fill: #A87A2A; }
      .num-vp { fill: #9C3A1C; }
      .title { font-family: 'Switzer', sans-serif; font-size: 10.5px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; fill: #2A1F18; }
      .title-vp { fill: #9C3A1C; }
      .question { font-family: 'Fraunces', serif; font-style: italic; font-size: 11px; fill: #5C4A3D; }
      .question-vp { fill: #9C3A1C; }
      .strip-label { font-family: 'Switzer', sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #8A7868; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="900" height="480"/>

  <!-- Top strip labels -->
  <text class="strip-label" x="170" y="30">LO QUE LA EMPRESA HACE</text>
  <text class="strip-label" x="460" y="30" text-anchor="middle">EL OFRECIMIENTO</text>
  <text class="strip-label" x="730" y="30" text-anchor="end">LO QUE EL CLIENTE EXPERIMENTA</text>

  <!-- Row 1 (top half): 7 internal blocks + propuesta de valor center + 3 cliente blocks -->
  <!-- 8. Asociaciones clave (top-left) -->
  <g>
    <rect class="block" x="40" y="50" width="160" height="170" rx="6"/>
    <text class="num" x="55" y="73">08</text>
    <text class="title" x="55" y="96">Asociaciones clave</text>
    <text class="question" x="55" y="125">¿Quiénes son los</text>
    <text class="question" x="55" y="140">aliados estratégicos</text>
    <text class="question" x="55" y="155">sin los que el modelo</text>
    <text class="question" x="55" y="170">no funcionaría?</text>
  </g>

  <!-- 7. Actividades clave (top center-left) -->
  <g>
    <rect class="block block-internal" x="210" y="50" width="160" height="85" rx="6"/>
    <text class="num" x="225" y="73">07</text>
    <text class="title" x="225" y="96">Actividades clave</text>
    <text class="question" x="225" y="115">¿Qué hacemos cada día</text>
    <text class="question" x="225" y="128">que no podemos delegar?</text>
  </g>

  <!-- 6. Recursos clave (middle center-left) -->
  <g>
    <rect class="block block-internal" x="210" y="140" width="160" height="80" rx="6"/>
    <text class="num" x="225" y="163">06</text>
    <text class="title" x="225" y="186">Recursos clave</text>
    <text class="question" x="225" y="205">¿Qué recursos críticos</text>
    <text class="question" x="225" y="218">necesitamos?</text>
  </g>

  <!-- 2. Propuesta de valor (center) -->
  <g>
    <rect class="block-vp" x="380" y="50" width="160" height="170" rx="6"/>
    <text class="num num-vp" x="395" y="73">02</text>
    <text class="title title-vp" x="395" y="96">Propuesta de valor</text>
    <text class="question question-vp" x="395" y="125">¿Qué problema</text>
    <text class="question question-vp" x="395" y="140">resolvemos o qué</text>
    <text class="question question-vp" x="395" y="155">necesidad cubrimos?</text>
    <text class="question question-vp" x="395" y="180">¿Por qué somos</text>
    <text class="question question-vp" x="395" y="195">diferentes de las</text>
    <text class="question question-vp" x="395" y="210">alternativas?</text>
  </g>

  <!-- 4. Relaciones con clientes (top center-right) -->
  <g>
    <rect class="block block-customer" x="550" y="50" width="160" height="85" rx="6"/>
    <text class="num" x="565" y="73">04</text>
    <text class="title" x="565" y="96">Relaciones con clientes</text>
    <text class="question" x="565" y="115">¿Qué tipo de relación</text>
    <text class="question" x="565" y="128">mantenemos con cada uno?</text>
  </g>

  <!-- 3. Canales (middle center-right) -->
  <g>
    <rect class="block block-customer" x="550" y="140" width="160" height="80" rx="6"/>
    <text class="num" x="565" y="163">03</text>
    <text class="title" x="565" y="186">Canales</text>
    <text class="question" x="565" y="205">¿Por qué canales llega</text>
    <text class="question" x="565" y="218">nuestra propuesta?</text>
  </g>

  <!-- 1. Segmentos de clientes (top-right) -->
  <g>
    <rect class="block block-customer" x="720" y="50" width="140" height="170" rx="6"/>
    <text class="num" x="735" y="73">01</text>
    <text class="title" x="735" y="96">Segmentos de clientes</text>
    <text class="question" x="735" y="125">¿Para quién creamos</text>
    <text class="question" x="735" y="140">valor?</text>
    <text class="question" x="735" y="165">¿Quiénes son nuestros</text>
    <text class="question" x="735" y="180">clientes más importantes?</text>
  </g>

  <!-- Bottom row: costes (left) + ingresos (right) -->
  <!-- 9. Estructura de costes -->
  <g>
    <rect class="block block-costs" x="40" y="240" width="410" height="120" rx="6"/>
    <text class="num num-vp" x="55" y="263">09</text>
    <text class="title title-vp" x="55" y="286">Estructura de costes</text>
    <text class="question question-vp" x="55" y="310">¿En qué gasta la empresa?</text>
    <text class="question question-vp" x="55" y="325">¿Qué costes son fijos y cuáles variables?</text>
    <text class="question question-vp" x="55" y="345">¿Hay economías de escala?</text>
  </g>

  <!-- 5. Fuentes de ingresos -->
  <g>
    <rect class="block block-rev" x="460" y="240" width="400" height="120" rx="6"/>
    <text class="num" x="475" y="263">05</text>
    <text class="title" x="475" y="286">Fuentes de ingresos</text>
    <text class="question" x="475" y="310">¿Cómo y por qué nos pagan los clientes?</text>
    <text class="question" x="475" y="325">¿Es venta unitaria, suscripción, comisión, licencia?</text>
    <text class="question" x="475" y="345">¿Qué peso tiene cada fuente sobre el total?</text>
  </g>

  <!-- Footer legend -->
  <text class="strip-label" x="40" y="395" fill="#A87A2A">INTERNO · LO QUE GASTAMOS</text>
  <text class="strip-label" x="860" y="395" fill="#0E4040" text-anchor="end">CLIENTE · LO QUE COBRAMOS</text>

  <text x="450" y="445" font-family="Fraunces" font-style="italic" font-size="13" fill="#5C4A3D" text-anchor="middle">Las 9 áreas se distribuyen en una página: cinco áreas miran al cliente (derecha) y cuatro al interior (izquierda).</text>
  <text x="450" y="463" font-family="Fraunces" font-style="italic" font-size="13" fill="#5C4A3D" text-anchor="middle">La propuesta de valor (centro) es lo que las conecta.</text>
</svg>
