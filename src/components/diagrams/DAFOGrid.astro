---
/**
 * 2x2 DAFO matrix with the four crosses (FO, DO, FA, DA) annotated
 * around it, so the reader sees not only the four cells but also the
 * strategies derived from each pair.
 */
---
<svg viewBox="0 0 720 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Matriz DAFO con cruces estratégicos">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .axis-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; fill: #5C4A3D; }
      .cell-f { fill: #E5F1DD; stroke: #4F8C3F; stroke-width: 1.5; }
      .cell-d { fill: #F5DDDD; stroke: #B83A3A; stroke-width: 1.5; }
      .cell-o { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 1.5; }
      .cell-a { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 1.5; }
      .cell-label { font-family: 'Fraunces', serif; font-size: 36px; font-style: italic; font-weight: 500; text-anchor: middle; }
      .cell-name { font-family: 'Switzer', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; text-anchor: middle; }
      .cell-desc { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #5C4A3D; text-anchor: middle; }
      .cross-label { font-family: 'Fraunces', serif; font-size: 11.5px; font-style: italic; fill: #2A1F18; }
      .cross-strat { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; fill: #C44E2C; }
      .legend-label { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="540"/>

  <!-- Axis labels -->
  <text class="axis-label" x="240" y="40" text-anchor="middle">FACTORES INTERNOS</text>
  <text class="axis-label" x="540" y="40" text-anchor="middle">FACTORES EXTERNOS</text>
  <text class="axis-label" x="50" y="195" transform="rotate(-90 50 195)" text-anchor="middle">POSITIVO</text>
  <text class="axis-label" x="50" y="375" transform="rotate(-90 50 375)" text-anchor="middle">NEGATIVO</text>

  <!-- F: Fortalezas (top-left) -->
  <g>
    <rect class="cell-f" x="100" y="60" width="280" height="170" rx="6"/>
    <text class="cell-label" x="240" y="115" fill="#4F8C3F">F</text>
    <text class="cell-name" x="240" y="160" fill="#2A5A1F">FORTALEZAS</text>
    <text class="cell-desc" x="240" y="180">Lo que la empresa hace bien</text>
    <text class="cell-desc" x="240" y="195">y la diferencia.</text>
  </g>

  <!-- O: Oportunidades (top-right) -->
  <g>
    <rect class="cell-o" x="400" y="60" width="280" height="170" rx="6"/>
    <text class="cell-label" x="540" y="115" fill="#1F6E6E">O</text>
    <text class="cell-name" x="540" y="160" fill="#0E4040">OPORTUNIDADES</text>
    <text class="cell-desc" x="540" y="180">Fuerzas externas favorables</text>
    <text class="cell-desc" x="540" y="195">que conviene aprovechar.</text>
  </g>

  <!-- D: Debilidades (bottom-left) -->
  <g>
    <rect class="cell-d" x="100" y="240" width="280" height="170" rx="6"/>
    <text class="cell-label" x="240" y="295" fill="#B83A3A">D</text>
    <text class="cell-name" x="240" y="340" fill="#702020">DEBILIDADES</text>
    <text class="cell-desc" x="240" y="360">Lo que la empresa hace peor</text>
    <text class="cell-desc" x="240" y="375">que sus competidores.</text>
  </g>

  <!-- A: Amenazas (bottom-right) -->
  <g>
    <rect class="cell-a" x="400" y="240" width="280" height="170" rx="6"/>
    <text class="cell-label" x="540" y="295" fill="#C44E2C">A</text>
    <text class="cell-name" x="540" y="340" fill="#9C3A1C">AMENAZAS</text>
    <text class="cell-desc" x="540" y="360">Fuerzas externas adversas</text>
    <text class="cell-desc" x="540" y="375">que conviene anticipar.</text>
  </g>

  <!-- Cross legend below the matrix -->
  <line x1="100" y1="430" x2="680" y2="430" stroke="#E5D4BD" stroke-width="1" stroke-dasharray="4 3"/>
  <text class="legend-label" x="100" y="455" fill="#5C4A3D">CRUCES ESTRATÉGICOS</text>

  <g>
    <text class="cross-strat" x="120" y="490" text-anchor="middle">FO</text>
    <text class="cross-label" x="170" y="490" text-anchor="start">Ofensivas — aprovechar fortalezas para capturar oportunidades</text>
  </g>
  <g>
    <text class="cross-strat" x="120" y="510" text-anchor="middle">DO</text>
    <text class="cross-label" x="170" y="510" text-anchor="start">Reorientación — corregir debilidades para no perder oportunidades</text>
  </g>
  <g>
    <text class="cross-strat" x="430" y="490" text-anchor="middle">FA</text>
    <text class="cross-label" x="480" y="490" text-anchor="start">Defensivas — proteger fortalezas frente a amenazas</text>
  </g>
  <g>
    <text class="cross-strat" x="430" y="510" text-anchor="middle">DA</text>
    <text class="cross-label" x="480" y="510" text-anchor="start">Supervivencia — minimizar riesgo donde somos vulnerables</text>
  </g>
</svg>
