---
/**
 * Visual map of the six blocks of the FOPP 4ESO book.
 * 3x2 grid of cards with roman numeral, title, color-coded
 * by thematic register, and a one-line description each.
 */
---
<svg viewBox="0 0 820 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Los seis bloques del libro de FOPP 4.º ESO">
  <title>Los seis bloques del libro</title>
  <desc>Mapa visual de los seis bloques del libro de Formación y Orientación Personal y Profesional: del autoconocimiento a la inserción laboral.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .card { stroke-width: 2; }
      .card-a { fill: #FBE3D6; stroke: #C44E2C; }
      .card-b { fill: #F5E5BC; stroke: #D4A24C; }
      .card-c { fill: #DBEDED; stroke: #1F6E6E; }
      .card-d { fill: #ECDCE5; stroke: #5B3A4E; }
      .card-e { fill: #F5DDD0; stroke: #9C3A1C; }
      .card-f { fill: #F0DDB8; stroke: #A87A2A; }
      .roman { font-family: 'Fraunces', serif; font-style: italic; font-size: 48px; font-weight: 500; text-anchor: middle; }
      .roman-a { fill: #9C3A1C; }
      .roman-b { fill: #A87A2A; }
      .roman-c { fill: #0E4040; }
      .roman-d { fill: #4A2B3F; }
      .roman-e { fill: #6B1E08; }
      .roman-f { fill: #8A5E18; }
      .block-eyebrow { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; fill: #5C4A3D; }
      .block-title { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 500; fill: #2A1F18; }
      .block-desc { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #5C4A3D; }
      .arrow-flow { fill: none; stroke: #C44E2C; stroke-width: 1.5; stroke-dasharray: 4 3; marker-end: url(#flow-arrow); }
      .flow-label { font-family: 'Fraunces', serif; font-style: italic; font-size: 11px; fill: #C44E2C; text-anchor: middle; }
    </style>
    <marker id="flow-arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#C44E2C"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="820" height="520"/>

  <!-- Top label -->
  <text class="flow-label" x="410" y="30" font-size="13">De dentro hacia fuera: del yo al mundo laboral</text>

  <!-- Row 1: Bloques A, B, C -->
  <!-- Bloque A: Conócete -->
  <g>
    <rect class="card card-a" x="40" y="60" width="240" height="180" rx="8"/>
    <text class="roman roman-a" x="80" y="115">I</text>
    <text class="block-eyebrow" x="120" y="92">BLOQUE A</text>
    <text class="block-title" x="120" y="115">Conócete</text>
    <text class="block-desc" x="60" y="160">Identidad, emociones,</text>
    <text class="block-desc" x="60" y="176">autoestima y salud mental.</text>
    <text class="block-desc" x="60" y="208" font-style="italic" fill="#9C3A1C">Unidades 1 y 2</text>
  </g>

  <!-- Bloque B: Tu entorno -->
  <g>
    <rect class="card card-b" x="290" y="60" width="240" height="180" rx="8"/>
    <text class="roman roman-b" x="330" y="115">II</text>
    <text class="block-eyebrow" x="375" y="92">BLOQUE B</text>
    <text class="block-title" x="375" y="115">Tu entorno</text>
    <text class="block-desc" x="310" y="160">Familia, amistades, redes</text>
    <text class="block-desc" x="310" y="176">y huella digital.</text>
    <text class="block-desc" x="310" y="208" font-style="italic" fill="#A87A2A">Unidad 3</text>
  </g>

  <!-- Bloque C: Decisiones -->
  <g>
    <rect class="card card-c" x="540" y="60" width="240" height="180" rx="8"/>
    <text class="roman roman-c" x="580" y="115">III</text>
    <text class="block-eyebrow" x="635" y="92">BLOQUE C</text>
    <text class="block-title" x="635" y="115">Decisiones</text>
    <text class="block-desc" x="560" y="160">Cómo elegir bien: método,</text>
    <text class="block-desc" x="560" y="176">sesgos y opciones.</text>
    <text class="block-desc" x="560" y="208" font-style="italic" fill="#0E4040">Unidad 4</text>
  </g>

  <!-- Arrow row 1 → row 2 (central) -->
  <line class="arrow-flow" x1="410" y1="250" x2="410" y2="280"/>

  <!-- Row 2: Bloques D, E, F -->
  <!-- Bloque D: Itinerarios -->
  <g>
    <rect class="card card-d" x="40" y="290" width="240" height="180" rx="8"/>
    <text class="roman roman-d" x="80" y="345">IV</text>
    <text class="block-eyebrow" x="130" y="322">BLOQUE D</text>
    <text class="block-title" x="130" y="345">Itinerarios</text>
    <text class="block-desc" x="60" y="390">Sistema educativo, FP,</text>
    <text class="block-desc" x="60" y="406">universidad y becas.</text>
    <text class="block-desc" x="60" y="438" font-style="italic" fill="#4A2B3F">Unidades 5 y 6</text>
  </g>

  <!-- Bloque E: Mundo laboral -->
  <g>
    <rect class="card card-e" x="290" y="290" width="240" height="180" rx="8"/>
    <text class="roman roman-e" x="330" y="345">V</text>
    <text class="block-eyebrow" x="375" y="322">BLOQUE E</text>
    <text class="block-title" x="375" y="345">Mundo laboral</text>
    <text class="block-desc" x="310" y="390">Mercado laboral, contratos</text>
    <text class="block-desc" x="310" y="406">y derechos.</text>
    <text class="block-desc" x="310" y="438" font-style="italic" fill="#6B1E08">Unidades 7 y 8</text>
  </g>

  <!-- Bloque F: Buscar empleo -->
  <g>
    <rect class="card card-f" x="540" y="290" width="240" height="180" rx="8"/>
    <text class="roman roman-f" x="580" y="345">VI</text>
    <text class="block-eyebrow" x="625" y="322">BLOQUE F</text>
    <text class="block-title" x="625" y="345">Buscar empleo</text>
    <text class="block-desc" x="560" y="390">CV, marca personal y</text>
    <text class="block-desc" x="560" y="406">proyecto de vida.</text>
    <text class="block-desc" x="560" y="438" font-style="italic" fill="#8A5E18">Unidades 9 y 10</text>
  </g>

  <!-- Footer arrow flow -->
  <path class="arrow-flow" d="M 160 480 L 660 480"/>
  <text class="flow-label" x="410" y="505">Del autoconocimiento (yo) a la inserción laboral (proyecto)</text>
</svg>
