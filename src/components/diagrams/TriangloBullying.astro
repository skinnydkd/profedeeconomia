---
/**
 * The three roles in school bullying arranged as a triangle: the one who
 * bullies (top), the one who suffers it (bottom-left) and the one who
 * watches (bottom-right). A highlighted center box stresses that the
 * observer is the turning point: silence sustains the bullying, while
 * speaking up or telling an adult can stop it.
 *
 * Used in FOPP 4ESO (convivencia y trabajo en equipo). Sensitive,
 * empowering framing — not graphic.
 */
---
<svg viewBox="0 0 820 600" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tb-title tb-desc">
  <title id="tb-title">El triángulo del acoso escolar</title>
  <desc id="tb-desc">El acoso tiene tres papeles: quien acosa, quien lo sufre y quien observa. El observador es la clave: su silencio sostiene el acoso y su intervención puede frenarlo.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .tri { fill: none; stroke: #E5D4BD; stroke-width: 2; stroke-dasharray: 6 6; }
      .node { stroke-width: 2; }
      .node-agresor { fill: #FBE3D6; stroke: #9C3A1C; }
      .node-victima { fill: #F5E5BC; stroke: #A87A2A; }
      .node-observador { fill: #DBEDED; stroke: #1F6E6E; }
      .role { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; text-anchor: middle; }
      .role-agresor { fill: #9C3A1C; }
      .role-victima { fill: #A87A2A; }
      .role-observador { fill: #1F6E6E; }
      .name { font-family: 'Fraunces', serif; font-style: italic; font-size: 24px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .descr { font-family: 'Switzer', sans-serif; font-size: 13.5px; font-weight: 400; fill: #5C4A3D; text-anchor: middle; }
      .key-box { fill: #FFFFFF; stroke: #1F6E6E; stroke-width: 2; }
      .key-eyebrow { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase; fill: #1F6E6E; text-anchor: middle; }
      .key-text { font-family: 'Fraunces', serif; font-style: italic; font-size: 16px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .key-arrow { fill: none; stroke: #1F6E6E; stroke-width: 2.5; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="820" height="600"/>

  <!-- Triangle skeleton: apex (410,110), bottom-left (160,470), bottom-right (660,470) -->
  <polygon class="tri" points="410,150 200,455 620,455"/>

  <!-- Center key box, pointing to the observer (bottom-right) -->
  <!-- Arrow from key box toward observer node -->
  <path class="key-arrow" d="M 520 380 L 600 432" marker-end="url(#tb-arrow)"/>
  <defs>
    <marker id="tb-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#1F6E6E"/>
    </marker>
  </defs>

  <rect class="key-box" x="250" y="300" width="320" height="92" rx="10"/>
  <text class="key-eyebrow" x="410" y="324">El observador tiene la llave</text>
  <text class="key-text" x="410" y="350">El silencio sostiene el acoso;</text>
  <text class="key-text" x="410" y="372">intervenir o avisar lo frena.</text>

  <!-- Top vertex: Quien acosa (agresor) -->
  <g>
    <rect class="node node-agresor" x="245" y="40" width="330" height="92" rx="12"/>
    <text class="role role-agresor" x="410" y="64">Quien acosa</text>
    <text class="name" x="410" y="94">El agresor</text>
    <text class="descr" x="410" y="118">ejerce el daño, busca poder o aprobación del grupo</text>
  </g>

  <!-- Bottom-left vertex: Quien lo sufre (víctima) -->
  <g>
    <rect class="node node-victima" x="20" y="470" width="335" height="92" rx="12"/>
    <text class="role role-victima" x="187" y="494">Quien lo sufre</text>
    <text class="name" x="187" y="524">La víctima</text>
    <text class="descr" x="187" y="548">recibe el acoso, se siente sola y atrapada</text>
  </g>

  <!-- Bottom-right vertex: Quien observa (observador) -->
  <g>
    <rect class="node node-observador" x="465" y="470" width="335" height="92" rx="12"/>
    <text class="role role-observador" x="632" y="494">Quien observa</text>
    <text class="name" x="632" y="524">El testigo</text>
    <text class="descr" x="632" y="548">ve lo que pasa — y su reacción lo cambia todo</text>
  </g>
</svg>
