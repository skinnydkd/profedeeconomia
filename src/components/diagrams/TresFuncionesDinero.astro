---
/**
 * The three functions of money for 3º ESO: medio de pago (means of payment),
 * unidad de cuenta (unit of account) and depósito de valor (store of value).
 * Drawn as three side-by-side panels, each with a Fraunces title, a schematic
 * SVG icon (no emoji) and a one-line Switzer explanation.
 *
 * Used in Eco 4ESO · money & finance unit.
 */
---
<svg viewBox="0 0 920 400" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="funcdinero-title funcdinero-desc">
  <title id="funcdinero-title">Las tres funciones del dinero</title>
  <desc id="funcdinero-desc">El dinero cumple tres funciones: medio de pago (comprar y vender), unidad de cuenta (poner precio y comparar) y depósito de valor (guardar riqueza para después).</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .panel-pago { fill: #FBE3D6; }
      .panel-cuenta { fill: #F5E5BC; }
      .panel-valor { fill: #DBEDED; }
      .panel-stroke-pago { stroke: #C44E2C; stroke-width: 2; }
      .panel-stroke-cuenta { stroke: #A87A2A; stroke-width: 2; }
      .panel-stroke-valor { stroke: #1F6E6E; stroke-width: 2; }
      .top-pago { fill: #C44E2C; }
      .top-cuenta { fill: #D4A24C; }
      .top-valor { fill: #1F6E6E; }
      .heading { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; fill: #8A7868; text-anchor: middle; }
      .p-title { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .p-line { font-family: 'Switzer', sans-serif; font-size: 14px; fill: #5C4A3D; text-anchor: middle; }
      .strip-bg { fill: #2A1F18; }
      .strip-text { font-family: 'Fraunces', serif; font-style: italic; font-size: 18px; fill: #FBF6EC; text-anchor: middle; }
      .tag-text { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="920" height="400"/>

  <text class="heading" x="460" y="34">Para qué sirve el dinero</text>

  <!-- ============ Panel 1: Medio de pago (terracota) ============ -->
  <g>
    <rect class="panel-pago panel-stroke-pago" x="30" y="56" width="270" height="260" rx="12"/>
    <rect class="top-pago" x="30" y="56" width="270" height="8" rx="4"/>
    <text class="p-title" x="165" y="98">Medio de pago</text>

    <!-- icon: buyer ↔ seller with a coin passing between them -->
    <!-- left person -->
    <circle cx="95" cy="150" r="15" fill="none" stroke="#9C3A1C" stroke-width="3"/>
    <path d="M 73 196 Q 95 168 117 196" fill="none" stroke="#9C3A1C" stroke-width="3"/>
    <!-- right person -->
    <circle cx="235" cy="150" r="15" fill="none" stroke="#9C3A1C" stroke-width="3"/>
    <path d="M 213 196 Q 235 168 257 196" fill="none" stroke="#9C3A1C" stroke-width="3"/>
    <!-- coin in the middle -->
    <circle cx="165" cy="150" r="20" fill="#FFFFFF" stroke="#C44E2C" stroke-width="3"/>
    <text class="tag-text" x="165" y="156" fill="#C44E2C">€</text>
    <!-- exchange arrows -->
    <path d="M 140 132 H 118" fill="none" stroke="#C44E2C" stroke-width="2.5"/>
    <path d="M 124 127 L 117 132 L 124 137" fill="none" stroke="#C44E2C" stroke-width="2.5"/>
    <path d="M 190 168 H 212" fill="none" stroke="#C44E2C" stroke-width="2.5"/>
    <path d="M 206 163 L 213 168 L 206 173" fill="none" stroke="#C44E2C" stroke-width="2.5"/>

    <text class="p-line" x="165" y="250">Sirve para comprar y vender</text>
    <text class="p-line" x="165" y="272">sin trueque.</text>
  </g>

  <!-- ============ Panel 2: Unidad de cuenta (mustard) ============ -->
  <g>
    <rect class="panel-cuenta panel-stroke-cuenta" x="325" y="56" width="270" height="260" rx="12"/>
    <rect class="top-cuenta" x="325" y="56" width="270" height="8" rx="4"/>
    <text class="p-title" x="460" y="98">Unidad de cuenta</text>

    <!-- icon: three price tags 1 €, 20 €, 500 € -->
    <!-- tag 1 -->
    <path d="M 372 132 H 432 V 162 H 372 L 358 147 Z" fill="#FFFFFF" stroke="#A87A2A" stroke-width="2.5"/>
    <circle cx="368" cy="147" r="3" fill="#A87A2A"/>
    <text class="tag-text" x="404" y="152" fill="#A87A2A">1 €</text>
    <!-- tag 2 -->
    <path d="M 405 152 H 470 V 182 H 405 L 391 167 Z" fill="#FFFFFF" stroke="#A87A2A" stroke-width="2.5"/>
    <circle cx="401" cy="167" r="3" fill="#A87A2A"/>
    <text class="tag-text" x="439" y="172" fill="#A87A2A">20 €</text>
    <!-- tag 3 -->
    <path d="M 438 172 H 512 V 202 H 438 L 424 187 Z" fill="#FFFFFF" stroke="#A87A2A" stroke-width="2.5"/>
    <circle cx="434" cy="187" r="3" fill="#A87A2A"/>
    <text class="tag-text" x="477" y="192" fill="#A87A2A">500 €</text>

    <text class="p-line" x="460" y="250">Sirve para poner precio</text>
    <text class="p-line" x="460" y="272">y comparar.</text>
  </g>

  <!-- ============ Panel 3: Depósito de valor (teal) ============ -->
  <g>
    <rect class="panel-valor panel-stroke-valor" x="620" y="56" width="270" height="260" rx="12"/>
    <rect class="top-valor" x="620" y="56" width="270" height="8" rx="4"/>
    <text class="p-title" x="755" y="98">Depósito de valor</text>

    <!-- icon: a piggy bank with a coin going in -->
    <!-- coin dropping in -->
    <circle cx="755" cy="124" r="11" fill="#FFFFFF" stroke="#1F6E6E" stroke-width="2.5"/>
    <text class="tag-text" x="755" y="129" fill="#1F6E6E" font-size="11">€</text>
    <!-- piggy body -->
    <ellipse cx="755" cy="178" rx="62" ry="42" fill="#FFFFFF" stroke="#1F6E6E" stroke-width="3"/>
    <!-- coin slot -->
    <rect x="745" y="142" width="20" height="5" rx="2.5" fill="#1F6E6E"/>
    <!-- snout -->
    <ellipse cx="700" cy="182" rx="13" ry="16" fill="#DBEDED" stroke="#1F6E6E" stroke-width="3"/>
    <circle cx="697" cy="178" r="2.5" fill="#1F6E6E"/>
    <circle cx="702" cy="186" r="2.5" fill="#1F6E6E"/>
    <!-- eye -->
    <circle cx="738" cy="166" r="3.5" fill="#1F6E6E"/>
    <!-- ear -->
    <path d="M 762 142 L 776 134 L 772 152 Z" fill="#DBEDED" stroke="#1F6E6E" stroke-width="2.5"/>
    <!-- legs -->
    <rect x="722" y="214" width="8" height="14" rx="3" fill="#1F6E6E"/>
    <rect x="780" y="214" width="8" height="14" rx="3" fill="#1F6E6E"/>

    <text class="p-line" x="755" y="252">Sirve para guardar riqueza</text>
    <text class="p-line" x="755" y="274">para más tarde.</text>
  </g>

  <!-- ============ Bottom strip ============ -->
  <rect class="strip-bg" x="30" y="344" width="860" height="40" rx="8"/>
  <text class="strip-text" x="460" y="370">Sin las tres funciones, el dinero no serviría.</text>
</svg>
