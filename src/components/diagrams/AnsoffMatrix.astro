---
/**
 * 2x2 Ansoff growth matrix with risk gradient (left-to-right and
 * top-to-bottom) shown as the cells darken toward diversification.
 */
---
<svg viewBox="0 0 720 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Matriz de Ansoff: estrategias de crecimiento">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .axis-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; fill: #5C4A3D; }
      .sub-label { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #8A7868; }
      .c-1 { fill: #F5E5BC; stroke: #D4A24C; stroke-width: 1.5; }
      .c-2 { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 1.5; }
      .c-3 { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 1.5; }
      .c-4 { fill: #ECDCE5; stroke: #5B3A4E; stroke-width: 2; }
      .cell-name { font-family: 'Fraunces', serif; font-size: 19px; font-weight: 500; }
      .cell-desc { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #5C4A3D; }
      .cell-ex { font-family: 'Switzer', sans-serif; font-size: 10.5px; font-style: italic; fill: #8A7868; }
      .risk-label { font-family: 'Switzer', sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="480"/>

  <!-- Axis labels -->
  <text class="axis-label" x="245" y="45" text-anchor="middle">MERCADO EXISTENTE</text>
  <text class="axis-label" x="545" y="45" text-anchor="middle">MERCADO NUEVO</text>
  <text class="axis-label" x="55" y="195" transform="rotate(-90 55 195)" text-anchor="middle">PRODUCTO EXISTENTE</text>
  <text class="axis-label" x="55" y="385" transform="rotate(-90 55 385)" text-anchor="middle">PRODUCTO NUEVO</text>

  <!-- Cell 1: Penetración (top-left, lowest risk) -->
  <g>
    <rect class="c-1" x="100" y="60" width="280" height="170" rx="6"/>
    <text class="risk-label" x="120" y="86" fill="#A87A2A">RIESGO BAJO</text>
    <text class="cell-name" x="120" y="115" fill="#2A1F18">Penetración</text>
    <text class="cell-name" x="120" y="138" fill="#2A1F18">de mercado</text>
    <text class="cell-desc" x="120" y="165">Más del mismo producto</text>
    <text class="cell-desc" x="120" y="180">al mismo cliente.</text>
    <text class="cell-ex" x="120" y="208">Coca-Cola intensificando consumo</text>
    <text class="cell-ex" x="120" y="223">en mercados maduros.</text>
  </g>

  <!-- Cell 2: Desarrollo de mercado (top-right, medium risk) -->
  <g>
    <rect class="c-2" x="400" y="60" width="280" height="170" rx="6"/>
    <text class="risk-label" x="420" y="86" fill="#9C3A1C">RIESGO MEDIO</text>
    <text class="cell-name" x="420" y="115" fill="#2A1F18">Desarrollo</text>
    <text class="cell-name" x="420" y="138" fill="#2A1F18">de mercado</text>
    <text class="cell-desc" x="420" y="165">Mismo producto,</text>
    <text class="cell-desc" x="420" y="180">clientes nuevos.</text>
    <text class="cell-ex" x="420" y="208">Mercadona expandiéndose</text>
    <text class="cell-ex" x="420" y="223">a Portugal en 2019.</text>
  </g>

  <!-- Cell 3: Desarrollo de producto (bottom-left, medium risk) -->
  <g>
    <rect class="c-3" x="100" y="240" width="280" height="170" rx="6"/>
    <text class="risk-label" x="120" y="266" fill="#9C3A1C">RIESGO MEDIO</text>
    <text class="cell-name" x="120" y="295" fill="#2A1F18">Desarrollo</text>
    <text class="cell-name" x="120" y="318" fill="#2A1F18">de producto</text>
    <text class="cell-desc" x="120" y="345">Producto nuevo,</text>
    <text class="cell-desc" x="120" y="360">clientes conocidos.</text>
    <text class="cell-ex" x="120" y="388">Apple del iPhone</text>
    <text class="cell-ex" x="120" y="403">al iPad y al Apple Watch.</text>
  </g>

  <!-- Cell 4: Diversificación (bottom-right, highest risk) -->
  <g>
    <rect class="c-4" x="400" y="240" width="280" height="170" rx="6"/>
    <text class="risk-label" x="420" y="266" fill="#5B3A4E">RIESGO ALTO</text>
    <text class="cell-name" x="420" y="295" fill="#2A1F18">Diversificación</text>
    <text class="cell-desc" x="420" y="325">Producto nuevo,</text>
    <text class="cell-desc" x="420" y="340">mercado nuevo.</text>
    <text class="cell-ex" x="420" y="368">Amazon lanzando AWS desde</text>
    <text class="cell-ex" x="420" y="383">su origen como librería online.</text>
  </g>
</svg>
