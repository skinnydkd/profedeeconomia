---
/**
 * Anatomy of a junior CV: vertical layout with labeled sections
 * and side annotations with practical advice for first-CV writers.
 */
---
<svg viewBox="0 0 880 620" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Anatomía de un currículum vitae junior">
  <title>Estructura recomendada de un CV junior</title>
  <desc>Representación visual de un CV bien estructurado para un perfil junior, con secciones etiquetadas y anotaciones laterales de consejos prácticos.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .page { fill: #FFFFFF; stroke: #E5D4BD; stroke-width: 2; }
      .section { stroke-width: 1.5; }
      .sec-header { fill: #FBE3D6; stroke: #C44E2C; }
      .sec-resumen { fill: #F5E5BC; stroke: #D4A24C; }
      .sec-experiencia { fill: #FFFFFF; stroke: #5B3A4E; }
      .sec-formacion { fill: #FFFFFF; stroke: #1F6E6E; }
      .sec-idiomas { fill: #DBEDED; stroke: #1F6E6E; }
      .sec-digital { fill: #ECDCE5; stroke: #5B3A4E; }
      .sec-extras { fill: #F5EDD9; stroke: #8A7868; }
      .sec-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #2A1F18; }
      .sec-meta { font-family: 'Switzer', sans-serif; font-size: 10px; fill: #5C4A3D; }
      .sec-name { font-family: 'Fraunces', serif; font-size: 14px; font-weight: 500; fill: #2A1F18; }
      .photo { fill: #F5EDD9; stroke: #8A7868; stroke-width: 1.5; stroke-dasharray: 3 2; }
      .photo-label { font-family: 'Switzer', sans-serif; font-size: 9px; fill: #8A7868; text-anchor: middle; }
      .tag { fill: #C44E2C; }
      .tag-text { font-family: 'Switzer', sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; fill: #FFFFFF; text-anchor: middle; }
      .note-line { stroke: #C44E2C; stroke-width: 1; fill: none; stroke-dasharray: 3 2; }
      .note-text { font-family: 'Fraunces', serif; font-style: italic; font-size: 11.5px; fill: #2A1F18; }
      .note-emph { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; fill: #C44E2C; letter-spacing: 0.6px; text-transform: uppercase; }
      .title-top { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; fill: #5C4A3D; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="880" height="620"/>

  <!-- Top title -->
  <text class="title-top" x="290" y="30" text-anchor="middle">Página A4 · Una sola hoja</text>

  <!-- "Page" outer rectangle -->
  <rect class="page" x="220" y="45" width="380" height="540" rx="3"/>

  <!-- 1. Header (datos + foto opcional) -->
  <g>
    <rect class="section sec-header" x="235" y="60" width="350" height="80" rx="4"/>
    <text class="sec-label" x="250" y="82">1 · HEADER</text>
    <text class="sec-name" x="250" y="105">Nombre Apellidos</text>
    <text class="sec-meta" x="250" y="122">email · teléfono · LinkedIn · ciudad</text>
    <!-- Foto -->
    <rect class="photo" x="510" y="72" width="60" height="60" rx="3"/>
    <text class="photo-label" x="540" y="100">FOTO</text>
    <text class="photo-label" x="540" y="115">(opcional)</text>
  </g>

  <!-- 2. Resumen -->
  <g>
    <rect class="section sec-resumen" x="235" y="150" width="350" height="60" rx="4"/>
    <text class="sec-label" x="250" y="172">2 · RESUMEN</text>
    <text class="sec-meta" x="250" y="190">3-4 líneas · quién eres · qué buscas ·</text>
    <text class="sec-meta" x="250" y="203">qué aportas</text>
  </g>

  <!-- 3. Experiencia (con tag) -->
  <g>
    <rect class="section sec-experiencia" x="235" y="220" width="350" height="100" rx="4"/>
    <text class="sec-label" x="250" y="242">3 · EXPERIENCIA</text>
    <text class="sec-meta" x="250" y="262">Puesto · empresa · fechas</text>
    <text class="sec-meta" x="250" y="278">– Logro 1 (con resultado medible)</text>
    <text class="sec-meta" x="250" y="294">– Logro 2 (con resultado medible)</text>
    <text class="sec-meta" x="250" y="310">– Logro 3 (con resultado medible)</text>
    <!-- Tag -->
    <rect class="tag" x="450" y="232" width="130" height="18" rx="9"/>
    <text class="tag-text" x="515" y="245">verbos + resultados</text>
  </g>

  <!-- 4. Formación -->
  <g>
    <rect class="section sec-formacion" x="235" y="330" width="350" height="70" rx="4"/>
    <text class="sec-label" x="250" y="352">4 · FORMACIÓN</text>
    <text class="sec-meta" x="250" y="372">Título · centro · fechas</text>
    <text class="sec-meta" x="250" y="388">(en orden cronológico inverso)</text>
  </g>

  <!-- 5. Idiomas -->
  <g>
    <rect class="section sec-idiomas" x="235" y="410" width="170" height="65" rx="4"/>
    <text class="sec-label" x="250" y="432">5 · IDIOMAS</text>
    <text class="sec-meta" x="250" y="452">Castellano: C2</text>
    <text class="sec-meta" x="250" y="467">Inglés: B2 (Cambridge)</text>
  </g>

  <!-- 6. Habilidades digitales -->
  <g>
    <rect class="section sec-digital" x="415" y="410" width="170" height="65" rx="4"/>
    <text class="sec-label" x="430" y="432">6 · DIGITAL</text>
    <text class="sec-meta" x="430" y="452">Excel · Canva · CapCut</text>
    <text class="sec-meta" x="430" y="467">Python básico · IA</text>
  </g>

  <!-- 7. Extras -->
  <g>
    <rect class="section sec-extras" x="235" y="485" width="350" height="85" rx="4"/>
    <text class="sec-label" x="250" y="507">7 · VOLUNTARIADO / EXTRAS</text>
    <text class="sec-meta" x="250" y="527">Voluntariado, proyectos personales,</text>
    <text class="sec-meta" x="250" y="543">aficiones que aporten contexto,</text>
    <text class="sec-meta" x="250" y="559">premios o reconocimientos.</text>
  </g>

  <!-- LEFT ANNOTATIONS -->
  <g>
    <text class="note-emph" x="20" y="100">Consejo 1</text>
    <text class="note-text" x="20" y="118">Sin foto si dudas:</text>
    <text class="note-text" x="20" y="132">evita sesgos del</text>
    <text class="note-text" x="20" y="146">reclutador.</text>
    <line class="note-line" x1="140" y1="100" x2="510" y2="100"/>
  </g>

  <g>
    <text class="note-emph" x="20" y="190">Consejo 2</text>
    <text class="note-text" x="20" y="208">El resumen es el</text>
    <text class="note-text" x="20" y="222">"trailer" del CV:</text>
    <text class="note-text" x="20" y="236">decisivo en 6 seg.</text>
    <line class="note-line" x1="140" y1="180" x2="235" y2="180"/>
  </g>

  <g>
    <text class="note-emph" x="20" y="290">Consejo 3</text>
    <text class="note-text" x="20" y="308">"Coordiné equipo</text>
    <text class="note-text" x="20" y="322">de 4 y subimos</text>
    <text class="note-text" x="20" y="336">ventas un 20 %",</text>
    <text class="note-text" x="20" y="350">no "responsable</text>
    <text class="note-text" x="20" y="364">de ventas".</text>
    <line class="note-line" x1="140" y1="290" x2="235" y2="290"/>
  </g>

  <!-- RIGHT ANNOTATIONS -->
  <g>
    <text class="note-emph" x="620" y="180">Consejo 4</text>
    <text class="note-text" x="620" y="198">Personalizar el CV</text>
    <text class="note-text" x="620" y="212">por oferta: cada</text>
    <text class="note-text" x="620" y="226">envío adapta el</text>
    <text class="note-text" x="620" y="240">resumen y orden.</text>
    <line class="note-line" x1="600" y1="180" x2="615" y2="180"/>
  </g>

  <g>
    <text class="note-emph" x="620" y="440">Consejo 5</text>
    <text class="note-text" x="620" y="458">Idiomas con nivel</text>
    <text class="note-text" x="620" y="472">MCER (A1-C2),</text>
    <text class="note-text" x="620" y="486">no "fluido" o</text>
    <text class="note-text" x="620" y="500">"medio-alto".</text>
    <line class="note-line" x1="585" y1="442" x2="615" y2="442"/>
  </g>

  <g>
    <text class="note-emph" x="620" y="530">Consejo 6</text>
    <text class="note-text" x="620" y="548">1 página máx.</text>
    <text class="note-text" x="620" y="562">para perfil junior.</text>
    <text class="note-text" x="620" y="576">Más allá, se diluye.</text>
    <line class="note-line" x1="585" y1="530" x2="615" y2="530"/>
  </g>
</svg>
