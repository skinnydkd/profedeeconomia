---
/**
 * Two-column comparison of fixed mindset vs growth mindset (Carol Dweck):
 * a left panel listing fixed-mindset attitudes (intelligence is innate,
 * failure defines you) against a right panel with the contrasting
 * growth-mindset attitudes (abilities are trained, failure teaches),
 * closing with the unit's takeaway.
 *
 * Used in Eco 4ESO (mentalidad de crecimiento y actitud emprendedora).
 */
---
<svg viewBox="0 0 860 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="mc-title mc-desc">
  <title id="mc-title">Mentalidad fija frente a mentalidad de crecimiento</title>
  <desc id="mc-desc">Comparación entre la mentalidad fija (la inteligencia es innata, el fallo define) y la mentalidad de crecimiento (las capacidades se entrenan, el fallo enseña), según Carol Dweck.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .panel { fill: #FFFFFF; stroke: #E5D4BD; stroke-width: 1.5; }
      .head-fija { fill: #F5E5BC; }
      .head-crec { fill: #FBE3D6; }
      .head-line-fija { fill: #D4A24C; }
      .head-line-crec { fill: #C44E2C; }
      .head-text { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; font-weight: 600; fill: #2A1F18; text-anchor: middle; }
      .eyebrow { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; text-anchor: middle; }
      .eyebrow-fija { fill: #A87A2A; }
      .eyebrow-crec { fill: #9C3A1C; }
      .item { font-family: 'Switzer', sans-serif; font-size: 14.5px; font-weight: 500; fill: #5C4A3D; }
      .mark-fija { fill: #A87A2A; font-family: 'Switzer', sans-serif; font-size: 15px; font-weight: 700; }
      .mark-crec { fill: #C44E2C; font-family: 'Switzer', sans-serif; font-size: 15px; font-weight: 700; }
      .divider { stroke: #E5D4BD; stroke-width: 1.5; stroke-dasharray: 4 5; }
      .take-strip { fill: #2A1F18; }
      .take-text { font-family: 'Fraunces', serif; font-style: italic; font-size: 19px; font-weight: 600; fill: #FBF6EC; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="860" height="460"/>

  <!-- ============ LEFT PANEL — Mentalidad fija ============ -->
  <rect class="panel" x="36" y="32" width="378" height="320" rx="8"/>
  <!-- header -->
  <path class="head-fija" d="M36 40 a8 8 0 0 1 8 -8 h362 a8 8 0 0 1 8 8 v44 h-378 z"/>
  <rect class="head-line-fija" x="36" y="84" width="378" height="3"/>
  <text class="eyebrow eyebrow-fija" x="225" y="55">Mentalidad</text>
  <text class="head-text" x="225" y="78">fija</text>

  <!-- items -->
  <text class="mark-fija" x="58" y="124">·</text>
  <text class="item" x="74" y="124">La inteligencia es algo</text>
  <text class="item" x="74" y="143">con lo que se nace</text>

  <text class="mark-fija" x="58" y="178">·</text>
  <text class="item" x="74" y="178">Evito los retos por</text>
  <text class="item" x="74" y="197">miedo a fallar</text>

  <text class="mark-fija" x="58" y="232">·</text>
  <text class="item" x="74" y="232">Si fallo, es que no valgo</text>

  <text class="mark-fija" x="58" y="276">·</text>
  <text class="item" x="74" y="276">Las críticas me hunden</text>

  <text class="mark-fija" x="58" y="320">·</text>
  <text class="item" x="74" y="320">El esfuerzo es para los</text>
  <text class="item" x="74" y="339">que no tienen talento</text>

  <!-- ============ CENTRAL DIVIDER ============ -->
  <line class="divider" x1="430" y1="40" x2="430" y2="344"/>

  <!-- ============ RIGHT PANEL — Mentalidad de crecimiento ============ -->
  <rect class="panel" x="446" y="32" width="378" height="320" rx="8"/>
  <!-- header -->
  <path class="head-crec" d="M446 40 a8 8 0 0 1 8 -8 h362 a8 8 0 0 1 8 8 v44 h-378 z"/>
  <rect class="head-line-crec" x="446" y="84" width="378" height="3"/>
  <text class="eyebrow eyebrow-crec" x="635" y="55">Mentalidad de</text>
  <text class="head-text" x="635" y="78">crecimiento</text>

  <!-- items -->
  <text class="mark-crec" x="468" y="124">→</text>
  <text class="item" x="490" y="124">La inteligencia se</text>
  <text class="item" x="490" y="143">entrena con esfuerzo</text>

  <text class="mark-crec" x="468" y="178">→</text>
  <text class="item" x="490" y="178">Busco los retos como</text>
  <text class="item" x="490" y="197">oportunidad de aprender</text>

  <text class="mark-crec" x="468" y="232">→</text>
  <text class="item" x="490" y="232">Si fallo, aprendo y</text>
  <text class="item" x="490" y="251">vuelvo a intentarlo</text>

  <text class="mark-crec" x="468" y="296">→</text>
  <text class="item" x="490" y="296">Las críticas me</text>
  <text class="item" x="490" y="315">ayudan a mejorar</text>

  <text class="mark-crec" x="468" y="339">→</text>
  <text class="item" x="490" y="339">El esfuerzo es el camino para mejorar</text>

  <!-- ============ BOTTOM TAKEAWAY STRIP ============ -->
  <rect class="take-strip" x="36" y="386" width="788" height="44" rx="8"/>
  <text class="take-text" x="430" y="414">No naces emprendedor: te entrenas para serlo.</text>
</svg>
