---
/**
 * The five areas of digital competence as defined by the European DigComp
 * framework, laid out as five numbered cards (2 + 3 rows): information and
 * data, communication and collaboration, content creation, safety and
 * problem solving. Each card carries a one-line description.
 *
 * Used in FP (vocational) · digital competence module.
 */
---
<svg viewBox="0 0 920 440" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dc-title dc-desc">
  <title id="dc-title">Las cinco áreas de la competencia digital (DigComp)</title>
  <desc id="dc-desc">El marco europeo DigComp organiza la competencia digital en cinco áreas: información y datos, comunicación y colaboración, creación de contenidos, seguridad, y resolución de problemas.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .eyebrow { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; fill: #C44E2C; text-anchor: middle; }
      .heading { font-family: 'Fraunces', serif; font-size: 25px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .sub { font-family: 'Switzer', sans-serif; font-size: 13px; font-weight: 500; fill: #8A7868; text-anchor: middle; }
      .card { fill: #FFFFFF; stroke: #E5D4BD; stroke-width: 1.5; }
      .card-acc-t { fill: #FBE3D6; }
      .card-acc-m { fill: #F5E5BC; }
      .card-acc-l { fill: #DBEDED; }
      .num { font-family: 'JetBrains Mono', monospace; font-size: 26px; font-weight: 500; text-anchor: middle; }
      .num-t { fill: #9C3A1C; }
      .num-m { fill: #A87A2A; }
      .num-l { fill: #1F6E6E; }
      .card-title { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 500; fill: #2A1F18; }
      .card-desc { font-family: 'Switzer', sans-serif; font-size: 12.5px; font-weight: 400; fill: #5C4A3D; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="920" height="440"/>

  <!-- Header -->
  <text class="eyebrow" x="460" y="40">Marco europeo DigComp</text>
  <text class="heading" x="460" y="72">Las cinco áreas de la competencia digital</text>
  <text class="sub" x="460" y="96">El referente europeo organiza la competencia digital en cinco áreas.</text>

  <!-- Geometry: card 282 wide, 116 tall. Accent strip 56 wide on the left. -->
  <!-- Row 1: two cards centered -->
  <!-- Card 1 -->
  <g>
    <rect class="card" x="146" y="124" width="282" height="116" rx="6"/>
    <rect class="card-acc-t" x="146" y="124" width="56" height="116" rx="6"/>
    <rect class="card-acc-t" x="190" y="124" width="12" height="116"/>
    <line x1="202" y1="124" x2="202" y2="240" stroke="#E5D4BD" stroke-width="1.5"/>
    <text class="num num-t" x="174" y="190">1</text>
    <text class="card-title" x="218" y="158">Información y datos</text>
    <text class="card-desc" x="218" y="184">Buscar, evaluar y gestionar</text>
    <text class="card-desc" x="218" y="202">información fiable.</text>
  </g>
  <!-- Card 2 -->
  <g>
    <rect class="card" x="492" y="124" width="282" height="116" rx="6"/>
    <rect class="card-acc-m" x="492" y="124" width="56" height="116" rx="6"/>
    <rect class="card-acc-m" x="536" y="124" width="12" height="116"/>
    <line x1="548" y1="124" x2="548" y2="240" stroke="#E5D4BD" stroke-width="1.5"/>
    <text class="num num-m" x="520" y="190">2</text>
    <text class="card-title" x="564" y="158">Comunicación y colaboración</text>
    <text class="card-desc" x="564" y="184">Interactuar y trabajar en red</text>
    <text class="card-desc" x="564" y="202">con respeto (netiqueta).</text>
  </g>

  <!-- Row 2: three cards -->
  <!-- Card 3 -->
  <g>
    <rect class="card" x="24" y="284" width="282" height="116" rx="6"/>
    <rect class="card-acc-l" x="24" y="284" width="56" height="116" rx="6"/>
    <rect class="card-acc-l" x="68" y="284" width="12" height="116"/>
    <line x1="80" y1="284" x2="80" y2="400" stroke="#E5D4BD" stroke-width="1.5"/>
    <text class="num num-l" x="52" y="350">3</text>
    <text class="card-title" x="96" y="318">Creación de contenidos</text>
    <text class="card-desc" x="96" y="344">Crear y editar contenidos;</text>
    <text class="card-desc" x="96" y="362">nociones de derechos de autor.</text>
  </g>
  <!-- Card 4 -->
  <g>
    <rect class="card" x="319" y="284" width="282" height="116" rx="6"/>
    <rect class="card-acc-t" x="319" y="284" width="56" height="116" rx="6"/>
    <rect class="card-acc-t" x="363" y="284" width="12" height="116"/>
    <line x1="375" y1="284" x2="375" y2="400" stroke="#E5D4BD" stroke-width="1.5"/>
    <text class="num num-t" x="347" y="350">4</text>
    <text class="card-title" x="391" y="318">Seguridad</text>
    <text class="card-desc" x="391" y="344">Proteger dispositivos, datos</text>
    <text class="card-desc" x="391" y="362">personales, salud y entorno.</text>
  </g>
  <!-- Card 5 -->
  <g>
    <rect class="card" x="614" y="284" width="282" height="116" rx="6"/>
    <rect class="card-acc-m" x="614" y="284" width="56" height="116" rx="6"/>
    <rect class="card-acc-m" x="658" y="284" width="12" height="116"/>
    <line x1="670" y1="284" x2="670" y2="400" stroke="#E5D4BD" stroke-width="1.5"/>
    <text class="num num-m" x="642" y="350">5</text>
    <text class="card-title" x="686" y="318">Resolución de problemas</text>
    <text class="card-desc" x="686" y="344">Resolver incidencias y aprender</text>
    <text class="card-desc" x="686" y="362">herramientas nuevas.</text>
  </g>
</svg>
