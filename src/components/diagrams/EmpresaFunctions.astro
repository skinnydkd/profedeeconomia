---
/**
 * The four functions of a company arranged around a central node.
 * Used in Unit 1 to visualize how production, commercial, financial
 * and social functions interact through the firm's coordination.
 */
---
<svg viewBox="0 0 720 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Las cuatro funciones de la empresa">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .center { fill: #C44E2C; }
      .center-stroke { fill: none; stroke: #9C3A1C; stroke-width: 1.5; }
      .node { fill: #FFFFFF; stroke: #E5D4BD; stroke-width: 1.5; }
      .node-prod { stroke: #C44E2C; }
      .node-com { stroke: #D4A24C; }
      .node-fin { stroke: #1F6E6E; }
      .node-soc { stroke: #5B3A4E; }
      .arrow { fill: none; stroke: #8A7868; stroke-width: 1.2; stroke-dasharray: 3 3; }
      .label-eyebrow { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; }
      .label-title { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 500; }
      .label-body { font-family: 'Switzer', sans-serif; font-size: 11.5px; fill: #5C4A3D; }
      .center-eyebrow { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; fill: #FBE3D6; }
      .center-label { font-family: 'Fraunces', serif; font-style: italic; font-size: 24px; font-weight: 500; fill: #FFFFFF; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="480"/>

  <!-- Connecting lines -->
  <line class="arrow" x1="360" y1="240" x2="200" y2="120"/>
  <line class="arrow" x1="360" y1="240" x2="520" y2="120"/>
  <line class="arrow" x1="360" y1="240" x2="200" y2="360"/>
  <line class="arrow" x1="360" y1="240" x2="520" y2="360"/>

  <!-- Central node: La empresa -->
  <circle class="center-stroke" cx="360" cy="240" r="74"/>
  <circle class="center" cx="360" cy="240" r="68"/>
  <text class="center-eyebrow" x="360" y="232" text-anchor="middle">LA</text>
  <text class="center-label" x="360" y="258" text-anchor="middle">EMPRESA</text>

  <!-- Top-left: Productiva -->
  <g>
    <rect class="node node-prod" x="60" y="60" width="240" height="110" rx="6"/>
    <text class="label-eyebrow" x="80" y="88" fill="#9C3A1C">FUNCIÓN PRODUCTIVA</text>
    <text class="label-title" x="80" y="115" fill="#2A1F18">Transformar</text>
    <text class="label-body" x="80" y="138">De materias primas, trabajo y</text>
    <text class="label-body" x="80" y="153">capital al producto final.</text>
  </g>

  <!-- Top-right: Comercial -->
  <g>
    <rect class="node node-com" x="420" y="60" width="240" height="110" rx="6"/>
    <text class="label-eyebrow" x="440" y="88" fill="#A87A2A">FUNCIÓN COMERCIAL</text>
    <text class="label-title" x="440" y="115" fill="#2A1F18">Conectar oferta y demanda</text>
    <text class="label-body" x="440" y="138">Quién compra, a qué precio,</text>
    <text class="label-body" x="440" y="153">por qué canal.</text>
  </g>

  <!-- Bottom-left: Financiera -->
  <g>
    <rect class="node node-fin" x="60" y="310" width="240" height="110" rx="6"/>
    <text class="label-eyebrow" x="80" y="338" fill="#1F6E6E">FUNCIÓN FINANCIERA</text>
    <text class="label-title" x="80" y="365" fill="#2A1F18">Captar y gestionar capital</text>
    <text class="label-body" x="80" y="388">Préstamos, ampliaciones,</text>
    <text class="label-body" x="80" y="403">reinversión, tesorería.</text>
  </g>

  <!-- Bottom-right: Social -->
  <g>
    <rect class="node node-soc" x="420" y="310" width="240" height="110" rx="6"/>
    <text class="label-eyebrow" x="440" y="338" fill="#5B3A4E">FUNCIÓN SOCIAL</text>
    <text class="label-title" x="440" y="365" fill="#2A1F18">Impacto en el entorno</text>
    <text class="label-body" x="440" y="388">Empleo, impuestos, RSC,</text>
    <text class="label-body" x="440" y="403">externalidades.</text>
  </g>
</svg>
