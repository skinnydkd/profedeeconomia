---
/**
 * Pentagonal arrangement of five team roles around a central "EQUIPO" node.
 * Belbin simplified to five complementary roles for project-based learning.
 */
---
<svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="roles-title roles-desc">
  <title id="roles-title">Cinco roles complementarios de un equipo</title>
  <desc id="roles-desc">Disposición pentagonal: cinco roles (cerebro, coordinador, implementador, evaluador y cohesionador) conectados por líneas finas a un nodo central "EQUIPO".</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .center { fill: #2A1F18; stroke: #5C4A3D; stroke-width: 2; }
      .role-cerebro { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .role-coordinador { fill: #F5E5BC; stroke: #D4A24C; stroke-width: 2; }
      .role-implementador { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 2; }
      .role-evaluador { fill: #ECDCE5; stroke: #5B3A4E; stroke-width: 2; }
      .role-cohesionador { fill: #F5EDD9; stroke: #8A7868; stroke-width: 2; }
      .link { fill: none; stroke: #C8B79A; stroke-width: 1; stroke-dasharray: 3 3; }
      .center-eyebrow { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; fill: #FBF6EC; text-anchor: middle; }
      .center-name { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; font-weight: 500; fill: #FFFFFF; text-anchor: middle; }
      .role-name { font-family: 'Fraunces', serif; font-size: 15px; font-weight: 500; text-anchor: middle; }
      .role-tag { font-family: 'Switzer', sans-serif; font-size: 10.5px; fill: #5C4A3D; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="800" height="500"/>

  <!-- Links from each role node to the center -->
  <line class="link" x1="400" y1="105" x2="400" y2="220"/>
  <line class="link" x1="675" y1="215" x2="445" y2="245"/>
  <line class="link" x1="570" y1="430" x2="430" y2="285"/>
  <line class="link" x1="230" y1="430" x2="370" y2="285"/>
  <line class="link" x1="125" y1="215" x2="355" y2="245"/>

  <!-- Center node -->
  <ellipse class="center" cx="400" cy="250" rx="80" ry="50"/>
  <text class="center-eyebrow" x="400" y="240">EL CONJUNTO</text>
  <text class="center-name" x="400" y="270">Equipo</text>

  <!-- Top: Cerebro (terracota) -->
  <g>
    <ellipse class="role-cerebro" cx="400" cy="65" rx="105" ry="42"/>
    <text class="role-name" x="400" y="58" fill="#9C3A1C">Cerebro</text>
    <text class="role-tag" x="400" y="78">ideas · innovación</text>
    <text class="role-tag" x="400" y="92">creatividad</text>
  </g>

  <!-- Top-right: Coordinador (mostassa) -->
  <g>
    <ellipse class="role-coordinador" cx="680" cy="175" rx="105" ry="42"/>
    <text class="role-name" x="680" y="168" fill="#A87A2A">Coordinador</text>
    <text class="role-tag" x="680" y="188">visión global · plazos</text>
    <text class="role-tag" x="680" y="202">reparto de tareas</text>
  </g>

  <!-- Bottom-right: Evaluador (berenjena/fopp) -->
  <g>
    <ellipse class="role-evaluador" cx="580" cy="445" rx="105" ry="42"/>
    <text class="role-name" x="580" y="438" fill="#5B3A4E">Evaluador</text>
    <text class="role-tag" x="580" y="458">crítica · análisis</text>
    <text class="role-tag" x="580" y="472">detecta riesgos</text>
  </g>

  <!-- Bottom-left: Cohesionador (cream) -->
  <g>
    <ellipse class="role-cohesionador" cx="220" cy="445" rx="105" ry="42"/>
    <text class="role-name" x="220" y="438" fill="#2A1F18">Cohesionador</text>
    <text class="role-tag" x="220" y="458">clima · empatía</text>
    <text class="role-tag" x="220" y="472">cuida al equipo</text>
  </g>

  <!-- Left: Implementador (teal) -->
  <g>
    <ellipse class="role-implementador" cx="120" cy="175" rx="105" ry="42"/>
    <text class="role-name" x="120" y="168" fill="#0E4040">Implementador</text>
    <text class="role-tag" x="120" y="188">ejecuta · entrega</text>
    <text class="role-tag" x="120" y="202">fiabilidad</text>
  </g>
</svg>
