---
/**
 * Porter's Five Forces diagram. Central node = competitive rivalry,
 * surrounded by the four forces that shape it.
 */
---
<svg viewBox="0 0 720 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Las cinco fuerzas competitivas de Porter">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .center { fill: #C44E2C; }
      .center-stroke { fill: none; stroke: #9C3A1C; stroke-width: 1.5; }
      .force { fill: #FFFFFF; stroke: #D4A24C; stroke-width: 2; }
      .force-rect { fill: #FFFFFF; stroke: #1F6E6E; stroke-width: 2; }
      .arrow { fill: none; stroke: #5C4A3D; stroke-width: 1.8; marker-end: url(#arrowhead); }
      .label-eyebrow { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; }
      .label-title { font-family: 'Fraunces', serif; font-size: 14px; font-weight: 500; fill: #2A1F18; }
      .label-body { font-family: 'Switzer', sans-serif; font-size: 10.5px; fill: #5C4A3D; }
      .center-label-1 { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #FBE3D6; text-anchor: middle; }
      .center-label-2 { font-family: 'Fraunces', serif; font-style: italic; font-size: 18px; font-weight: 500; fill: #FFFFFF; text-anchor: middle; }
    </style>
    <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#5C4A3D"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="540"/>

  <!-- Arrows pointing to center -->
  <line class="arrow" x1="360" y1="100" x2="360" y2="220"/>
  <line class="arrow" x1="360" y1="440" x2="360" y2="320"/>
  <line class="arrow" x1="180" y1="270" x2="290" y2="270"/>
  <line class="arrow" x1="540" y1="270" x2="430" y2="270"/>

  <!-- Top: Nuevos entrantes -->
  <g>
    <rect class="force" x="220" y="30" width="280" height="70" rx="6"/>
    <text class="label-eyebrow" x="360" y="55" fill="#A87A2A" text-anchor="middle">3 · AMENAZA</text>
    <text class="label-title" x="360" y="78" text-anchor="middle">Nuevos entrantes</text>
    <text class="label-body" x="360" y="93" text-anchor="middle">Barreras de entrada al sector</text>
  </g>

  <!-- Bottom: Sustitutivos -->
  <g>
    <rect class="force" x="220" y="440" width="280" height="70" rx="6"/>
    <text class="label-eyebrow" x="360" y="465" fill="#A87A2A" text-anchor="middle">4 · AMENAZA</text>
    <text class="label-title" x="360" y="488" text-anchor="middle">Productos sustitutivos</text>
    <text class="label-body" x="360" y="503" text-anchor="middle">Alternativas que cubren la misma función</text>
  </g>

  <!-- Left: Proveedores -->
  <g>
    <rect class="force-rect" x="20" y="225" width="160" height="90" rx="6"/>
    <text class="label-eyebrow" x="100" y="250" fill="#1F6E6E" text-anchor="middle">2 · PODER DE</text>
    <text class="label-title" x="100" y="275" text-anchor="middle">Proveedores</text>
    <text class="label-body" x="100" y="293" text-anchor="middle">Si son pocos y críticos,</text>
    <text class="label-body" x="100" y="307" text-anchor="middle">imponen condiciones.</text>
  </g>

  <!-- Right: Clientes -->
  <g>
    <rect class="force-rect" x="540" y="225" width="160" height="90" rx="6"/>
    <text class="label-eyebrow" x="620" y="250" fill="#1F6E6E" text-anchor="middle">1 · PODER DE</text>
    <text class="label-title" x="620" y="275" text-anchor="middle">Clientes</text>
    <text class="label-body" x="620" y="293" text-anchor="middle">Si pueden comparar y</text>
    <text class="label-body" x="620" y="307" text-anchor="middle">cambiar, presionan precios.</text>
  </g>

  <!-- Center: Rivalidad -->
  <ellipse class="center-stroke" cx="360" cy="270" rx="90" ry="58"/>
  <ellipse class="center" cx="360" cy="270" rx="84" ry="52"/>
  <text class="center-label-1" x="360" y="262">5 · RIVALIDAD</text>
  <text class="center-label-2" x="360" y="285">en el sector</text>
</svg>
