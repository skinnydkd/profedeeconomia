---
/**
 * The four types of innovation from the Oslo Manual arranged in a 2x2
 * grid: product, process, organisation and marketing. Each cell pairs a
 * one-line definition with a concrete everyday example, underlining that
 * innovating does not require inventing a brand-new product.
 *
 * Used in FP / Bachillerato entrepreneurship units (two books).
 */
---
<svg viewBox="0 0 840 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ti-title ti-desc">
  <title id="ti-title">Los cuatro tipos de innovación</title>
  <desc id="ti-desc">La innovación puede ser de producto, de proceso, de organización o de marketing. No hace falta inventar un producto nuevo para innovar.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .eyebrow { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase; fill: #C44E2C; text-anchor: middle; }
      .heading { font-family: 'Fraunces', serif; font-size: 27px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .note { font-family: 'Switzer', sans-serif; font-size: 13px; font-weight: 500; fill: #5C4A3D; text-anchor: middle; }
      .cell { stroke: #E5D4BD; stroke-width: 1.5; }
      .cell-terr { fill: #FBE3D6; fill-opacity: 0.55; }
      .cell-must { fill: #F5E5BC; fill-opacity: 0.55; }
      .cell-teal { fill: #DBEDED; fill-opacity: 0.6; }
      .cell-ink  { fill: #F5EDD9; }
      .bar-terr { fill: #C44E2C; }
      .bar-must { fill: #D4A24C; }
      .bar-teal { fill: #1F6E6E; }
      .bar-ink  { fill: #5C4A3D; }
      .cell-title { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 500; fill: #2A1F18; }
      .cell-def { font-family: 'Switzer', sans-serif; font-size: 13.5px; font-weight: 500; fill: #5C4A3D; }
      .cell-ex { font-family: 'Fraunces', serif; font-style: italic; font-size: 13.5px; font-weight: 500; fill: #8A7868; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="840" height="540"/>

  <!-- Header -->
  <text class="eyebrow" x="420" y="44">Manual de Oslo</text>
  <text class="heading" x="420" y="78">Los cuatro tipos de innovación</text>
  <text class="note" x="420" y="106">No hace falta inventar un producto nuevo: se puede innovar en el proceso, la organización o el marketing.</text>

  <!-- Grid: two columns at x=60 and x=432, two rows at y=140 and y=348.
       Cell 348 wide, 178 tall, gap 24. -->

  <!-- Top-left: De producto (terracota) -->
  <rect class="cell cell-terr" x="60" y="140" width="348" height="178" rx="6"/>
  <rect class="bar-terr" x="60" y="140" width="6" height="178" rx="3"/>
  <text class="cell-title" x="84" y="176">De producto</text>
  <text class="cell-def" x="84" y="206">Un bien o servicio nuevo o mejorado.</text>
  <text class="cell-ex" x="84" y="246">Ej.: un envase de zumo que se</text>
  <text class="cell-ex" x="84" y="266">conserva sin frío.</text>

  <!-- Top-right: De proceso (mustard) -->
  <rect class="cell cell-must" x="432" y="140" width="348" height="178" rx="6"/>
  <rect class="bar-must" x="432" y="140" width="6" height="178" rx="3"/>
  <text class="cell-title" x="456" y="176">De proceso</text>
  <text class="cell-def" x="456" y="206">Una forma nueva de producir o distribuir.</text>
  <text class="cell-ex" x="456" y="246">Ej.: pedir por app y recoger</text>
  <text class="cell-ex" x="456" y="266">en taquilla.</text>

  <!-- Bottom-left: De organización (teal) -->
  <rect class="cell cell-teal" x="60" y="348" width="348" height="178" rx="6"/>
  <rect class="bar-teal" x="60" y="348" width="6" height="178" rx="3"/>
  <text class="cell-title" x="84" y="384">De organización</text>
  <text class="cell-def" x="84" y="414">Una nueva forma de organizar el</text>
  <text class="cell-def" x="84" y="434">trabajo o la empresa.</text>
  <text class="cell-ex" x="84" y="474">Ej.: equipos autónomos sin</text>
  <text class="cell-ex" x="84" y="494">jefes intermedios.</text>

  <!-- Bottom-right: De marketing (ink-soft) -->
  <rect class="cell cell-ink" x="432" y="348" width="348" height="178" rx="6"/>
  <rect class="bar-ink" x="432" y="348" width="6" height="178" rx="3"/>
  <text class="cell-title" x="456" y="384">De marketing</text>
  <text class="cell-def" x="456" y="414">Un nuevo diseño, envase, canal o</text>
  <text class="cell-def" x="456" y="434">forma de vender.</text>
  <text class="cell-ex" x="456" y="474">Ej.: vender solo online con</text>
  <text class="cell-ex" x="456" y="494">suscripción.</text>
</svg>
