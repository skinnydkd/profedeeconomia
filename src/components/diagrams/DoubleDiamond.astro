---
/**
 * Double diamond model of creative process: alternating phases of
 * divergence and convergence, applied twice (problem space + solution
 * space). Used in Unit 5 to make explicit the rhythm of design
 * thinking.
 */
---
<svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="El doble diamante: divergencia y convergencia, dos veces">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .diamond-div { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .diamond-conv { fill: #F5E5BC; stroke: #D4A24C; stroke-width: 2; }
      .phase-label { font-family: 'Switzer', sans-serif; font-size: 10.5px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; text-anchor: middle; }
      .phase-name { font-family: 'Fraunces', serif; font-style: italic; font-size: 16px; font-weight: 500; text-anchor: middle; }
      .phase-desc { font-family: 'Switzer', sans-serif; font-size: 10.5px; text-anchor: middle; fill: #5C4A3D; }
      .stage-label { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; text-anchor: middle; }
      .vertical-label { font-family: 'Switzer', sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; fill: #8A7868; }
      .arrow { fill: none; stroke: #8A7868; stroke-width: 1.4; stroke-dasharray: 4 3; marker-end: url(#tip); }
    </style>
    <marker id="tip" markerWidth="9" markerHeight="9" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 9 3, 0 6" fill="#8A7868"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="760" height="380"/>

  <!-- Stage labels at top -->
  <text class="stage-label" x="200" y="40" fill="#C44E2C">PROBLEMA</text>
  <text class="stage-label" x="560" y="40" fill="#D4A24C">SOLUCIÓN</text>

  <!-- First diamond (problem space): D1 (divergence) + D2 (convergence) -->
  <polygon class="diamond-div" points="60,180 200,90 200,270"/>
  <polygon class="diamond-conv" points="340,90 340,270 200,180"/>

  <!-- Second diamond (solution space): D3 (divergence) + D4 (convergence) -->
  <polygon class="diamond-div" points="420,180 560,90 560,270"/>
  <polygon class="diamond-conv" points="700,90 700,270 560,180"/>

  <!-- Phase labels for the four wedges -->
  <text class="phase-label" x="135" y="170" fill="#9C3A1C">DIVERGIR</text>
  <text class="phase-name" x="135" y="195">Descubrir</text>

  <text class="phase-label" x="265" y="170" fill="#A87A2A">CONVERGIR</text>
  <text class="phase-name" x="265" y="195">Definir</text>

  <text class="phase-label" x="495" y="170" fill="#9C3A1C">DIVERGIR</text>
  <text class="phase-name" x="495" y="195">Desarrollar</text>

  <text class="phase-label" x="625" y="170" fill="#A87A2A">CONVERGIR</text>
  <text class="phase-name" x="625" y="195">Entregar</text>

  <!-- Descriptions below -->
  <text class="phase-desc" x="135" y="295">Entrevistas,</text>
  <text class="phase-desc" x="135" y="310">observación,</text>
  <text class="phase-desc" x="135" y="325">mapa de empatía.</text>

  <text class="phase-desc" x="265" y="295">Síntesis del</text>
  <text class="phase-desc" x="265" y="310">problema real,</text>
  <text class="phase-desc" x="265" y="325">hipótesis críticas.</text>

  <text class="phase-desc" x="495" y="295">Ideación divergente,</text>
  <text class="phase-desc" x="495" y="310">brainwriting, SCAMPER,</text>
  <text class="phase-desc" x="495" y="325">prototipos baratos.</text>

  <text class="phase-desc" x="625" y="295">Selección,</text>
  <text class="phase-desc" x="625" y="310">validación con</text>
  <text class="phase-desc" x="625" y="325">cliente, refinado.</text>

  <!-- Bottom direction arrows -->
  <line class="arrow" x1="40" y1="355" x2="720" y2="355"/>
  <text class="vertical-label" x="380" y="370" text-anchor="middle">FLUJO TEMPORAL: 4-6 SEMANAS PARA UN CICLO COMPLETO</text>
</svg>
