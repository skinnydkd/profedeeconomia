---
/**
 * Composition of "coste empresa" (total labor cost) shown as a
 * three-tier stacked bar: líquido (what the worker actually receives)
 * → bruto → coste empresa total. Numbers are illustrative for a
 * salary of 1.500 € brutos/mes.
 */
---
<svg viewBox="0 0 720 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Composición del coste empresa">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .bar-base { fill: #E5F1DD; stroke: #4F8C3F; stroke-width: 2; }
      .bar-mid { fill: #F5E5BC; stroke: #D4A24C; stroke-width: 2; }
      .bar-top { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .arrow { stroke: #5C4A3D; stroke-width: 1.5; fill: none; marker-end: url(#arrow-end); }
      .level-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; }
      .amount { font-family: 'Fraunces', serif; font-style: italic; font-size: 28px; font-weight: 500; }
      .desc { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #5C4A3D; }
      .annotation { font-family: 'Fraunces', serif; font-style: italic; font-size: 12px; fill: #2A1F18; }
      .annotation-label { font-family: 'Switzer', sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
    </style>
    <marker id="arrow-end" markerWidth="9" markerHeight="9" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 9 3, 0 6" fill="#5C4A3D"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="460"/>

  <!-- Title strip -->
  <text class="level-label" x="360" y="38" text-anchor="middle" fill="#5C4A3D">QUÉ COBRA LA PERSONA Y QUÉ PAGA LA EMPRESA</text>

  <!-- Three bars from bottom to top -->
  <!-- Bar 1 (bottom): Líquido = 1200 € (width 60%) -->
  <rect class="bar-base" x="180" y="340" width="220" height="50" rx="4"/>
  <text class="level-label" x="190" y="370" fill="#2A5A1F">LÍQUIDO</text>
  <text class="amount" x="380" y="375" text-anchor="end" fill="#2A5A1F">1.200 €</text>

  <!-- Bar 2 (middle): Bruto = 1500 € (width 75%) -->
  <rect class="bar-mid" x="180" y="220" width="280" height="50" rx="4"/>
  <text class="level-label" x="190" y="250" fill="#A87A2A">SALARIO BRUTO</text>
  <text class="amount" x="440" y="255" text-anchor="end" fill="#A87A2A">1.500 €</text>

  <!-- Bar 3 (top): Coste empresa = 1950 € (width 97.5%) -->
  <rect class="bar-top" x="180" y="100" width="370" height="50" rx="4"/>
  <text class="level-label" x="190" y="130" fill="#9C3A1C">COSTE EMPRESA</text>
  <text class="amount" x="530" y="135" text-anchor="end" fill="#9C3A1C">1.950 €</text>

  <!-- Annotation between bar 1 and bar 2: deducciones -->
  <line class="arrow" x1="400" y1="340" x2="400" y2="280"/>
  <line class="arrow" x1="400" y1="220" x2="400" y2="280" stroke-dasharray="0"/>
  <rect x="420" y="285" width="270" height="48" rx="4" fill="#FFFFFF" stroke="#D4A24C" stroke-width="1"/>
  <text class="annotation-label" x="430" y="302" fill="#A87A2A">DEDUCCIONES DEL TRABAJADOR</text>
  <text class="annotation" x="430" y="318">Cotización Seguridad Social (≈6,35%)</text>
  <text class="annotation" x="430" y="330">+ Retención IRPF (variable según salario)</text>

  <!-- Annotation between bar 2 and bar 3: cuotas patronales -->
  <line class="arrow" x1="460" y1="220" x2="460" y2="160"/>
  <line class="arrow" x1="460" y1="100" x2="460" y2="160" stroke-dasharray="0"/>
  <rect x="480" y="165" width="210" height="48" rx="4" fill="#FFFFFF" stroke="#C44E2C" stroke-width="1"/>
  <text class="annotation-label" x="490" y="182" fill="#9C3A1C">CUOTAS PATRONALES</text>
  <text class="annotation" x="490" y="198">≈ 30 % del bruto a la</text>
  <text class="annotation" x="490" y="210">Seguridad Social. NO aparece en nómina.</text>

  <!-- Vertical scale -->
  <line x1="160" y1="100" x2="160" y2="390" stroke="#8A7868" stroke-width="1.5"/>
  <line x1="155" y1="125" x2="165" y2="125" stroke="#8A7868" stroke-width="1.5"/>
  <line x1="155" y1="245" x2="165" y2="245" stroke="#8A7868" stroke-width="1.5"/>
  <line x1="155" y1="365" x2="165" y2="365" stroke="#8A7868" stroke-width="1.5"/>

  <!-- Bottom note -->
  <text x="360" y="430" font-family="Fraunces" font-style="italic" font-size="13" fill="#5C4A3D" text-anchor="middle">El coste real para la empresa es 1,30 × el salario bruto, no el salario líquido.</text>
</svg>
