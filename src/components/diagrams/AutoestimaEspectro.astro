---
/**
 * Horizontal self-esteem spectrum with three zones: weak self-esteem
 * (left), healthy self-esteem (centre, highlighted) and inflated
 * self-esteem (right). Each zone lists typical attitudes, framing the
 * healthy attitude as the balanced middle ground, not either extreme.
 *
 * Used in FOPP 4ESO (personal development and self-esteem).
 */
---
<svg viewBox="0 0 920 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ae-title ae-desc">
  <title id="ae-title">El espectro de la autoestima</title>
  <desc id="ae-desc">La autoestima sana está en el centro: ni hundirse con cada crítica (débil) ni creerse por encima de todo (inflada). Reconocer el propio valor y los límites sin pisar a nadie.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .zone { stroke: #E5D4BD; stroke-width: 1.5; }
      .zone-weak { fill: #F5E5BC; }
      .zone-healthy { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 2.5; }
      .zone-inflated { fill: #FBE3D6; }
      .header { font-family: 'Fraunces', serif; font-style: italic; font-size: 23px; font-weight: 600; fill: #2A1F18; text-anchor: middle; }
      .header-healthy { fill: #1F6E6E; }
      .header-inflated { fill: #9C3A1C; }
      .tag { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #8A7868; text-anchor: middle; }
      .bullet { font-family: 'Switzer', sans-serif; font-size: 14px; font-weight: 500; fill: #5C4A3D; text-anchor: middle; }
      .bullet-healthy { fill: #2A1F18; }
      .axis-line { stroke: #E5D4BD; stroke-width: 2; }
      .axis-end { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; fill: #8A7868; }
      .note { font-family: 'Fraunces', serif; font-style: italic; font-size: 16px; font-weight: 500; fill: #C44E2C; text-anchor: middle; }
      .note-arrow { stroke: #C44E2C; stroke-width: 2; fill: none; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="920" height="420"/>

  <!-- Spectrum axis under the zones -->
  <line class="axis-line" x1="40" y1="100" x2="880" y2="100"/>
  <text class="axis-end" x="40" y="86" text-anchor="start">Extremo</text>
  <text class="axis-end" x="880" y="86" text-anchor="end">Extremo</text>

  <!-- Three zones: weak (left), healthy (centre), inflated (right) -->
  <rect class="zone zone-weak" x="40" y="120" width="270" height="210" rx="6"/>
  <rect class="zone zone-healthy" x="325" y="120" width="270" height="210" rx="6"/>
  <rect class="zone zone-inflated" x="610" y="120" width="270" height="210" rx="6"/>

  <!-- Weak self-esteem -->
  <text class="header" x="175" y="160">Autoestima débil</text>
  <text class="tag" x="175" y="184">Por defecto</text>
  <text class="bullet" x="175" y="222">Me hundo con</text>
  <text class="bullet" x="175" y="241">cualquier crítica</text>
  <text class="bullet" x="175" y="271">Creo que no valgo</text>
  <text class="bullet" x="175" y="301">Dejo que decidan</text>
  <text class="bullet" x="175" y="320">por mí</text>

  <!-- Healthy self-esteem (centre, highlighted) -->
  <text class="header header-healthy" x="460" y="160">Autoestima sana</text>
  <text class="tag" x="460" y="184">Equilibrio</text>
  <text class="bullet bullet-healthy" x="460" y="218">Reconozco lo que valgo</text>
  <text class="bullet bullet-healthy" x="460" y="237">y lo que me falta</text>
  <text class="bullet bullet-healthy" x="460" y="267">Encajo las críticas</text>
  <text class="bullet bullet-healthy" x="460" y="286">sin hundirme</text>
  <text class="bullet bullet-healthy" x="460" y="316">Pongo límites sin</text>
  <text class="bullet bullet-healthy" x="460" y="335">pisar a nadie</text>

  <!-- Inflated self-esteem -->
  <text class="header header-inflated" x="745" y="160">Autoestima inflada</text>
  <text class="tag" x="745" y="184">Por exceso</text>
  <text class="bullet" x="745" y="222">Nunca es culpa mía</text>
  <text class="bullet" x="745" y="252">Necesito tener</text>
  <text class="bullet" x="745" y="271">razón siempre</text>
  <text class="bullet" x="745" y="301">Piso a otros para</text>
  <text class="bullet" x="745" y="320">sentirme arriba</text>

  <!-- Note: the healthy place is the centre, not the extremes -->
  <path class="note-arrow" d="M 460 348 L 460 372"/>
  <path class="note-arrow" d="M 452 364 L 460 372 L 468 364"/>
  <text class="note" x="460" y="396">Lo sano está en el centro, no en los extremos</text>
</svg>
