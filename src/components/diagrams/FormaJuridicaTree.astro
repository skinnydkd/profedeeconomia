---
/**
 * Decision tree for choosing legal form. Five terminal forms reachable
 * by answering the four key questions above (alone? capital? co-op?
 * future investment?).
 */
---
<svg viewBox="0 0 760 580" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Árbol de decisión para elegir forma jurídica">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .question { fill: #FFFFFF; stroke: #C44E2C; stroke-width: 2; }
      .answer-yes { stroke: #4F8C3F; stroke-width: 1.5; fill: none; marker-end: url(#arrow-green); }
      .answer-no { stroke: #B83A3A; stroke-width: 1.5; fill: none; marker-end: url(#arrow-red); }
      .terminal { stroke-width: 2; }
      .term-1 { fill: #FBE3D6; stroke: #C44E2C; }
      .term-2 { fill: #F5E5BC; stroke: #D4A24C; }
      .term-3 { fill: #DBEDED; stroke: #1F6E6E; }
      .term-4 { fill: #ECDCE5; stroke: #5B3A4E; }
      .term-5 { fill: #E5F1DD; stroke: #4F8C3F; }
      .q-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; text-anchor: middle; fill: #C44E2C; }
      .q-text { font-family: 'Fraunces', serif; font-size: 13px; font-weight: 500; text-anchor: middle; fill: #2A1F18; }
      .edge-label { font-family: 'Switzer', sans-serif; font-size: 10.5px; font-weight: 700; letter-spacing: 0.5px; }
      .term-name { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 500; text-anchor: middle; }
    </style>
    <marker id="arrow-green" markerWidth="9" markerHeight="9" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 9 3, 0 6" fill="#4F8C3F"/>
    </marker>
    <marker id="arrow-red" markerWidth="9" markerHeight="9" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 9 3, 0 6" fill="#B83A3A"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="760" height="580"/>

  <!-- Q1: ¿Vas solo? -->
  <g>
    <rect class="question" x="290" y="20" width="180" height="60" rx="6"/>
    <text class="q-label" x="380" y="40">PREGUNTA 1</text>
    <text class="q-text" x="380" y="60">¿Vas solo?</text>
  </g>

  <!-- Edges from Q1 -->
  <line class="answer-yes" x1="340" y1="80" x2="180" y2="130"/>
  <text class="edge-label" x="220" y="100" fill="#4F8C3F">SÍ</text>

  <line class="answer-no" x1="420" y1="80" x2="580" y2="130"/>
  <text class="edge-label" x="540" y="100" fill="#B83A3A">NO</text>

  <!-- Q2: ¿Capital < 3.000 €? (left) -->
  <g>
    <rect class="question" x="80" y="135" width="200" height="60" rx="6"/>
    <text class="q-label" x="180" y="155">PREGUNTA 2</text>
    <text class="q-text" x="180" y="175">¿Capital &lt; 3.000 €?</text>
  </g>

  <!-- Q3: ¿Cooperativa? (right) -->
  <g>
    <rect class="question" x="480" y="135" width="200" height="60" rx="6"/>
    <text class="q-label" x="580" y="155">PREGUNTA 3</text>
    <text class="q-text" x="580" y="175">¿Lógica cooperativa?</text>
  </g>

  <!-- Edges Q2 -->
  <line class="answer-yes" x1="135" y1="195" x2="105" y2="240"/>
  <text class="edge-label" x="105" y="220" fill="#4F8C3F">SÍ</text>

  <line class="answer-no" x1="225" y1="195" x2="255" y2="240"/>
  <text class="edge-label" x="250" y="220" fill="#B83A3A">NO</text>

  <!-- Edges Q3 -->
  <line class="answer-yes" x1="535" y1="195" x2="505" y2="240"/>
  <text class="edge-label" x="500" y="220" fill="#4F8C3F">SÍ</text>

  <line class="answer-no" x1="625" y1="195" x2="655" y2="240"/>
  <text class="edge-label" x="660" y="220" fill="#B83A3A">NO</text>

  <!-- T1: Autónomo -->
  <g>
    <rect class="terminal term-2" x="35" y="245" width="160" height="55" rx="6"/>
    <text class="term-name" x="115" y="278" fill="#A87A2A">Autónomo</text>
  </g>

  <!-- Q4: ¿Beneficio > 50 K€ o riesgo alto? (going from Q2 NO) -->
  <g>
    <rect class="question" x="190" y="245" width="200" height="60" rx="6"/>
    <text class="q-label" x="290" y="265">PREGUNTA 4</text>
    <text class="q-text" x="290" y="285">¿Beneficio &gt; 50 K€?</text>
  </g>

  <!-- T3: Cooperativa -->
  <g>
    <rect class="terminal term-3" x="425" y="245" width="160" height="55" rx="6"/>
    <text class="term-name" x="505" y="278" fill="#0E4040">Cooperativa</text>
  </g>

  <!-- Q5: ¿Captación capital externo? (going from Q3 NO) -->
  <g>
    <rect class="question" x="585" y="245" width="170" height="60" rx="6"/>
    <text class="q-label" x="670" y="265">PREGUNTA 5</text>
    <text class="q-text" x="670" y="285">¿Captarás capital?</text>
  </g>

  <!-- Edges Q4 -->
  <line class="answer-yes" x1="245" y1="305" x2="215" y2="360"/>
  <text class="edge-label" x="210" y="335" fill="#4F8C3F">SÍ</text>

  <line class="answer-no" x1="335" y1="305" x2="365" y2="360"/>
  <text class="edge-label" x="370" y="335" fill="#B83A3A">NO</text>

  <!-- Edges Q5 -->
  <line class="answer-yes" x1="640" y1="305" x2="610" y2="360"/>
  <text class="edge-label" x="605" y="335" fill="#4F8C3F">SÍ</text>

  <line class="answer-no" x1="710" y1="305" x2="700" y2="360"/>
  <text class="edge-label" x="710" y="335" fill="#B83A3A">NO</text>

  <!-- T2: SLU -->
  <g>
    <rect class="terminal term-1" x="135" y="365" width="160" height="55" rx="6"/>
    <text class="term-name" x="215" y="398" fill="#9C3A1C">SLU</text>
  </g>

  <!-- T1 (alternative): Autónomo (already drawn left, this is from Q4 NO) -->
  <g>
    <rect class="terminal term-2" x="305" y="365" width="160" height="55" rx="6"/>
    <text class="term-name" x="385" y="398" fill="#A87A2A">Autónomo</text>
  </g>

  <!-- T4: SA -->
  <g>
    <rect class="terminal term-4" x="510" y="365" width="180" height="55" rx="6"/>
    <text class="term-name" x="600" y="398" fill="#3D2434">SL → SA cuando crezca</text>
  </g>

  <!-- T5: SL -->
  <g>
    <rect class="terminal term-5" x="640" y="430" width="100" height="55" rx="6"/>
    <text class="term-name" x="690" y="463" fill="#2A5A1F">SL</text>
  </g>

  <!-- Note at bottom -->
  <text x="380" y="535" font-family="Fraunces" font-style="italic" font-size="13" fill="#5C4A3D" text-anchor="middle">El árbol cubre el 95 % de los casos. El 5 % restante requiere asesoría profesional.</text>
</svg>
