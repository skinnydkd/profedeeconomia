---
/**
 * Necesidades primarias vs. secundarias para 3º ESO. Two side-by-side panels:
 * left (teal-soft) lists imprescindible needs to live; right (mustard-soft)
 * lists wellbeing wants you could live without. A bottom strip carries the
 * takeaway about deciding where to spend.
 *
 * Used in FOPP 4ESO / 3º ESO economics (las necesidades humanas).
 */
---
<svg viewBox="0 0 840 440" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="necesidades-title necesidades-desc">
  <title id="necesidades-title">Necesidades primarias y secundarias</title>
  <desc id="necesidades-desc">Las necesidades primarias son imprescindibles para vivir (comer, dormir, salud, vivienda); las secundarias mejoran el bienestar pero no son imprescindibles. Distinguirlas ayuda a decidir en qué gastar.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .panel-prim { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 2; }
      .panel-sec { fill: #F5E5BC; stroke: #A87A2A; stroke-width: 2; }
      .panel-bar-prim { fill: #1F6E6E; }
      .panel-bar-sec { fill: #D4A24C; }
      .strip { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 1.5; }
      .h-title { font-family: 'Fraunces', serif; font-style: italic; font-size: 24px; fill: #2A1F18; }
      .h-prim { fill: #1F6E6E; }
      .h-sec { fill: #A87A2A; }
      .h-sub { font-family: 'Switzer', sans-serif; font-size: 13px; font-style: italic; fill: #5C4A3D; }
      .item { font-family: 'Switzer', sans-serif; font-size: 16px; font-weight: 500; fill: #2A1F18; }
      .mark-prim { fill: #1F6E6E; font-family: 'Switzer', sans-serif; font-size: 16px; font-weight: 700; }
      .mark-sec { fill: #A87A2A; font-family: 'Switzer', sans-serif; font-size: 16px; font-weight: 700; }
      .take { font-family: 'Switzer', sans-serif; font-size: 16px; font-weight: 600; fill: #9C3A1C; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="840" height="440"/>

  <!-- LEFT PANEL: necesidades primarias -->
  <rect class="panel-prim" x="40" y="36" width="360" height="296" rx="12"/>
  <rect class="panel-bar-prim" x="40" y="36" width="360" height="8" rx="4"/>
  <text class="h-title h-prim" x="64" y="82">Necesidades primarias</text>
  <text class="h-sub" x="64" y="108">Imprescindibles para vivir</text>

  <text class="mark-prim" x="64" y="152">·</text>
  <text class="item" x="80" y="152">Comer</text>
  <text class="mark-prim" x="64" y="186">·</text>
  <text class="item" x="80" y="186">Beber</text>
  <text class="mark-prim" x="64" y="220">·</text>
  <text class="item" x="80" y="220">Dormir</text>
  <text class="mark-prim" x="64" y="254">·</text>
  <text class="item" x="80" y="254">Abrigo y ropa</text>
  <text class="mark-prim" x="64" y="288">·</text>
  <text class="item" x="80" y="288">Salud</text>
  <text class="mark-prim" x="64" y="322">·</text>
  <text class="item" x="80" y="322">Vivienda</text>

  <!-- RIGHT PANEL: necesidades secundarias -->
  <rect class="panel-sec" x="440" y="36" width="360" height="296" rx="12"/>
  <rect class="panel-bar-sec" x="440" y="36" width="360" height="8" rx="4"/>
  <text class="h-title h-sec" x="464" y="82">Necesidades secundarias</text>
  <text class="h-sub" x="464" y="108">Mejoran tu bienestar, pero podrías vivir sin ellas</text>

  <text class="mark-sec" x="464" y="152">→</text>
  <text class="item" x="486" y="152">Móvil de última generación</text>
  <text class="mark-sec" x="464" y="186">→</text>
  <text class="item" x="486" y="186">Videojuegos</text>
  <text class="mark-sec" x="464" y="220">→</text>
  <text class="item" x="486" y="220">Ropa de marca</text>
  <text class="mark-sec" x="464" y="254">→</text>
  <text class="item" x="486" y="254">Viajes</text>
  <text class="mark-sec" x="464" y="288">→</text>
  <text class="item" x="486" y="288">Ocio</text>

  <!-- BOTTOM STRIP: takeaway -->
  <rect class="strip" x="40" y="360" width="760" height="52" rx="10"/>
  <text class="take" x="420" y="392">Distinguir unas de otras es el primer paso para decidir bien en qué gastas.</text>
</svg>
