---
/**
 * Prospect Theory value function (Kahneman & Tversky, 1979).
 * S-shaped, asymmetric value curve centred on a reference point at
 * the origin: concave over gains, convex and steeper over losses
 * (loss aversion). The dashed mirror shows that a loss of magnitude x
 * hurts more than an equal gain of x pleases.
 *
 * Used in Eco 1BACH · Unit 2 (behavioural economics / decision-making).
 */
---
<svg viewBox="0 0 800 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="prospect-title prospect-desc">
  <title id="prospect-title">Función de valor de la Teoría Prospectiva</title>
  <desc id="prospect-desc">Curva de valor en forma de S asimétrica de Kahneman y Tversky, centrada en un punto de referencia. Es cóncava en las ganancias y convexa y más pronunciada en las pérdidas, lo que ilustra la aversión a la pérdida: perder duele más de lo que agrada ganar la misma cantidad.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .axis { stroke: #5C4A3D; stroke-width: 1.5; fill: none; }
      .grid { stroke: #E5D4BD; stroke-width: 1; stroke-dasharray: 2 4; fill: none; }
      .gains { fill: none; stroke: #1F6E6E; stroke-width: 3; }
      .losses { fill: none; stroke: #C44E2C; stroke-width: 3; }
      .mirror { fill: none; stroke: #8A7868; stroke-width: 1.4; stroke-dasharray: 5 4; }
      .guide { stroke: #8A7868; stroke-width: 1; stroke-dasharray: 4 4; fill: none; }
      .ref { fill: #FFFFFF; stroke: #2A1F18; stroke-width: 2.5; }
      .axis-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; fill: #5C4A3D; }
      .axis-letter { font-family: 'Fraunces', serif; font-style: italic; font-size: 17px; font-weight: 500; fill: #2A1F18; }
      .quad-label { font-family: 'Switzer', sans-serif; font-size: 11.5px; font-weight: 700; fill: #5C4A3D; }
      .curve-label { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; }
      .ref-label { font-family: 'Switzer', sans-serif; font-size: 10.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; fill: #2A1F18; }
      .note { font-family: 'Fraunces', serif; font-style: italic; font-size: 14px; font-weight: 500; fill: #2A1F18; }
      .tick { font-family: 'JetBrains Mono', monospace; font-size: 10px; fill: #8A7868; }
    </style>
    <marker id="prospect-arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#5C4A3D"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="800" height="520"/>

  <!-- Plot: origin (reference point) at (400, 250). x: 90..710, y: 50..450 -->

  <!-- Light grid -->
  <line class="grid" x1="90" y1="150" x2="710" y2="150"/>
  <line class="grid" x1="90" y1="350" x2="710" y2="350"/>
  <line class="grid" x1="245" y1="50" x2="245" y2="450"/>
  <line class="grid" x1="555" y1="50" x2="555" y2="450"/>

  <!-- Axes through the reference point -->
  <line class="axis" x1="90" y1="250" x2="725" y2="250" marker-end="url(#prospect-arrow)"/>
  <line class="axis" x1="400" y1="460" x2="400" y2="45" marker-end="url(#prospect-arrow)"/>

  <!-- Axis titles -->
  <text class="axis-letter" x="735" y="255">x</text>
  <text class="axis-label" x="240" y="478" text-anchor="middle">PÉRDIDAS</text>
  <text class="axis-label" x="560" y="478" text-anchor="middle">GANANCIAS</text>
  <text class="axis-label" x="412" y="60">VALOR PERCIBIDO</text>
  <text class="axis-letter" x="384" y="60" text-anchor="end" font-style="italic">v</text>

  <!-- Gains branch: concave, less steep. From origin (400,250) up-right to (710,130) -->
  <path class="gains" d="M 400 250 Q 500 175 710 130"/>

  <!-- Losses branch: convex and STEEPER. From origin (400,250) down-left to (110,440) -->
  <path class="losses" d="M 400 250 Q 300 320 110 440"/>

  <!-- Symmetric reference: dashed mirror of the gains branch reflected into the
       loss quadrant, to show the asymmetry (losses curve falls below it). -->
  <path class="mirror" d="M 400 250 Q 300 325 90 370"/>

  <!-- Reference point at origin -->
  <circle class="ref" cx="400" cy="250" r="6"/>
  <text class="ref-label" x="412" y="278">Punto de referencia</text>

  <!-- Illustration of asymmetry: equal magnitude gain vs loss (x = ±155 px) -->
  <!-- Gain at x=+155 (px=555): v on curve ≈ y=160 -->
  <line class="guide" x1="555" y1="250" x2="555" y2="160"/>
  <line class="guide" x1="400" y1="160" x2="555" y2="160"/>
  <circle cx="555" cy="160" r="4" fill="#1F6E6E"/>
  <!-- Loss at x=-155 (px=245): v on curve ≈ y=357 -->
  <line class="guide" x1="245" y1="250" x2="245" y2="357"/>
  <line class="guide" x1="400" y1="357" x2="245" y2="357"/>
  <circle cx="245" cy="357" r="4" fill="#C44E2C"/>

  <text class="tick" x="555" y="245" text-anchor="middle">+x</text>
  <text class="tick" x="245" y="268" text-anchor="middle">−x</text>

  <!-- Curve labels -->
  <text class="curve-label" x="640" y="120" fill="#1F6E6E" text-anchor="middle">Ganancias</text>
  <text class="quad-label" x="640" y="138" text-anchor="middle">(cóncava)</text>
  <text class="curve-label" x="160" y="412" fill="#9C3A1C">Pérdidas</text>
  <text class="quad-label" x="160" y="430">(convexa y más pronunciada)</text>

  <!-- Asymmetry note -->
  <text class="note" x="600" y="320" text-anchor="middle">La pérdida de x duele más</text>
  <text class="note" x="600" y="340" text-anchor="middle">de lo que agrada ganar x</text>
</svg>
