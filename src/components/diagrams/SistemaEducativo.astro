---
/**
 * Vertical flowchart of the Spanish post-ESO educational system,
 * showing the three main branches (Bachillerato, FP Grado Medio,
 * FP Grado Básico) and their bridges (EBAU, pruebas de acceso)
 * up to Universidad / FP Grado Superior / mundo laboral.
 */
---
<svg viewBox="0 0 880 620" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Itinerarios formativos del sistema educativo español tras 4.º ESO">
  <title>Sistema educativo español tras 4.º ESO</title>
  <desc>Diagrama de transiciones desde 4.º ESO hacia Bachillerato, FP Grado Medio y FP Grado Básico, con las pasarelas hacia FP Grado Superior, Universidad y mundo laboral.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .node-root { fill: #C44E2C; stroke: #9C3A1C; stroke-width: 2; }
      .node-bach { fill: #FFFFFF; stroke: #D4A24C; stroke-width: 2; }
      .node-bach-mini { fill: #F5E5BC; stroke: #A87A2A; stroke-width: 1.5; }
      .node-fpm { fill: #ECDCE5; stroke: #5B3A4E; stroke-width: 2; }
      .node-fpb { fill: #EFE2CB; stroke: #8A7868; stroke-width: 1.5; }
      .node-fps { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 2; }
      .node-uni { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .node-laboral { fill: #FFFFFF; stroke: #2A1F18; stroke-width: 2; stroke-dasharray: 4 3; }
      .edge { fill: none; stroke: #5C4A3D; stroke-width: 1.8; marker-end: url(#arrow-edge); }
      .edge-soft { fill: none; stroke: #8A7868; stroke-width: 1.4; marker-end: url(#arrow-soft); stroke-dasharray: 5 4; }
      .root-label-1 { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #FBE3D6; text-anchor: middle; }
      .root-label-2 { font-family: 'Fraunces', serif; font-style: italic; font-size: 19px; font-weight: 500; fill: #FFFFFF; text-anchor: middle; }
      .node-title { font-family: 'Fraunces', serif; font-size: 15px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .node-sub { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #5C4A3D; text-anchor: middle; }
      .mini-label { font-family: 'Switzer', sans-serif; font-size: 10.5px; font-weight: 600; fill: #2A1F18; text-anchor: middle; }
      .edge-label { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; fill: #5C4A3D; text-anchor: middle; }
      .edge-label-bg { fill: #FBF6EC; }
      .age-note { font-family: 'Switzer', sans-serif; font-style: italic; font-size: 10px; fill: #8A7868; text-anchor: middle; }
    </style>
    <marker id="arrow-edge" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#5C4A3D"/>
    </marker>
    <marker id="arrow-soft" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#8A7868"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="880" height="620"/>

  <!-- Root: 4.º ESO -->
  <g>
    <rect class="node-root" x="350" y="20" width="180" height="60" rx="8"/>
    <text class="root-label-1" x="440" y="42">PUNTO DE PARTIDA</text>
    <text class="root-label-2" x="440" y="66">4.º ESO</text>
  </g>

  <!-- Edges from root to 3 branches -->
  <path class="edge" d="M 410 80 Q 410 110 230 140"/>
  <path class="edge" d="M 440 80 L 440 140"/>
  <path class="edge" d="M 470 80 Q 470 110 650 140"/>

  <!-- Branch 1: Bachillerato (left) -->
  <g>
    <rect class="node-bach" x="80" y="140" width="280" height="130" rx="8"/>
    <text class="node-title" x="220" y="165">Bachillerato</text>
    <text class="node-sub" x="220" y="183">2 cursos · 16-18 años</text>
    <!-- 3 mini-modalities -->
    <rect class="node-bach-mini" x="95" y="200" width="80" height="55" rx="5"/>
    <text class="mini-label" x="135" y="222">Ciencias</text>
    <text class="mini-label" x="135" y="237">y Tecno.</text>
    <rect class="node-bach-mini" x="180" y="200" width="80" height="55" rx="5"/>
    <text class="mini-label" x="220" y="222">Humanid.</text>
    <text class="mini-label" x="220" y="237">y CC.SS.</text>
    <rect class="node-bach-mini" x="265" y="200" width="80" height="55" rx="5"/>
    <text class="mini-label" x="305" y="222">Artes /</text>
    <text class="mini-label" x="305" y="237">General</text>
  </g>

  <!-- Branch 2: FP Grado Medio (center) -->
  <g>
    <rect class="node-fpm" x="365" y="140" width="170" height="80" rx="8"/>
    <text class="node-title" x="450" y="170">FP Grado Medio</text>
    <text class="node-sub" x="450" y="190">2 cursos · técnico</text>
    <text class="node-sub" x="450" y="206">profesional</text>
  </g>

  <!-- Branch 3: FP Grado Básico (right) -->
  <g>
    <rect class="node-fpb" x="555" y="140" width="190" height="80" rx="8"/>
    <text class="node-title" x="650" y="170">FP Grado Básico</text>
    <text class="node-sub" x="650" y="190">Alternativa 15-17 años</text>
    <text class="node-sub" x="650" y="206">sin Graduado en ESO</text>
  </g>

  <!-- FP Básico → FP Medio (pasarela hacia arriba/lateral) -->
  <path class="edge-soft" d="M 600 220 Q 570 260 535 200"/>
  <text class="edge-label" x="585" y="255">titula → acceso</text>

  <!-- From Bachillerato down -->
  <path class="edge" d="M 180 270 L 180 350"/>
  <path class="edge" d="M 320 270 L 320 350"/>

  <!-- From FP Medio down (to FP Superior with prueba) and to laboral -->
  <path class="edge" d="M 430 220 L 430 350"/>
  <path class="edge-soft" d="M 500 220 Q 700 280 750 350"/>

  <!-- Edge labels for Bachillerato exits -->
  <rect class="edge-label-bg" x="135" y="305" width="90" height="18" rx="3"/>
  <text class="edge-label" x="180" y="318" fill="#C44E2C">vía EBAU</text>
  <rect class="edge-label-bg" x="270" y="305" width="100" height="18" rx="3"/>
  <text class="edge-label" x="320" y="318">acceso directo</text>

  <!-- Edge labels for FP Medio exits -->
  <rect class="edge-label-bg" x="375" y="305" width="110" height="18" rx="3"/>
  <text class="edge-label" x="430" y="318">prueba acceso</text>

  <!-- Row 3: Universidad / FP Superior / Mundo laboral -->
  <g>
    <rect class="node-uni" x="80" y="350" width="200" height="80" rx="8"/>
    <text class="node-title" x="180" y="382">Universidad</text>
    <text class="node-sub" x="180" y="402">Grados · 3-4 años</text>
    <text class="node-sub" x="180" y="418">Másteres · doctorado</text>
  </g>

  <g>
    <rect class="node-fps" x="320" y="350" width="220" height="80" rx="8"/>
    <text class="node-title" x="430" y="382">FP Grado Superior</text>
    <text class="node-sub" x="430" y="402">2 cursos · técnico</text>
    <text class="node-sub" x="430" y="418">superior · prácticas</text>
  </g>

  <g>
    <rect class="node-laboral" x="600" y="350" width="200" height="80" rx="8"/>
    <text class="node-title" x="700" y="382">Mundo laboral</text>
    <text class="node-sub" x="700" y="402">Contrato por cuenta</text>
    <text class="node-sub" x="700" y="418">ajena o autónomo</text>
  </g>

  <!-- From FP Superior → Universidad (acceso con o sin EBAU) -->
  <path class="edge-soft" d="M 320 390 L 280 390"/>
  <rect class="edge-label-bg" x="255" y="370" width="90" height="18" rx="3"/>
  <text class="edge-label" x="300" y="383">acceso directo</text>

  <!-- From FP Superior → Mundo laboral -->
  <path class="edge" d="M 540 390 L 600 390"/>

  <!-- From Universidad → Mundo laboral (bottom curve) -->
  <path class="edge" d="M 180 430 Q 180 510 700 510 L 700 430"/>
  <rect class="edge-label-bg" x="380" y="498" width="140" height="20" rx="3"/>
  <text class="edge-label" x="450" y="513">tras titulación</text>

  <!-- Age annotations -->
  <text class="age-note" x="220" y="290">16-18 años</text>
  <text class="age-note" x="430" y="240">16-18 años</text>
  <text class="age-note" x="650" y="240">15-17 años</text>
  <text class="age-note" x="430" y="448">18-20 años</text>

  <!-- Footer note -->
  <text class="age-note" x="440" y="595" font-style="italic" font-size="11">Todos los itinerarios desembocan, antes o después, en el mundo laboral. Las pasarelas garantizan que ninguna decisión es definitiva.</text>
</svg>
