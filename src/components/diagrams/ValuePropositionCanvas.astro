---
/**
 * Value Proposition Canvas de Osterwalder. A la izquierda, el cuadrado de
 * la propuesta de valor (productos y servicios, aliviadores de frustraciones
 * y creadores de alegrías). A la derecha, el círculo del perfil del cliente
 * (trabajos del cliente, frustraciones y alegrías). El encaje (fit) se da
 * cuando lo que ofrecemos responde a lo que el cliente necesita.
 *
 * Used in EDMN 2BACH · Unit 5 (diseño creativo de modelos de negocio).
 */
---
<svg viewBox="0 0 900 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="vpc-title vpc-desc">
  <title id="vpc-title">Value Proposition Canvas</title>
  <desc id="vpc-desc">El cuadrado de la propuesta de valor recoge productos y servicios, aliviadores de frustraciones y creadores de alegrías. El círculo del perfil del cliente recoge sus trabajos, sus frustraciones y sus alegrías. Hay encaje cuando la propuesta responde al perfil.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .square { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .circle-out { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 2; }
      .seg { fill: none; stroke: #1F6E6E; stroke-width: 1.4; }
      .seg-square { fill: none; stroke: #C44E2C; stroke-width: 1.4; }
      .side-head { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; text-anchor: middle; }
      .head-vp { fill: #9C3A1C; }
      .head-cust { fill: #0E4040; }
      .seg-title { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; fill: #2A1F18; }
      .seg-sub { font-family: 'Switzer', sans-serif; font-size: 9.5px; fill: #5C4A3D; }
      .fit { font-family: 'Fraunces', serif; font-style: italic; font-size: 13px; fill: #5C4A3D; text-anchor: middle; }
      .fit-arrow { stroke: #D4A24C; stroke-width: 2.5; fill: none; marker-end: url(#vpc-arrow); }
      .has-tip { cursor: help; }
    </style>
    <marker id="vpc-arrow" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#D4A24C"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="900" height="480"/>

  <!-- Side headers -->
  <text class="side-head head-vp" x="225" y="40">PROPUESTA DE VALOR</text>
  <text class="side-head head-cust" x="675" y="40">PERFIL DEL CLIENTE</text>

  <!-- LEFT: square divided. Square at x=60..390, y=70..400 (330x330). -->
  <!-- A square split by a diagonal so it interlocks with the circle visually. -->
  <rect class="square has-tip" x="60" y="70" width="330" height="330" rx="10"><title>Es la parte que controla la empresa: lo que diseña y ofrece. Se rellena DESPUÉS del perfil del cliente, nunca al revés, para no enamorarse de un producto que nadie pide.</title></rect>
  <!-- Internal divisions: top half (productos), bottom-left (aliviadores), bottom-right (creadores) -->
  <line class="seg-square" x1="60" y1="200" x2="390" y2="200"/>
  <line class="seg-square" x1="225" y1="200" x2="225" y2="400"/>

  <!-- Productos y servicios (top) -->
  <text class="seg-title" x="80" y="100">Productos y servicios</text>
  <text class="seg-sub" x="80" y="120">Lo que la empresa ofrece:</text>
  <text class="seg-sub" x="80" y="136">la lista de productos y</text>
  <text class="seg-sub" x="80" y="152">servicios en los que se apoya</text>
  <text class="seg-sub" x="80" y="168">la propuesta de valor.</text>

  <!-- Aliviadores de frustraciones (bottom-left) -->
  <text class="seg-title" x="80" y="226">Aliviadores</text>
  <text class="seg-sub" x="80" y="244">Cómo el producto</text>
  <text class="seg-sub" x="80" y="260">elimina o reduce</text>
  <text class="seg-sub" x="80" y="276">aquello que molesta</text>
  <text class="seg-sub" x="80" y="292">o frena al cliente.</text>

  <!-- Creadores de alegrías (bottom-right) -->
  <text class="seg-title" x="245" y="226">Creadores</text>
  <text class="seg-sub" x="245" y="244">Cómo el producto</text>
  <text class="seg-sub" x="245" y="260">genera beneficios y</text>
  <text class="seg-sub" x="245" y="276">resultados que el</text>
  <text class="seg-sub" x="245" y="292">cliente desea.</text>

  <!-- RIGHT: circle. Center (675, 235), r 165. -->
  <circle class="circle-out has-tip" cx="675" cy="235" r="165"><title>Es la parte que la empresa NO controla: hay que investigarla observando y hablando con clientes reales. Es el punto de partida de todo el lienzo.</title></circle>
  <!-- Divisions: vertical line splitting right circle, and a horizontal on the left part -->
  <line class="seg" x1="675" y1="70" x2="675" y2="400"/>
  <line class="seg" x1="510" y1="235" x2="675" y2="235"/>

  <!-- Trabajos del cliente (right half) -->
  <text class="seg-title" x="695" y="180">Trabajos del cliente</text>
  <text class="seg-sub" x="695" y="200">Las tareas que intenta</text>
  <text class="seg-sub" x="695" y="216">resolver: funcionales,</text>
  <text class="seg-sub" x="695" y="232">sociales y emocionales.</text>

  <!-- Frustraciones (left-top) -->
  <text class="seg-title" x="540" y="150">Frustraciones</text>
  <text class="seg-sub" x="540" y="170">Riesgos, obstáculos</text>
  <text class="seg-sub" x="540" y="186">y malos resultados</text>
  <text class="seg-sub" x="540" y="202">que teme.</text>

  <!-- Alegrías (left-bottom) -->
  <text class="seg-title" x="540" y="290">Alegrías</text>
  <text class="seg-sub" x="540" y="310">Beneficios que espera,</text>
  <text class="seg-sub" x="540" y="326">desea o le sorprenden</text>
  <text class="seg-sub" x="540" y="342">gratamente.</text>

  <!-- Fit arrows between square and circle -->
  <path class="fit-arrow" d="M 395 200 H 470"/>
  <path class="fit-arrow" d="M 505 270 H 430" />

  <!-- Footnote -->
  <text class="fit" x="450" y="445">Hay encaje (fit) cuando los aliviadores y creadores responden a las frustraciones, alegrías y trabajos del cliente.</text>
</svg>
