---
/**
 * Six PESTEL dimensions arranged as a hexagon around a central
 * "macroentorno" node. Each cell color-coded for visual distinction.
 */
---
<svg viewBox="0 0 720 580" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Las seis dimensiones del análisis PESTEL">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .center { fill: #5C4A3D; }
      .center-stroke { fill: none; stroke: #2A1F18; stroke-width: 1.5; }
      .center-label-1 { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #FBE3D6; text-anchor: middle; }
      .center-label-2 { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; font-weight: 500; fill: #FFFFFF; text-anchor: middle; }
      .arm { stroke: #8A7868; stroke-width: 1.2; stroke-dasharray: 3 3; }
      .letter { font-family: 'Fraunces', serif; font-style: italic; font-size: 30px; font-weight: 500; text-anchor: middle; }
      .dim-name { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; text-anchor: middle; }
      .dim-desc { font-family: 'Switzer', sans-serif; font-size: 10.5px; fill: #5C4A3D; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="580"/>

  <!-- Arms from center to each dimension -->
  <line class="arm" x1="360" y1="270" x2="360" y2="100"/>
  <line class="arm" x1="360" y1="270" x2="600" y2="180"/>
  <line class="arm" x1="360" y1="270" x2="600" y2="360"/>
  <line class="arm" x1="360" y1="270" x2="360" y2="440"/>
  <line class="arm" x1="360" y1="270" x2="120" y2="360"/>
  <line class="arm" x1="360" y1="270" x2="120" y2="180"/>

  <!-- Center -->
  <circle class="center-stroke" cx="360" cy="270" r="68"/>
  <circle class="center" cx="360" cy="270" r="62"/>
  <text class="center-label-1" x="360" y="262">MACRO</text>
  <text class="center-label-2" x="360" y="285">entorno</text>

  <!-- P (top) -->
  <g>
    <circle cx="360" cy="80" r="45" fill="#FBE3D6" stroke="#C44E2C" stroke-width="2"/>
    <text class="letter" x="360" y="92" fill="#9C3A1C">P</text>
    <text class="dim-name" x="360" y="155" fill="#9C3A1C">POLÍTICO</text>
    <text class="dim-desc" x="360" y="172">Gobiernos · aranceles · subvenciones</text>
  </g>

  <!-- E económico (top-right) -->
  <g>
    <circle cx="600" cy="160" r="45" fill="#F5E5BC" stroke="#D4A24C" stroke-width="2"/>
    <text class="letter" x="600" y="172" fill="#A87A2A">E</text>
    <text class="dim-name" x="600" y="235" fill="#A87A2A">ECONÓMICO</text>
    <text class="dim-desc" x="600" y="252">Ciclo · inflación · tipos · paro</text>
  </g>

  <!-- S (bottom-right) -->
  <g>
    <circle cx="600" cy="380" r="45" fill="#DBEDED" stroke="#1F6E6E" stroke-width="2"/>
    <text class="letter" x="600" y="392" fill="#0E4040">S</text>
    <text class="dim-name" x="600" y="455" fill="#0E4040">SOCIAL</text>
    <text class="dim-desc" x="600" y="472">Demografía · valores · hábitos</text>
  </g>

  <!-- T (bottom) -->
  <g>
    <circle cx="360" cy="460" r="45" fill="#ECDCE5" stroke="#5B3A4E" stroke-width="2"/>
    <text class="letter" x="360" y="472" fill="#3D2434">T</text>
    <text class="dim-name" x="360" y="535" fill="#3D2434">TECNOLÓGICO</text>
    <text class="dim-desc" x="360" y="552">IA · automatización · digitalización</text>
  </g>

  <!-- E ecológico (bottom-left) -->
  <g>
    <circle cx="120" cy="380" r="45" fill="#E5F1DD" stroke="#4F8C3F" stroke-width="2"/>
    <text class="letter" x="120" y="392" fill="#2A5A1F">E</text>
    <text class="dim-name" x="120" y="455" fill="#2A5A1F">ECOLÓGICO</text>
    <text class="dim-desc" x="120" y="472">Clima · sostenibilidad · recursos</text>
  </g>

  <!-- L (top-left) -->
  <g>
    <circle cx="120" cy="160" r="45" fill="#F5DDDD" stroke="#B83A3A" stroke-width="2"/>
    <text class="letter" x="120" y="172" fill="#702020">L</text>
    <text class="dim-name" x="120" y="235" fill="#702020">LEGAL</text>
    <text class="dim-desc" x="120" y="252">Normativa · fiscalidad · protección</text>
  </g>
</svg>
