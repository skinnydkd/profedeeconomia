---
/**
 * Comparativa de los cuatro tipos de proceso productivo, situados en una
 * matriz volumen (eje horizontal) frente a variedad (eje vertical):
 * por proyecto, por lotes, en masa y continuo. A más volumen, menos
 * variedad, y viceversa: la clásica relación inversa producto-proceso.
 *
 * Used in EDMN 2BACH · Unit 7 (función productiva).
 */
---
<svg viewBox="0 0 880 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="procprod-title procprod-desc">
  <title id="procprod-title">Tipos de proceso productivo</title>
  <desc id="procprod-desc">Los cuatro tipos de proceso productivo —por proyecto, por lotes, en masa y continuo— se ordenan en una diagonal: a poco volumen y mucha variedad corresponde la producción por proyecto; a mucho volumen y poca variedad, la producción continua.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .axis { stroke: #5C4A3D; stroke-width: 1.5; }
      .grid { stroke: #E5D4BD; stroke-width: 1; stroke-dasharray: 2 4; }
      .axis-label { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; fill: #5C4A3D; }
      .diag { stroke: #D4A24C; stroke-width: 2; stroke-dasharray: 7 5; fill: none; }
      .card { stroke-width: 2; }
      .card-1 { fill: #FBE3D6; stroke: #C44E2C; }
      .card-2 { fill: #F5E5BC; stroke: #D4A24C; }
      .card-3 { fill: #F5E5BC; stroke: #D4A24C; }
      .card-4 { fill: #FBE3D6; stroke: #C44E2C; }
      .card-name { font-family: 'Switzer', sans-serif; font-size: 13px; font-weight: 700; fill: #2A1F18; text-anchor: middle; }
      .card-sub { font-family: 'Switzer', sans-serif; font-size: 10px; fill: #5C4A3D; text-anchor: middle; }
      .card-ex { font-family: 'Fraunces', serif; font-style: italic; font-size: 10.5px; fill: #9C3A1C; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="880" height="520"/>

  <!-- Axes: x 90..820, y 60..430 -->
  <line class="grid" x1="90" y1="245" x2="820" y2="245"/>
  <line class="grid" x1="455" y1="60" x2="455" y2="430"/>
  <line class="axis" x1="90" y1="430" x2="830" y2="430"/>
  <line class="axis" x1="90" y1="50" x2="90" y2="430"/>

  <!-- Axis titles -->
  <text class="axis-label" x="455" y="465" text-anchor="middle">VOLUMEN DE PRODUCCIÓN  →</text>
  <text class="axis-label" x="40" y="245" text-anchor="middle" transform="rotate(-90 40 245)">VARIEDAD DEL PRODUCTO  →</text>
  <text class="axis-label" x="120" y="80" fill="#8A7868">bajo volumen</text>
  <text class="axis-label" x="790" y="80" fill="#8A7868" text-anchor="end">alto volumen</text>

  <!-- Diagonal trend (top-left high variety/low volume → bottom-right low variety/high volume) -->
  <line class="diag" x1="150" y1="90" x2="760" y2="400"/>

  <!-- Card 1: Por proyecto (top-left: mucha variedad, poco volumen) -->
  <rect class="card card-1" x="100" y="75" width="190" height="120" rx="8"/>
  <text class="card-name" x="195" y="102">Por proyecto</text>
  <text class="card-sub" x="195" y="122">Una unidad única,</text>
  <text class="card-sub" x="195" y="137">a medida del cliente</text>
  <text class="card-ex" x="195" y="165">un puente, un barco,</text>
  <text class="card-ex" x="195" y="180">una boda</text>

  <!-- Card 2: Por lotes (center-upper) -->
  <rect class="card card-2" x="290" y="165" width="190" height="120" rx="8"/>
  <text class="card-name" x="385" y="192">Por lotes (batch)</text>
  <text class="card-sub" x="385" y="212">Tandas de producto</text>
  <text class="card-sub" x="385" y="227">que se repiten</text>
  <text class="card-ex" x="385" y="255">panadería, ropa por</text>
  <text class="card-ex" x="385" y="270">colecciones, muebles</text>

  <!-- Card 3: En masa / cadena (center-lower) -->
  <rect class="card card-3" x="430" y="245" width="190" height="120" rx="8"/>
  <text class="card-name" x="525" y="272">En masa (cadena)</text>
  <text class="card-sub" x="525" y="292">Gran volumen de un</text>
  <text class="card-sub" x="525" y="307">producto estándar</text>
  <text class="card-ex" x="525" y="335">automóviles,</text>
  <text class="card-ex" x="525" y="350">electrodomésticos</text>

  <!-- Card 4: Continuo (bottom-right: poca variedad, mucho volumen) -->
  <rect class="card card-4" x="620" y="305" width="190" height="120" rx="8"/>
  <text class="card-name" x="715" y="332">Continuo</text>
  <text class="card-sub" x="715" y="352">Flujo ininterrumpido</text>
  <text class="card-sub" x="715" y="367">24 horas, sin paradas</text>
  <text class="card-ex" x="715" y="395">refinería, central</text>
  <text class="card-ex" x="715" y="410">eléctrica, cementera</text>
</svg>
