---
/**
 * Empathy Map with six quadrants arranged around a central persona
 * silhouette. Layout based on XPLANE's canonical version.
 */
---
<svg viewBox="0 0 760 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mapa de empatía: seis cuadrantes alrededor del cliente">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .quad { fill: #FFFFFF; stroke: #E5D4BD; stroke-width: 1.5; }
      .quad-top { stroke: #C44E2C; }
      .quad-side-l { stroke: #D4A24C; }
      .quad-side-r { stroke: #1F6E6E; }
      .quad-bottom-pain { stroke: #B83A3A; }
      .quad-bottom-gain { stroke: #4F8C3F; }
      .num { font-family: 'Fraunces', serif; font-style: italic; font-size: 13px; font-weight: 500; fill: #A87A2A; }
      .title { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; fill: #2A1F18; }
      .question { font-family: 'Fraunces', serif; font-style: italic; font-size: 11.5px; fill: #5C4A3D; }
      .persona-circle { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .persona-label { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #9C3A1C; text-anchor: middle; }
      .persona-name { font-family: 'Fraunces', serif; font-style: italic; font-size: 18px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="760" height="540"/>

  <!-- Top: Piensa y siente -->
  <g>
    <rect class="quad quad-top" x="180" y="40" width="400" height="100" rx="6"/>
    <text class="num" x="200" y="62">01</text>
    <text class="title" x="200" y="84">¿Qué piensa y siente?</text>
    <text class="question" x="200" y="106">Sus motivaciones profundas, preocupaciones,</text>
    <text class="question" x="200" y="120">aspiraciones, miedos no expresados.</text>
  </g>

  <!-- Left: Oye -->
  <g>
    <rect class="quad quad-side-l" x="40" y="160" width="190" height="220" rx="6"/>
    <text class="num" x="55" y="182">02</text>
    <text class="title" x="55" y="204">¿Qué oye?</text>
    <text class="question" x="55" y="226">Lo que le dicen amigos,</text>
    <text class="question" x="55" y="240">familia, jefes, redes</text>
    <text class="question" x="55" y="254">sociales, influencers.</text>
    <text class="question" x="55" y="278">Qué medios consume.</text>
    <text class="question" x="55" y="292">Qué autoridades respeta.</text>
  </g>

  <!-- Right: Ve -->
  <g>
    <rect class="quad quad-side-r" x="530" y="160" width="190" height="220" rx="6"/>
    <text class="num" x="545" y="182">03</text>
    <text class="title" x="545" y="204">¿Qué ve?</text>
    <text class="question" x="545" y="226">Su entorno físico,</text>
    <text class="question" x="545" y="240">la oferta del mercado,</text>
    <text class="question" x="545" y="254">sus referentes visuales.</text>
    <text class="question" x="545" y="278">Qué compite por su</text>
    <text class="question" x="545" y="292">atención y su tiempo.</text>
  </g>

  <!-- Center: Persona -->
  <ellipse class="persona-circle" cx="380" cy="270" rx="130" ry="90"/>
  <text class="persona-label" x="380" y="248">CLIENTE OBJETIVO</text>
  <text class="persona-name" x="380" y="274">Persona concreta</text>
  <text class="question" x="380" y="298" text-anchor="middle">— no un segmento abstracto —</text>

  <!-- Bottom-center: Dice y hace -->
  <g>
    <rect class="quad" x="240" y="400" width="280" height="80" rx="6"/>
    <text class="num" x="260" y="422">04</text>
    <text class="title" x="260" y="444">¿Qué dice y qué hace?</text>
    <text class="question" x="260" y="466">Su discurso público vs. su comportamiento.</text>
  </g>

  <!-- Bottom-left: Le duele -->
  <g>
    <rect class="quad quad-bottom-pain" x="40" y="400" width="190" height="120" rx="6"/>
    <text class="num" x="55" y="422" fill="#702020">05</text>
    <text class="title" x="55" y="444" fill="#702020">¿Qué le duele?</text>
    <text class="question" x="55" y="466">Frustraciones, miedos,</text>
    <text class="question" x="55" y="480">obstáculos, fricción.</text>
    <text class="question" x="55" y="500">Lo que querría evitar</text>
    <text class="question" x="55" y="514">si pudiera.</text>
  </g>

  <!-- Bottom-right: Qué gana -->
  <g>
    <rect class="quad quad-bottom-gain" x="530" y="400" width="190" height="120" rx="6"/>
    <text class="num" x="545" y="422" fill="#2A5A1F">06</text>
    <text class="title" x="545" y="444" fill="#2A5A1F">¿Qué gana?</text>
    <text class="question" x="545" y="466">Necesidades reales,</text>
    <text class="question" x="545" y="480">deseos, métricas propias</text>
    <text class="question" x="545" y="500">de éxito. Lo que de</text>
    <text class="question" x="545" y="514">verdad le importa.</text>
  </g>
</svg>
