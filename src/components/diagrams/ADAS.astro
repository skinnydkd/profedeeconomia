---
/**
 * AD-AS macroeconomic equilibrium model.
 * AD slopes down (terra), SRAS slopes up (mustard),
 * LRAS vertical at potential output Y* (dashed ink).
 * All three intersect at equilibrium E with price level P*.
 */
---
<svg viewBox="0 0 800 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="adas-title adas-desc">
  <title id="adas-title">Modelo AD-AS: equilibrio macroeconómico</title>
  <desc id="adas-desc">Cruce de demanda agregada descendente, oferta agregada de corto plazo ascendente y oferta agregada de largo plazo vertical en la producción potencial Y*. Determina el nivel de precios de equilibrio P* y la producción real Y*.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .axis { stroke: #5C4A3D; stroke-width: 1.5; fill: none; }
      .ad { stroke: #C44E2C; stroke-width: 2.5; fill: none; }
      .sras { stroke: #D4A24C; stroke-width: 2.5; fill: none; }
      .lras { stroke: #2A1F18; stroke-width: 2; stroke-dasharray: 6 5; fill: none; }
      .guide { stroke: #8A7868; stroke-width: 1; stroke-dasharray: 4 4; fill: none; }
      .axis-label { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; fill: #5C4A3D; }
      .curve-label { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 500; font-style: italic; }
      .point-label { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 500; font-style: italic; fill: #2A1F18; }
      .small-note { font-family: 'Switzer', sans-serif; font-size: 10.5px; fill: #5C4A3D; font-style: italic; }
      .tick { font-family: 'JetBrains Mono', monospace; font-size: 11px; fill: #5C4A3D; }
    </style>
    <marker id="adas-arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#5C4A3D"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="800" height="520"/>

  <!-- Plot area: x from 90 to 720, y from 50 to 430 -->
  <line class="axis" x1="90" y1="430" x2="740" y2="430" marker-end="url(#adas-arrow)"/>
  <line class="axis" x1="90" y1="450" x2="90" y2="40" marker-end="url(#adas-arrow)"/>

  <!-- Origin -->
  <text class="tick" x="80" y="448" text-anchor="end">0</text>

  <!-- Axis titles -->
  <text class="axis-label" x="755" y="435">Y</text>
  <text class="axis-label" x="80" y="35" text-anchor="end">P</text>
  <text class="axis-label" x="415" y="490" text-anchor="middle">PRODUCCIÓN REAL</text>
  <text class="axis-label" x="30" y="240" text-anchor="middle" transform="rotate(-90 30 240)">NIVEL DE PRECIOS</text>

  <!-- LRAS: vertical line at Y* (x = 415) -->
  <line class="lras" x1="415" y1="60" x2="415" y2="430"/>

  <!-- AD: descending line, intersects (415, 240). Passes from (140, 90) to (700, 400). -->
  <line class="ad" x1="140" y1="90" x2="700" y2="400"/>

  <!-- SRAS: ascending line, intersects (415, 240). From (140, 400) to (700, 90). -->
  <line class="sras" x1="140" y1="400" x2="700" y2="90"/>

  <!-- Equilibrium guides -->
  <line class="guide" x1="415" y1="240" x2="90" y2="240"/>

  <!-- Equilibrium dot -->
  <circle cx="415" cy="240" r="7" fill="#FFFFFF" stroke="#2A1F18" stroke-width="2.5"/>

  <!-- Curve labels -->
  <text class="curve-label" x="710" y="408" fill="#C44E2C">AD</text>
  <text class="curve-label" x="710" y="88" fill="#A87A2A">SRAS</text>
  <text class="curve-label" x="425" y="58" fill="#2A1F18">LRAS</text>

  <!-- Equilibrium labels -->
  <text class="point-label" x="430" y="232">E</text>
  <text class="point-label" x="82" y="245" text-anchor="end">P*</text>
  <text class="point-label" x="415" y="450" text-anchor="middle">Y*</text>

  <!-- Small note under Y* -->
  <text class="small-note" x="415" y="467" text-anchor="middle">producción potencial</text>
</svg>
