---
/**
 * 2x2 classification of goods by rivalry (rows) and excludability
 * (columns), following Samuelson and Ostrom: private goods, club goods,
 * common-pool resources and pure public goods. Each quadrant carries a
 * canonical example.
 *
 * Used in Eco 1BACH · Unit 6 (market failures and public goods).
 */
---
<svg viewBox="0 0 800 560" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="bp-title bp-desc">
  <title id="bp-title">Matriz de bienes: rivalidad y exclusión</title>
  <desc id="bp-desc">Matriz dos por dos que clasifica los bienes según sean rivales o no en el consumo y excluibles o no. Combina cuatro tipos: bienes privados (rival y excluible), bienes de club (no rival y excluible), recursos comunes (rival y no excluible) y bienes públicos puros (no rival y no excluible), con un ejemplo en cada cuadrante.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .cell { stroke: #E5D4BD; stroke-width: 1.5; }
      .cell-private { fill: #F5E5BC; fill-opacity: 0.5; }
      .cell-club { fill: #F5EDD9; }
      .cell-common { fill: #FBE3D6; fill-opacity: 0.6; }
      .cell-public { fill: #DBEDED; fill-opacity: 0.7; }
      .head-bar { fill: #2A1F18; }
      .head-text { font-family: 'Switzer', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; fill: #FBF6EC; text-anchor: middle; }
      .axis-title { font-family: 'Switzer', sans-serif; font-size: 12.5px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; fill: #5C4A3D; text-anchor: middle; }
      .cell-title { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 500; fill: #2A1F18; text-anchor: middle; }
      .cell-title-pub { fill: #1F6E6E; }
      .cell-title-com { fill: #9C3A1C; }
      .cell-tag { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; fill: #8A7868; text-anchor: middle; }
      .cell-ex { font-family: 'Fraunces', serif; font-style: italic; font-size: 14px; font-weight: 500; fill: #5C4A3D; text-anchor: middle; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="800" height="560"/>

  <!-- Grid geometry: cells start at x=200, y=130. Each cell 260 wide, 180 tall. -->
  <!-- Column headers (Excludability) -->
  <rect class="head-bar" x="200" y="80" width="260" height="38" rx="4"/>
  <rect class="head-bar" x="470" y="80" width="260" height="38" rx="4"/>
  <text class="head-text" x="330" y="104">Excluible</text>
  <text class="head-text" x="600" y="104">No excluible</text>
  <text class="axis-title" x="465" y="52">EXCLUSIÓN</text>

  <!-- Row headers (Rivalry) -->
  <rect class="head-bar" x="40" y="130" width="150" height="180" rx="4"/>
  <rect class="head-bar" x="40" y="320" width="150" height="180" rx="4"/>
  <text class="head-text" x="115" y="225">Rival</text>
  <text class="head-text" x="115" y="415">No rival</text>
  <text class="axis-title" x="22" y="318" transform="rotate(-90 22 318)">RIVALIDAD</text>

  <!-- Cells -->
  <!-- Top-left: Rival + Excluible = Bien privado -->
  <rect class="cell cell-private" x="200" y="130" width="260" height="180" rx="4"/>
  <text class="cell-title" x="330" y="195">Bien privado</text>
  <text class="cell-tag" x="330" y="220">Rival · Excluible</text>
  <text class="cell-ex" x="330" y="258">Ej.: una manzana,</text>
  <text class="cell-ex" x="330" y="277">un corte de pelo</text>

  <!-- Top-right: Rival + No excluible = Recurso común -->
  <rect class="cell cell-common" x="470" y="130" width="260" height="180" rx="4"/>
  <text class="cell-title cell-title-com" x="600" y="195">Recurso común</text>
  <text class="cell-tag" x="600" y="220">Rival · No excluible</text>
  <text class="cell-ex" x="600" y="258">Ej.: caladero de pesca,</text>
  <text class="cell-ex" x="600" y="277">pastizal comunal</text>

  <!-- Bottom-left: No rival + Excluible = Bien de club -->
  <rect class="cell cell-club" x="200" y="320" width="260" height="180" rx="4"/>
  <text class="cell-title" x="330" y="385">Bien de club</text>
  <text class="cell-tag" x="330" y="410">No rival · Excluible</text>
  <text class="cell-ex" x="330" y="448">Ej.: Netflix,</text>
  <text class="cell-ex" x="330" y="467">autopista de peaje</text>

  <!-- Bottom-right: No rival + No excluible = Bien público puro -->
  <rect class="cell cell-public" x="470" y="320" width="260" height="180" rx="4"/>
  <text class="cell-title cell-title-pub" x="600" y="385">Bien público puro</text>
  <text class="cell-tag" x="600" y="410">No rival · No excluible</text>
  <text class="cell-ex" x="600" y="448">Ej.: defensa nacional,</text>
  <text class="cell-ex" x="600" y="467">un faro, el alumbrado</text>
</svg>
