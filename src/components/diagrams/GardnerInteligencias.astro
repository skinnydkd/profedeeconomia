---
/**
 * Wheel of Howard Gardner's eight multiple intelligences, drawn as eight
 * radial sectors around a central hub. Each sector carries a typographic
 * icon and the name of the intelligence.
 *
 * Used in FOPP 4ESO · Unit 1 (autoconocimiento e identidad personal).
 */
---
<svg viewBox="0 0 760 760" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gardner-title gardner-desc">
  <title id="gardner-title">Las ocho inteligencias múltiples de Gardner</title>
  <desc id="gardner-desc">Rueda de ocho sectores con las inteligencias lingüística, lógico-matemática, espacial, musical, corporal-cinestésica, naturalista, interpersonal e intrapersonal. Cada persona tiene las ocho en distinto grado.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .sector { stroke: #FBF6EC; stroke-width: 3; }
      .s1 { fill: #ECDCE5; }
      .s2 { fill: #FBE3D6; }
      .s3 { fill: #F5E5BC; }
      .s4 { fill: #ECDCE5; }
      .s5 { fill: #FBE3D6; }
      .s6 { fill: #F5E5BC; }
      .s7 { fill: #ECDCE5; }
      .s8 { fill: #FBE3D6; }
      .hub { fill: #5B3A4E; stroke: #FFFFFF; stroke-width: 3; }
      .hub-ring { fill: none; stroke: #ECDCE5; stroke-width: 1.5; }
      .icon { font-family: 'Fraunces', serif; font-style: italic; font-size: 30px; font-weight: 600; fill: #5B3A4E; text-anchor: middle; }
      .name { font-family: 'Switzer', sans-serif; font-size: 12.5px; font-weight: 700; letter-spacing: 0.4px; fill: #2A1F18; text-anchor: middle; }
      .hub-label-1 { font-family: 'Switzer', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; fill: #ECDCE5; text-anchor: middle; }
      .hub-label-2 { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; font-weight: 500; fill: #FFFFFF; text-anchor: middle; }
      .has-tip { cursor: help; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="760" height="760"/>

  <!-- 8 sectors, 45 degrees each, center (380,380), outer r=320 -->
  <!-- Sector points computed from center; angles start at -90 (top) clockwise. -->
  <!-- top sector spans -112.5 to -67.5 -->
  <path class="sector s1 has-tip" d="M 380 380 L 257.5 84.4 L 502.5 84.4 Z"><title>Facilidad con las palabras: leer, escribir, contar historias, aprender idiomas. Destaca en periodistas, escritores y abogados.</title></path>
  <path class="sector s2 has-tip" d="M 380 380 L 502.5 84.4 L 675.6 257.5 Z"><title>Razonar con números, patrones y relaciones de causa-efecto. Destaca en científicos, ingenieros y programadores.</title></path>
  <path class="sector s3 has-tip" d="M 380 380 L 675.6 257.5 L 675.6 502.5 Z"><title>Pensar en imágenes y orientarse en el espacio. Destaca en arquitectos, diseñadores, pilotos y escultores.</title></path>
  <path class="sector s4 has-tip" d="M 380 380 L 675.6 502.5 L 502.5 675.6 Z"><title>Sensibilidad al ritmo, el tono y la melodía. Destaca en músicos, compositores y quien aprende con canciones.</title></path>
  <path class="sector s5 has-tip" d="M 380 380 L 502.5 675.6 L 257.5 675.6 Z"><title>Usar el cuerpo con precisión y coordinación. Destaca en deportistas, bailarines, cirujanos y artesanos.</title></path>
  <path class="sector s6 has-tip" d="M 380 380 L 257.5 675.6 L 84.4 502.5 Z"><title>Observar, clasificar y entender la naturaleza y los seres vivos. Destaca en biólogos, agricultores y ecologistas.</title></path>
  <path class="sector s7 has-tip" d="M 380 380 L 84.4 502.5 L 84.4 257.5 Z"><title>Entender a los demás, sus emociones e intenciones. Destaca en docentes, vendedores, líderes y terapeutas.</title></path>
  <path class="sector s8 has-tip" d="M 380 380 L 84.4 257.5 L 257.5 84.4 Z"><title>Conocerse a uno mismo: emociones, metas y límites propios. Es la base de la autoestima y de tomar buenas decisiones.</title></path>

  <!-- Icons + names per sector (placed along the bisector at r=210 and r=255) -->
  <!-- Sector 1 (top, 0deg up) -->
  <text class="icon" x="380" y="160">Aa</text>
  <text class="name" x="380" y="195">Lingüística</text>
  <!-- Sector 2 (top-right) -->
  <text class="icon" x="535" y="225">+−</text>
  <text class="name" x="540" y="258">Lógico-mat.</text>
  <!-- Sector 3 (right) -->
  <text class="icon" x="600" y="372">◫</text>
  <text class="name" x="600" y="405">Espacial</text>
  <!-- Sector 4 (bottom-right) -->
  <text class="icon" x="535" y="520">♪</text>
  <text class="name" x="538" y="553">Musical</text>
  <!-- Sector 5 (bottom) -->
  <text class="icon" x="380" y="580">↻</text>
  <text class="name" x="380" y="613">Corporal</text>
  <!-- Sector 6 (bottom-left) -->
  <text class="icon" x="222" y="520">❦</text>
  <text class="name" x="222" y="553">Naturalista</text>
  <!-- Sector 7 (left) -->
  <text class="icon" x="160" y="372">∞</text>
  <text class="name" x="160" y="405">Interpersonal</text>
  <!-- Sector 8 (top-left) -->
  <text class="icon" x="222" y="225">◉</text>
  <text class="name" x="222" y="258">Intrapersonal</text>

  <!-- Central hub -->
  <circle class="hub-ring" cx="380" cy="380" r="92"/>
  <circle class="hub" cx="380" cy="380" r="84"/>
  <text class="hub-label-1" x="380" y="368">TÚ TIENES</text>
  <text class="hub-label-2" x="380" y="396">las 8</text>
  <text class="hub-label-1" x="380" y="416">EN DISTINTO GRADO</text>
</svg>
