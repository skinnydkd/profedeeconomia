---
/**
 * Marketing mix 4P diagram: four interlocking quadrants around a
 * central target customer node.
 */
---
<svg viewBox="0 0 720 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="El marketing mix: las 4P (Producto, Precio, Plaza, Promoción)">
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .quad-prod { fill: #FBE3D6; stroke: #C44E2C; stroke-width: 2; }
      .quad-price { fill: #F5E5BC; stroke: #D4A24C; stroke-width: 2; }
      .quad-place { fill: #DBEDED; stroke: #1F6E6E; stroke-width: 2; }
      .quad-promo { fill: #ECDCE5; stroke: #5B3A4E; stroke-width: 2; }
      .center { fill: #2A1F18; stroke: #FFFFFF; stroke-width: 3; }
      .center-label-1 { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; fill: #F5E5BC; text-anchor: middle; }
      .center-label-2 { font-family: 'Fraunces', serif; font-style: italic; font-size: 18px; font-weight: 500; fill: #FFFFFF; text-anchor: middle; }
      .letter { font-family: 'Fraunces', serif; font-style: italic; font-size: 56px; font-weight: 500; }
      .quad-name { font-family: 'Switzer', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; }
      .quad-q { font-family: 'Fraunces', serif; font-style: italic; font-size: 13px; fill: #2A1F18; }
      .quad-bullet { font-family: 'Switzer', sans-serif; font-size: 11px; fill: #5C4A3D; }
    </style>
  </defs>
  <rect class="bg" x="0" y="0" width="720" height="480"/>

  <!-- Top-left: Producto -->
  <g>
    <rect class="quad-prod" x="40" y="40" width="290" height="180" rx="6"/>
    <text class="letter" x="290" y="100" fill="#9C3A1C" text-anchor="end">P</text>
    <text class="quad-name" x="60" y="62" fill="#9C3A1C">PRODUCTO</text>
    <text class="quad-q" x="60" y="115">¿Qué vendemos?</text>
    <text class="quad-bullet" x="60" y="142">· Diseño, calidad, gama</text>
    <text class="quad-bullet" x="60" y="158">· Marca y packaging</text>
    <text class="quad-bullet" x="60" y="174">· Garantía y postventa</text>
    <text class="quad-bullet" x="60" y="200">· Servicios complementarios</text>
  </g>

  <!-- Top-right: Precio -->
  <g>
    <rect class="quad-price" x="390" y="40" width="290" height="180" rx="6"/>
    <text class="letter" x="640" y="100" fill="#A87A2A" text-anchor="end">P</text>
    <text class="quad-name" x="410" y="62" fill="#A87A2A">PRECIO</text>
    <text class="quad-q" x="410" y="115">¿Cuánto cuesta?</text>
    <text class="quad-bullet" x="410" y="142">· Estrategia (premium, paridad...)</text>
    <text class="quad-bullet" x="410" y="158">· Descuentos y promociones</text>
    <text class="quad-bullet" x="410" y="174">· Formas de pago</text>
    <text class="quad-bullet" x="410" y="200">· Condiciones de crédito</text>
  </g>

  <!-- Bottom-left: Plaza -->
  <g>
    <rect class="quad-place" x="40" y="260" width="290" height="180" rx="6"/>
    <text class="letter" x="290" y="320" fill="#1F6E6E" text-anchor="end">P</text>
    <text class="quad-name" x="60" y="282" fill="#1F6E6E">PLAZA</text>
    <text class="quad-q" x="60" y="335">¿Dónde se vende?</text>
    <text class="quad-bullet" x="60" y="362">· Canales (directo, corto, largo)</text>
    <text class="quad-bullet" x="60" y="378">· Cobertura geográfica</text>
    <text class="quad-bullet" x="60" y="394">· Inventario y transporte</text>
    <text class="quad-bullet" x="60" y="420">· Punto de venta físico/digital</text>
  </g>

  <!-- Bottom-right: Promoción -->
  <g>
    <rect class="quad-promo" x="390" y="260" width="290" height="180" rx="6"/>
    <text class="letter" x="640" y="320" fill="#5B3A4E" text-anchor="end">P</text>
    <text class="quad-name" x="410" y="282" fill="#5B3A4E">PROMOCIÓN</text>
    <text class="quad-q" x="410" y="335">¿Cómo se comunica?</text>
    <text class="quad-bullet" x="410" y="362">· Publicidad</text>
    <text class="quad-bullet" x="410" y="378">· Relaciones públicas</text>
    <text class="quad-bullet" x="410" y="394">· Venta personal</text>
    <text class="quad-bullet" x="410" y="420">· Marketing digital y redes</text>
  </g>

  <!-- Center: cliente objetivo -->
  <circle class="center" cx="360" cy="240" r="42"/>
  <text class="center-label-1" x="360" y="232">CLIENTE</text>
  <text class="center-label-2" x="360" y="256">objetivo</text>
</svg>
