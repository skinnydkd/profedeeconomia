---
/**
 * The five phases of design thinking in a left-to-right sequence:
 * empatizar, definir, idear, prototipar and testar, connected by
 * terracota arrows, plus a curved iteration arrow back to the start.
 * Used in FP to show that the process is iterative, not linear.
 */
---
<svg viewBox="0 0 1000 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dtf-title dtf-desc">
  <title id="dtf-title">Las cinco fases del design thinking</title>
  <desc id="dtf-desc">El design thinking es un proceso iterativo de cinco fases: empatizar, definir, idear, prototipar y testar. Tras testar se vuelve a empezar, repitiendo el ciclo hasta dar con la solución.</desc>
  <defs>
    <style>
      .bg { fill: #FBF6EC; }
      .node { fill: #FFFFFF; stroke: #C44E2C; stroke-width: 1.8; }
      .num-disc { fill: #FBE3D6; }
      .num { font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 500; fill: #9C3A1C; }
      .phase-eyebrow { font-family: 'Switzer', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; fill: #8A7868; }
      .phase-title { font-family: 'Fraunces', serif; font-size: 19px; font-weight: 500; fill: #2A1F18; }
      .phase-body { font-family: 'Switzer', sans-serif; font-size: 11.5px; fill: #5C4A3D; }
      .arrow { fill: none; stroke: #C44E2C; stroke-width: 2; }
      .iter { fill: none; stroke: #C44E2C; stroke-width: 2; stroke-dasharray: 5 4; }
      .iter-label { font-family: 'Fraunces', serif; font-style: italic; font-size: 14px; font-weight: 500; fill: #9C3A1C; }
    </style>
    <marker id="dtf-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0,0 L10,5 L0,10 z" fill="#C44E2C"/>
    </marker>
  </defs>
  <rect class="bg" x="0" y="0" width="1000" height="380"/>

  <!-- Sequential arrows between nodes (cy = 150, r = 44) -->
  <line class="arrow" x1="144" y1="150" x2="206" y2="150" marker-end="url(#dtf-arrow)"/>
  <line class="arrow" x1="334" y1="150" x2="396" y2="150" marker-end="url(#dtf-arrow)"/>
  <line class="arrow" x1="524" y1="150" x2="586" y2="150" marker-end="url(#dtf-arrow)"/>
  <line class="arrow" x1="714" y1="150" x2="776" y2="150" marker-end="url(#dtf-arrow)"/>

  <!-- Phase 1: Empatizar -->
  <g>
    <circle class="node" cx="100" cy="150" r="44"/>
    <circle class="num-disc" cx="100" cy="150" r="17"/>
    <text class="num" x="100" y="155" text-anchor="middle">01</text>
    <text class="phase-eyebrow" x="100" y="218" text-anchor="middle">Fase 1</text>
    <text class="phase-title" x="100" y="244" text-anchor="middle">Empatizar</text>
    <text class="phase-body" x="100" y="270" text-anchor="middle">Entender de verdad a la</text>
    <text class="phase-body" x="100" y="286" text-anchor="middle">persona y su problema.</text>
  </g>

  <!-- Phase 2: Definir -->
  <g>
    <circle class="node" cx="290" cy="150" r="44"/>
    <circle class="num-disc" cx="290" cy="150" r="17"/>
    <text class="num" x="290" y="155" text-anchor="middle">02</text>
    <text class="phase-eyebrow" x="290" y="218" text-anchor="middle">Fase 2</text>
    <text class="phase-title" x="290" y="244" text-anchor="middle">Definir</text>
    <text class="phase-body" x="290" y="270" text-anchor="middle">Concretar el problema</text>
    <text class="phase-body" x="290" y="286" text-anchor="middle">real que vas a resolver.</text>
  </g>

  <!-- Phase 3: Idear -->
  <g>
    <circle class="node" cx="480" cy="150" r="44"/>
    <circle class="num-disc" cx="480" cy="150" r="17"/>
    <text class="num" x="480" y="155" text-anchor="middle">03</text>
    <text class="phase-eyebrow" x="480" y="218" text-anchor="middle">Fase 3</text>
    <text class="phase-title" x="480" y="244" text-anchor="middle">Idear</text>
    <text class="phase-body" x="480" y="270" text-anchor="middle">Generar muchas ideas</text>
    <text class="phase-body" x="480" y="286" text-anchor="middle">sin censura.</text>
  </g>

  <!-- Phase 4: Prototipar -->
  <g>
    <circle class="node" cx="670" cy="150" r="44"/>
    <circle class="num-disc" cx="670" cy="150" r="17"/>
    <text class="num" x="670" y="155" text-anchor="middle">04</text>
    <text class="phase-eyebrow" x="670" y="218" text-anchor="middle">Fase 4</text>
    <text class="phase-title" x="670" y="244" text-anchor="middle">Prototipar</text>
    <text class="phase-body" x="670" y="270" text-anchor="middle">Construir una versión</text>
    <text class="phase-body" x="670" y="286" text-anchor="middle">rápida y barata.</text>
  </g>

  <!-- Phase 5: Testar -->
  <g>
    <circle class="node" cx="860" cy="150" r="44"/>
    <circle class="num-disc" cx="860" cy="150" r="17"/>
    <text class="num" x="860" y="155" text-anchor="middle">05</text>
    <text class="phase-eyebrow" x="860" y="218" text-anchor="middle">Fase 5</text>
    <text class="phase-title" x="860" y="244" text-anchor="middle">Testar</text>
    <text class="phase-body" x="860" y="270" text-anchor="middle">Probarla con personas</text>
    <text class="phase-body" x="860" y="286" text-anchor="middle">reales y aprender.</text>
  </g>

  <!-- Iteration arrow: from Testar back up and over to Empatizar -->
  <path class="iter" d="M 860 106 C 860 40, 100 40, 100 106" marker-end="url(#dtf-arrow)"/>
  <text class="iter-label" x="480" y="44" text-anchor="middle">se repite hasta acertar</text>
</svg>
