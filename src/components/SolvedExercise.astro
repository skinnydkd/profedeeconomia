---
type Props = {
  /** "7.1", "9.3"... shown big in the eyebrow */
  number: string;
  /** Short title for the exercise */
  title: string;
};

const { number, title } = Astro.props;
---

<figure class="solved-exercise" role="group">
  <header class="solved-exercise__header">
    <span class="solved-exercise__label">Ejercicio resuelto</span>
    <span class="solved-exercise__number">{number}</span>
  </header>
  <h3 class="solved-exercise__title">{title}</h3>
  <div class="solved-exercise__body">
    <slot />
  </div>
</figure>

<style>
  .solved-exercise {
    margin: 3rem 0;
    padding: 2rem 2.2rem 2.2rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-left: 5px solid var(--color-terra);
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(42, 31, 24, 0.05), 0 6px 18px rgba(42, 31, 24, 0.06);
  }

  .solved-exercise__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .solved-exercise__label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-terra-deep);
    font-weight: 700;
  }

  .solved-exercise__number {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2.4rem;
    color: var(--color-mustard-deep);
    line-height: 1;
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }

  .solved-exercise__title {
    font-family: var(--font-serif);
    font-size: 1.45rem;
    line-height: 1.25;
    color: var(--color-ink);
    margin: 0 0 1.2rem;
    font-weight: 500;
    font-variation-settings: "SOFT" 80, "WONK" 0;
  }

  .solved-exercise__body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .solved-exercise__body :global(p) {
    margin: 0 0 1em;
  }
  .solved-exercise__body :global(p:last-child) { margin-bottom: 0; }

  /* No drop cap inside */
  .solved-exercise__body :global(p::first-letter) {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }

  /* Strong (used for "Enunciado", "Datos", "Solución" labels) */
  .solved-exercise__body :global(p strong:only-child) {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-terra-deep);
    margin-top: 0.4rem;
    margin-bottom: 0.6rem;
    font-weight: 700;
  }

  .solved-exercise__body :global(ol) {
    padding-left: 1.4rem;
    counter-reset: step;
    list-style: none;
  }
  .solved-exercise__body :global(ol > li) {
    counter-increment: step;
    position: relative;
    padding-left: 0.6rem;
    margin-bottom: 0.7em;
  }
  .solved-exercise__body :global(ol > li::before) {
    content: counter(step) ".";
    position: absolute;
    left: -1.4rem;
    width: 1.4rem;
    text-align: left;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-terra);
    font-weight: 500;
    font-variation-settings: "SOFT" 80, "WONK" 0;
  }

  .solved-exercise__body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-bg-cream);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    color: var(--color-terra-deep);
  }

  .solved-exercise__body :global(pre) {
    background: var(--color-bg-cream);
    padding: 0.9rem 1.1rem;
    border-radius: 4px;
    border-left: 3px solid var(--color-mustard);
    overflow-x: auto;
    font-size: 0.95rem;
    margin: 0.7em 0;
  }

  /* Print-friendly: avoid splitting an exercise across pages when possible */
  @media print {
    .solved-exercise {
      box-shadow: none;
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }
</style>
