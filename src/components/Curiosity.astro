---
type Props = {
  /** Short title that appears as the WONK serif italic line */
  title: string;
  /** Optional eyebrow override; defaults to "Sabíais que…" */
  label?: string;
};

const { title, label = '¿Sabíais que…?' } = Astro.props;
---

<aside class="curiosity">
  <span class="curiosity__label">{label}</span>
  <h4 class="curiosity__title">{title}</h4>
  <div class="curiosity__body">
    <slot />
  </div>
</aside>

<style>
  .curiosity {
    margin: 2.4rem 0;
    padding: 1.6rem 1.8rem 1.7rem 2rem;
    background: var(--color-mustard-soft);
    border-left: 3px solid var(--color-mustard);
    border-radius: 0 6px 6px 0;
    position: relative;
  }

  .curiosity::before {
    content: "✱";
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    color: var(--color-mustard-deep);
    font-size: 1.6rem;
    line-height: 1;
    opacity: 0.5;
  }

  .curiosity__label {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-mustard-deep);
    font-weight: 700;
    display: block;
    margin-bottom: 0.4rem;
  }

  .curiosity__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 2rem 0.7rem 0;
    font-weight: 500;
    text-transform: none;
    letter-spacing: -0.005em;
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }

  .curiosity__body {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
  }
  .curiosity__body :global(p) { margin: 0 0 0.8em; }
  .curiosity__body :global(p:last-child) { margin-bottom: 0; }

  /* No drop cap inside */
  .curiosity__body :global(p::first-letter) {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }

  @media print {
    .curiosity { break-inside: avoid; page-break-inside: avoid; }
  }
</style>
