---
/**
 * Numbered steps with editorial styling. Use it whenever a sequence
 * of actions, criteria or stages benefits from explicit numbering and
 * stronger visual hierarchy than a regular ordered list.
 *
 *   <Steps>
 *     <li>Primer paso…</li>
 *     <li>Segundo paso…</li>
 *   </Steps>
 *
 * Renders large terracota numbers and indented prose. Do NOT nest.
 */
type Props = {
  /** Optional eyebrow shown above the list. e.g. "Pasos", "Criterios". */
  label?: string;
  /** Optional small title shown below the eyebrow. */
  title?: string;
  /** Default counter (1) or roman (I, II, III…). */
  variant?: 'arabic' | 'roman';
};

const { label, title, variant = 'arabic' } = Astro.props;
---

<section class:list={['steps', `steps--${variant}`]}>
  {label && <span class="steps__label">{label}</span>}
  {title && <h4 class="steps__title">{title}</h4>}
  <ol class="steps__list">
    <slot />
  </ol>
</section>

<style>
  .steps {
    margin: 2.4rem 0;
    padding: 1.4rem 1.6rem 1.5rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-left: 4px solid var(--color-terra);
    border-radius: 0 6px 6px 0;
  }

  .steps__label {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-terra-deep);
    font-weight: 700;
    display: block;
    margin-bottom: 0.4rem;
  }
  .steps__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 1.1rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: -0.005em;
    font-variation-settings: "SOFT" 80;
  }

  .steps__list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: step;
  }
  .steps__list :global(li) {
    counter-increment: step;
    position: relative;
    padding: 0.4rem 0 0.5rem 3rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink);
    border-bottom: 1px dashed var(--color-line-soft);
  }
  .steps__list :global(li:last-child) { border-bottom: none; padding-bottom: 0.2rem; }
  .steps__list :global(li::before) {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0.3rem;
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-terra-soft);
    color: var(--color-terra-deep);
    border-radius: 50%;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    font-weight: 500;
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }

  /* Roman variant — useful for principios, axiomas, leyes */
  .steps--roman .steps__list { counter-reset: step; }
  .steps--roman .steps__list :global(li::before) {
    content: counter(step, upper-roman);
    font-size: 0.95rem;
    background: var(--color-mustard-soft);
    color: var(--color-mustard-deep);
  }

  .steps__list :global(p) { margin: 0 0 0.5em; }
  .steps__list :global(p:last-child) { margin-bottom: 0; }
  .steps__list :global(strong) { color: var(--color-ink); }

  /* No drop cap inside */
  .steps__list :global(p::first-letter) {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }

  @media print {
    .steps { break-inside: avoid; page-break-inside: avoid; }
  }
</style>
