---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div>profedeeconomia.es — material editorial para profesores de instituto · {year}</div>
    <div>
      <a href="/sobre/">Sobre el proyecto</a> ·
      <a href="/contacto/">Contacto</a> ·
      <a href="/legal/aviso-legal/">Aviso legal</a> ·
      <a href="/legal/privacidad/">Privacidad</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-line);
    padding: 3.5rem 0 2.5rem;
    font-size: 0.95rem;
    color: var(--color-ink-mute);
  }
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
  }
  .container a { color: var(--color-ink-soft); text-decoration: none; }
  .container a:hover { color: var(--color-terra); }
</style>
