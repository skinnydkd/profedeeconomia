---
import type { Asignatura } from '@/lib/asignaturas';

type Props = { asignatura: Asignatura };
const { asignatura: a } = Astro.props;
const isPublicado = a.estado === 'publicado';
---

<a href={`/${a.slug}/`} class:list={['subject-card', `c-${a.color}`, !isPublicado && 'is-proximamente']}>
  <div class="level-row">
    <span class="level">{a.level}</span>
    <span class="num">{a.num}</span>
  </div>
  <h3>{a.title}</h3>
  <p class="tagline">{a.tagline}</p>
  {isPublicado
    ? <span class="arrow">Entrar →</span>
    : <span class="badge-proximamente">Próximamente</span>
  }
</a>

<style>
  .subject-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 1.6rem 1.8rem 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition:
      transform .25s var(--ease-soft),
      box-shadow .25s var(--ease-soft),
      border-color .25s var(--ease-soft);
  }
  .subject-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background: var(--card-color, var(--color-terra));
  }
  .subject-card.c-edmn    { --card-color: var(--color-edmn);    --card-color-soft: var(--color-edmn-soft); }
  .subject-card.c-eco1    { --card-color: var(--color-eco1);    --card-color-soft: var(--color-eco1-soft); }
  .subject-card.c-eco4    { --card-color: var(--color-eco4);    --card-color-soft: var(--color-eco4-soft); }
  .subject-card.c-fopp    { --card-color: var(--color-fopp);    --card-color-soft: var(--color-fopp-soft); }
  .subject-card.c-taller3 { --card-color: var(--color-taller3); --card-color-soft: var(--color-taller3-soft); }
  .subject-card.c-ipe1    { --card-color: var(--color-ipe1);    --card-color-soft: var(--color-ipe1-soft); }
  .subject-card.c-ipe2    { --card-color: var(--color-ipe2);    --card-color-soft: var(--color-ipe2-soft); }
  .subject-card.c-eeae    { --card-color: var(--color-eeae);    --card-color-soft: var(--color-eeae-soft); }
  .subject-card.c-gpe     { --card-color: var(--color-gpe);     --card-color-soft: var(--color-gpe-soft); }
  .subject-card.c-proximamente { --card-color: var(--color-ink-mute); --card-color-soft: var(--color-line); }

  .subject-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 1px 2px rgba(42, 31, 24, 0.06),
      0 8px 24px rgba(42, 31, 24, 0.08);
    border-color: var(--card-color);
  }

  /* Próximamente: card aparece atenuada però funcional (porta al hub placeholder) */
  .subject-card.is-proximamente {
    background: var(--color-bg);
    border-style: dashed;
  }
  .subject-card.is-proximamente::before {
    opacity: 0.55;
  }
  .subject-card.is-proximamente h3,
  .subject-card.is-proximamente .tagline {
    opacity: 0.78;
  }

  .level-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 0.4rem;
  }
  .level {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--card-color);
    background: var(--card-color-soft);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-weight: 500;
  }
  .num {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    color: var(--card-color);
    font-size: 1.6rem;
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }
  h3 {
    font-size: 1.55rem;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .tagline {
    color: var(--color-ink-soft);
    font-size: 1rem;
    margin: 0;
    flex: 1;
    line-height: 1.55;
  }
  .arrow {
    color: var(--card-color);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .badge-proximamente {
    color: var(--color-ink-mute);
    font-size: 0.82rem;
    font-weight: 600;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.65rem;
    background: var(--color-bg-cream);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    width: fit-content;
  }
</style>
