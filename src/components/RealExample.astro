---
type Props = {
  /** Short headline for the example */
  title: string;
  /** Optional source/citation (printed in italic small at the bottom) */
  source?: string;
  /** Optional URL the source links to */
  sourceUrl?: string;
};

const { title, source, sourceUrl } = Astro.props;
---

<aside class="real-example">
  <div class="real-example__rule"></div>
  <span class="real-example__label">Ejemplo real</span>
  <h4 class="real-example__title">{title}</h4>
  <div class="real-example__body">
    <slot />
  </div>
  {source && (
    <p class="real-example__source">
      Fuente:
      {sourceUrl ? <a href={sourceUrl} target="_blank" rel="noopener noreferrer">{source}</a> : <span>{source}</span>}
    </p>
  )}
</aside>

<style>
  .real-example {
    margin: 2.6rem 0;
    padding: 1.7rem 1.9rem 1.5rem;
    background: var(--color-fopp-soft);
    border-radius: 6px;
    position: relative;
  }

  .real-example__rule {
    width: 2.5rem;
    height: 3px;
    background: var(--color-fopp);
    border-radius: 999px;
    margin-bottom: 0.9rem;
  }

  .real-example__label {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fopp);
    font-weight: 700;
    display: block;
    margin-bottom: 0.4rem;
  }

  .real-example__title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 0.9rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: -0.005em;
    font-variation-settings: "SOFT" 80, "WONK" 0;
  }

  .real-example__body {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--color-ink);
  }
  .real-example__body :global(p) { margin: 0 0 0.8em; }
  .real-example__body :global(p:last-child) { margin-bottom: 0; }

  /* No drop cap inside */
  .real-example__body :global(p::first-letter) {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }

  .real-example__source {
    margin: 1rem 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-ink-mute);
    font-variation-settings: "SOFT" 80;
  }
  .real-example__source a {
    color: var(--color-fopp);
    text-decoration: none;
    border-bottom: 1px solid var(--color-fopp);
  }
  .real-example__source a:hover { color: var(--color-ink); }

  @media print {
    .real-example { break-inside: avoid; page-break-inside: avoid; }
  }
</style>
