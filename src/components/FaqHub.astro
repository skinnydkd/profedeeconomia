---
/**
 * Visible FAQ block for the subject hubs. Semantic <dl> Q&A so both readers and
 * AI answer-extractors get clean question→answer pairs. The matching FAQPage
 * JSON-LD is emitted from the page via faqLd() (src/lib/seo.ts).
 */
import type { Faq } from '@/lib/faq';

interface Props {
  faqs: Faq[];
}
const { faqs } = Astro.props;
---

<section class="faq">
  <div class="container">
    <h2>Preguntas frecuentes</h2>
    <dl class="faq-list">
      {faqs.map((f) => (
        <div class="faq-item">
          <dt>{f.q}</dt>
          <dd>{f.a}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .faq { padding: 0 0 clamp(3rem, 7vw, 6rem); }
  .faq h2 { margin: 0 0 1.5rem; }
  .faq-list { margin: 0; padding: 0; }
  .faq-item {
    padding: 1.3rem 0;
    border-top: 1px solid var(--color-line);
    max-width: 70ch;
  }
  .faq-item:last-child { border-bottom: 1px solid var(--color-line); }
  dt {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
  }
  dd {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    line-height: 1.6;
  }
</style>
