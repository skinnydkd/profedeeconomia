---
/**
 * Wrapper for any inline SVG / illustration with caption and optional
 * source attribution. Used to keep figures consistent across units.
 *
 *   <Diagram caption="Las cuatro funciones de la empresa" source="LOMLOE RD 243/2022">
 *     <PorterForces />
 *   </Diagram>
 */
type Props = {
  caption: string;
  source?: string;
  /** "default" centers the figure with full width; "tight" keeps it within text width. */
  variant?: 'default' | 'tight';
  /** Stable id used by capture-diagrams.mjs to name the PNG for slide output. */
  id?: string;
};

const { caption, source, variant = 'default', id } = Astro.props;
---

<figure
  class:list={['diagram', `diagram--${variant}`]}
  data-slide-diagram={id ?? ''}
>
  <div class="diagram__inner">
    <slot />
  </div>
  <figcaption class="diagram__caption">
    <span class="diagram__caption-text">{caption}</span>
    {source && <span class="diagram__caption-source">Fuente: {source}</span>}
  </figcaption>
</figure>

<style>
  .diagram {
    margin: 2.6rem 0;
    padding: 1.5rem 1.6rem 1.2rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(42, 31, 24, 0.04), 0 4px 14px rgba(42, 31, 24, 0.05);
  }
  .diagram--tight { max-width: var(--measure-prose); }

  .diagram__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-x: auto;
  }
  .diagram__inner :global(svg) {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
  }

  .diagram__caption {
    margin-top: 0.9rem;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--color-line);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--color-ink-soft);
    text-align: center;
    font-variation-settings: "SOFT" 80;
  }
  .diagram__caption-text { display: block; }
  .diagram__caption-source {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.78rem;
    color: var(--color-ink-mute);
    font-style: italic;
  }

  @media print {
    .diagram {
      box-shadow: none;
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }
</style>
