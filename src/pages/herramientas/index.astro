---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Herramientas docentes"
  description="Generador de Situaciones de Aprendizaje LOMLOE y creador de pruebas. En desarrollo."
>
  <div class="container">
    <nav class="breadcrumb"><a href="/">Inicio</a> <span class="sep">›</span> <span>Herramientas</span></nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">Material transversal</span>
      <h1>Herramientas <span class="serif-italic-wonk accent">docentes</span>.</h1>
      <p class="lede">
        En esta sección vivirán el generador de Situaciones de Aprendizaje LOMLOE y el creador
        de pruebas de evaluación. Pendiente de migración (fase 0.5, abril 2027+).
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .hero { padding: 1rem 0 clamp(3rem, 7vw, 6rem); }
  h1 { max-width: 22ch; margin: 1rem 0 0.6rem; }
  .accent { color: var(--color-terra); }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-ink-soft);
    max-width: 55ch;
    margin: 1.5rem 0;
    line-height: 1.5;
    font-variation-settings: "SOFT" 80;
  }
</style>
