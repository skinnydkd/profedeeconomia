---
import BaseLayout from '@layouts/BaseLayout.astro';
import EjemploEmpresa from '@components/emprendimiento/EjemploEmpresa.astro';
import { getCollection } from 'astro:content';

const ejemplos = (await getCollection('emprendimientoEjemplos'))
  .filter((e) => e.data.estado === 'publicado')
  .sort((a, b) => a.data.orden - b.data.orden || a.data.nombre.localeCompare(b.data.nombre));
---
<BaseLayout
  title="Ejemplos de empresas con chispa"
  description="Casos trabajados de empresas (reales, ficticias y locales) con su marketing mix (4P) o su modelo de negocio (BMC) rellenado, para el proyecto de emprendimiento."
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href="/emprendimiento/">Emprendimiento</a> <span class="sep">›</span>
      <span>Ejemplos con chispa</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">Emprendimiento · ejemplos</span>
      <h1>Empresas con chispa</h1>
      <p class="lede">
        Casos para ver el <strong>marketing mix (4P)</strong> y el <strong>modelo de negocio (BMC)</strong>
        en acción: empresas reales que reconoces, startups inventadas con gracia y algún negocio del barrio.
        Úsalos como espejo para vuestro propio proyecto.
      </p>
    </div>
  </section>

  <section class="grid">
    <div class="container">
      {ejemplos.length === 0
        ? <p class="empty">Pronto, una galería de ejemplos con chispa.</p>
        : ejemplos.map((e) => <EjemploEmpresa ejemplo={e.data} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .container { max-width: 920px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .hero { padding: 1rem 0 1rem; }
  .kicker { font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-terra); }
  h1 { margin: 0.6rem 0 0.6rem; }
  .lede { font-family: var(--font-serif); font-style: italic; font-size: 1.3rem; line-height: 1.5; color: var(--color-ink-soft); max-width: 56ch; font-variation-settings: "SOFT" 80; }
  .grid { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .empty { font-family: var(--font-serif); font-style: italic; color: var(--color-ink-mute); }
</style>
