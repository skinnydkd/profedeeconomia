---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('emprendimientoActividades'))
  .filter((a) => a.data.estado === 'publicado')
  .sort((a, b) => a.data.orden - b.data.orden || a.data.title.localeCompare(b.data.title));
const rendered = await Promise.all(entries.map(async (a) => ({ a, Content: (await render(a)).Content })));
---
<BaseLayout
  title="Kit de actitud emprendedora"
  description="Actividades para trabajar la actitud emprendedora: perder la vergüenza a pedir y a hablar en público, pitch, negociar. Para usar tal cual en clase."
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href="/emprendimiento/">Emprendimiento</a> <span class="sep">›</span>
      <span>Kit de actitud</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">Emprendimiento · actitud</span>
      <h1>Perder la vergüenza (y otras valentías)</h1>
      <p class="lede">
        Emprender es, sobre todo, atreverse: <strong>pedir, preguntar, hablar en público, decir que no,
        negociar</strong>. Estas actividades cortas entrenan esa actitud antes (y durante) el proyecto.
      </p>
    </div>
  </section>

  <section class="list">
    <div class="container">
      {rendered.length === 0
        ? <p class="empty">Pronto, un kit de actividades para perder la vergüenza.</p>
        : rendered.map(({ a, Content }) => (
          <article class="act">
            <h2 class="act__title">{a.data.title}</h2>
            <p class="act__meta">
              <strong>Trabaja:</strong> {a.data.objetivo}
              {a.data.duracion && <> · {a.data.duracion}</>}
              {a.data.agrupacion && <> · {a.data.agrupacion}</>}
            </p>
            <div class="act__body"><Content /></div>
          </article>
        ))}
    </div>
  </section>
</BaseLayout>

<style>
  .container { max-width: 760px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .hero { padding: 1rem 0 1rem; }
  .kicker { font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-terra-deep); }
  h1 { margin: 0.6rem 0 0.6rem; }
  .lede { font-family: var(--font-serif); font-style: italic; font-size: 1.3rem; line-height: 1.5; color: var(--color-ink-soft); max-width: 52ch; font-variation-settings: "SOFT" 80; }
  .list { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .act { border-top: 1px solid var(--color-line); padding: 2rem 0; }
  .act__title { font-size: 1.5rem; margin: 0 0 0.4rem; }
  .act__meta { font-family: var(--font-sans); font-size: 0.92rem; color: var(--color-ink-mute); margin: 0 0 1rem; }
  .act__meta strong { color: var(--color-terra-deep); }
  .act__body { font-size: 1.08rem; line-height: 1.7; }
  .empty { font-family: var(--font-serif); font-style: italic; color: var(--color-ink-mute); }
</style>
