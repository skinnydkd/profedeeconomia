---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURAS, ASIGNATURA_SLUGS } from '@/lib/asignaturas';
import { getCollection } from 'astro:content';

const gpe = ASIGNATURAS['gpe-bach'];
const edmn = ASIGNATURAS['edmn-2bach'];

// Inverse index: the emprendimiento angle of every subject. We surface the
// project-type activities and the capstone projects (cuaderno de proyecto) that
// already live inside each asignatura — single source of truth, no duplication.
const actsAll = await getCollection('actividades');
const proyAll = await getCollection('proyecto');
const proyectoActs = actsAll.filter((x) => x.data.tipo === 'proyecto' && x.data.estado === 'publicado');

const porAsignatura = ASIGNATURA_SLUGS
  .map((slug) => ({
    a: ASIGNATURAS[slug],
    acts: proyectoActs
      .filter((x) => x.data.asignatura === slug)
      .sort((x, y) => x.data.unidad_relacionada - y.data.unidad_relacionada),
    capstone: proyAll.some((x) => x.data.asignatura === slug && x.data.estado === 'publicado'),
  }))
  .filter((x) => x.a.estado === 'publicado' && (x.acts.length > 0 || x.capstone));
---

<BaseLayout
  title="Emprendimiento"
  description="La asignatura de emprendimiento puro (GPE) y «De cero a empresa», un proyecto transversal para llevar al aula en cualquier nivel."
>
  <div class="container">
    <nav class="breadcrumb"><a href="/">Inicio</a> <span class="sep">›</span> <span>Emprendimiento</span></nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">Material transversal</span>
      <h1><span class="serif-italic-wonk accent">Emprendimiento</span> en el aula.</h1>
      <p class="lede">
        El emprendimiento atraviesa todas nuestras asignaturas. Este es el sitio que
        lo reúne: un proyecto para montar con el alumnado a cualquier nivel, las dos
        materias que lo trabajan a fondo (GPE y EDMN) y el ángulo emprendedor de cada
        asignatura, todo enlazado a donde de verdad vive.
      </p>
    </div>
  </section>

  <section class="cards">
    <div class="container">
      <div class="card-grid">
        <a class="card card--proyecto" href="/emprendimiento/proyecto/">
          <span class="card__eyebrow">Proyecto transversal</span>
          <h2 class="card__title serif">De cero a empresa</h2>
          <p class="card__desc">
            En equipo, el alumnado crea una empresa que resuelve un problema real,
            la valida saliendo a la calle y la pone a prueba con datos. Doce fases
            con <strong>cuaderno del alumno</strong> para rellenar —con sus plantillas
            visuales (Business Model Canvas, punto muerto…)— y ejemplos, entrevistas
            y actividades tejidos en cada paso. Modular: de un sprint a un curso entero.
          </p>
          <span class="card__cta">Ver el proyecto y el cuaderno →</span>
        </a>

        <a class="card card--gpe" href={`/${gpe.slug}/`}>
          <span class="card__eyebrow">Asignatura</span>
          <h2 class="card__title serif">{gpe.title}</h2>
          <p class="card__desc">
            La materia de emprendimiento puro de Bachillerato: del equipo y la idea
            al pitch final, con libro, cuaderno de proyecto, actividades y tests.
          </p>
          <span class="card__cta">Ir a la asignatura →</span>
        </a>

        <a class="card card--edmn" href={`/${edmn.slug}/proyecto/`}>
          <span class="card__eyebrow">Capstone de 2.º BACH</span>
          <h2 class="card__title serif">El plan de empresa de EDMN</h2>
          <p class="card__desc">
            El proyecto que recorre todo Empresa y Diseño de Modelos de Negocio:
            seis fases del equipo y el mercado al plan económico-financiero y el
            pitch, con plantillas para rellenar en cada paso.
          </p>
          <span class="card__cta">Ver el capstone →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="recursos">
    <div class="container">
      <h2 class="recursos__h">Las herramientas, ya dentro del proyecto</h2>
      <p class="recursos__lead">
        Estos recursos aparecen <strong>integrados en la fase donde se usan</strong>:
        los ejemplos en el modelo de negocio, la entrevista en la validación, el kit
        de actitud en las primeras fases. Aquí los tenéis también sueltos, como
        biblioteca de consulta.
      </p>
      <div class="card-grid">
        <a class="card card--rec" href="/emprendimiento/ejemplos/">
          <span class="card__eyebrow">Ejemplos con chispa</span>
          <h3 class="card__title serif">Empresas, 4P y BMC en acción</h3>
          <p class="card__desc">Casos reales, ficticios divertidos y locales, con su marketing mix o su modelo de negocio rellenado. Espejos para vuestro proyecto.</p>
          <span class="card__cta">Ver ejemplos →</span>
        </a>
        <a class="card card--rec" href="/emprendimiento/actividades/">
          <span class="card__eyebrow">Kit de actitud</span>
          <h3 class="card__title serif">Perder la vergüenza</h3>
          <p class="card__desc">Actividades cortas para atreverse a pedir, preguntar y hablar en público: la actitud que más cuesta y más vale al emprender.</p>
          <span class="card__cta">Abrir el kit →</span>
        </a>
        <a class="card card--rec" href="/emprendimiento/entrevista-emprendedores/">
          <span class="card__eyebrow">Proyecto</span>
          <h3 class="card__title serif">Entrevista a emprendedores</h3>
          <p class="card__desc">El alumnado sale a la calle a entrevistar a propietarios de negocios locales. Guion, banco de preguntas y plantilla descargable.</p>
          <span class="card__cta">Ver el proyecto →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="indice">
    <div class="container">
      <h2 class="indice__h">El emprendimiento, asignatura por asignatura</h2>
      <p class="indice__lead">
        No reinventamos nada: el emprendimiento ya está dentro de cada materia. Aquí
        tienes el atajo a su proyecto-capstone y a sus actividades de proyecto, cada
        una enlazada a su asignatura.
      </p>
      <div class="indice__grid">
        {porAsignatura.map((x) => (
          <div class={`materia c-${x.a.color}`}>
            <a class="materia__name" href={`/${x.a.slug}/`}>{x.a.title}</a>
            <span class="materia__level">{x.a.level}</span>
            <ul class="materia__links">
              {x.capstone && (
                <li><a href={`/${x.a.slug}/proyecto/`}>Cuaderno de proyecto (capstone)</a></li>
              )}
              {x.acts.map((act) => (
                <li><a href={`/${x.a.slug}/actividades/`}>{act.data.title}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container { max-width: 1240px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .hero { padding: 1rem 0 clamp(2rem, 5vw, 3.5rem); }
  .kicker { font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-terra); }
  h1 { max-width: 22ch; margin: 0.6rem 0 0.8rem; }
  .accent { color: var(--color-terra); }
  .lede { font-family: var(--font-serif); font-style: italic; font-size: 1.4rem; color: var(--color-ink-soft); max-width: 56ch; margin: 1rem 0; line-height: 1.5; font-variation-settings: "SOFT" 80; }
  .cards { padding: 0 0 clamp(3rem, 7vw, 6rem); }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .card { display: block; background: #fff; border: 1px solid var(--color-line); border-top: 3px solid var(--color-mustard); padding: 1.6rem 1.75rem 1.4rem; text-decoration: none; color: inherit; transition: box-shadow 0.18s ease, transform 0.18s ease, border-color 0.18s ease; }
  .card--gpe { border-top-color: #8C2F39; }
  .card:hover { box-shadow: 0 4px 18px rgba(42,31,24,0.08); transform: translateY(-2px); }
  .card__eyebrow { font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-mustard-deep); font-weight: 600; }
  .card--gpe .card__eyebrow { color: #8C2F39; }
  .card__title { font-size: 1.6rem; line-height: 1.1; margin: 0.5rem 0 0.75rem; font-variation-settings: "SOFT" 80; }
  .card__desc { color: var(--color-ink-soft); font-size: 1rem; line-height: 1.6; margin: 0 0 1rem; }
  .card__cta { font-size: 0.9rem; font-weight: 600; color: var(--color-terra); }
  .recursos { padding: 0 0 clamp(3rem, 7vw, 6rem); border-top: 1px solid var(--color-line); padding-top: clamp(2.5rem, 5vw, 4rem); }
  .recursos__h { font-size: 1.5rem; margin: 0 0 0.6rem; }
  .recursos__lead { max-width: 60ch; margin: 0 0 1.8rem; color: var(--color-ink-soft); font-size: 1rem; line-height: 1.6; }
  .card--rec { border-top-color: var(--color-terra); }
  .card--rec .card__eyebrow { color: var(--color-terra); }
  .card--rec .card__title { font-size: 1.35rem; }
  .card--edmn { border-top-color: var(--color-edmn); }
  .card--edmn .card__eyebrow { color: var(--color-edmn); }

  /* Inverse index — emprendimiento angle of each subject */
  .indice { padding: 0 0 clamp(3rem, 7vw, 6rem); border-top: 1px solid var(--color-line); padding-top: clamp(2.5rem, 5vw, 4rem); }
  .indice__h { font-size: 1.5rem; margin: 0 0 0.6rem; }
  .indice__lead { max-width: 64ch; margin: 0 0 1.8rem; color: var(--color-ink-soft); font-size: 1rem; line-height: 1.6; }
  .indice__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.2rem; }
  .materia { border: 1px solid var(--color-line); border-left: 4px solid var(--card-color, var(--color-mustard)); border-radius: 8px; padding: 1.1rem 1.3rem; background: var(--color-paper); }
  .materia.c-edmn { --card-color: var(--color-edmn); }
  .materia.c-eco1 { --card-color: var(--color-eco1); }
  .materia.c-eco4 { --card-color: var(--color-eco4); }
  .materia.c-fopp { --card-color: var(--color-fopp); }
  .materia.c-taller3 { --card-color: var(--color-taller3); }
  .materia.c-ipe1 { --card-color: var(--color-ipe1); }
  .materia.c-ipe2 { --card-color: var(--color-ipe2); }
  .materia.c-eeae { --card-color: var(--color-eeae); }
  .materia.c-gpe { --card-color: var(--color-gpe); }
  .materia__name { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 500; color: var(--color-ink); text-decoration: none; display: block; }
  .materia__name:hover { color: var(--card-color); }
  .materia__level { font-family: var(--font-sans); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-ink-mute); font-weight: 600; }
  .materia__links { list-style: none; margin: 0.7rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.35rem; }
  .materia__links a { font-size: 0.92rem; color: var(--color-ink-soft); text-decoration: none; line-height: 1.4; }
  .materia__links a:hover { color: var(--card-color); }
  .materia__links li { padding-left: 0.9rem; position: relative; }
  .materia__links li::before { content: "→"; position: absolute; left: 0; color: var(--card-color); }
</style>
