---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURA_SLUGS, ASIGNATURAS } from '@/lib/asignaturas';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

/**
 * Listado de diapositivas por asignatura.
 *
 * Las diapositivas se generan automáticamente desde los MDX del libro
 * mediante `npm run build:slides`. Cada unidad publicada tiene un PDF
 * descargable y un HTML para previsualización web en
 * `/slides/<asignatura>/<unit>.{pdf,html}`.
 */

export const getStaticPaths = (async () => {
  return ASIGNATURA_SLUGS.map((slug) => ({
    params: { asignatura: slug },
    props: { asignatura: ASIGNATURAS[slug] },
  }));
}) satisfies GetStaticPaths;

const { asignatura: a } = Astro.props;

const allUnits = await getCollection('libro');
const units = allUnits
  .filter((u) => u.data.asignatura === a.slug && u.data.estado === 'publicado')
  .sort((x, y) => x.data.unidad - y.data.unidad);

const slidesBase = `/slides/${a.slug}`;
---

<BaseLayout
  title={`Diapositivas — ${a.shortLabel}`}
  description={`Diapositivas para cada unidad del libro de ${a.title}.`}
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <span>Diapositivas</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">{a.shortLabel} · diapositivas</span>
      <h1>Diapositivas para clase</h1>
      <p class="lede">
        {units.length === 0
          ? 'Las diapositivas se publicarán a medida que el libro se vaya completando.'
          : `Un deck por unidad. Auto-generado desde el libro, pensado como esqueleto para clase: cada profesor puede afinarlo según el grupo y el tiempo disponible.`}
      </p>

      {units.length > 0 && (
        <p class="meta">
          {units.length} {units.length === 1 ? 'unidad' : 'unidades'} · PDF + HTML por
          cada una · estética {a.shortLabel}
        </p>
      )}
    </div>
  </section>

  {units.length > 0 && (
    <section class="grid">
      <div class="container">
        <ul class="card-grid">
          {units.map((u) => {
            const slug = u.id.split('/').pop()?.replace(/\.mdx?$/, '');
            return (
              <li class="card">
                <div class="card__num">{String(u.data.unidad).padStart(2, '0')}</div>
                <h3 class="card__title">{u.data.title}</h3>
                {u.data.lema && <p class="card__lede">{u.data.lema}</p>}
                <div class="card__meta">
                  {u.data.duracion && <span>{u.data.duracion}</span>}
                  {u.data.bloque && <span>· {u.data.bloque}</span>}
                </div>
                <div class="card__cta">
                  <a class="cta cta--primary" href={`${slidesBase}/${slug}.pdf`} download>
                    <span class="cta__icon" aria-hidden="true">↓</span>
                    Descargar PDF
                  </a>
                  <a class="cta cta--ghost" href={`${slidesBase}/${slug}.html`} target="_blank" rel="noopener">
                    Ver en navegador
                  </a>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <section class="note">
    <div class="container">
      <p class="note-text">
        Cada deck se genera automáticamente desde el MDX del libro. Los esqueletos
        contienen el título, los objetivos, los conceptos clave y una diapositiva
        por sección del capítulo. Si encuentras errores o quieres aportar
        diapositivas refinadas, escríbenos a
        <a class="editorial-link" href="mailto:hola@profedeeconomia.es">hola@profedeeconomia.es</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hero { padding: 1rem 0 clamp(2rem, 5vw, 4rem); }
  h1 { margin: 1rem 0 0.6rem; }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--color-ink-soft);
    max-width: 55ch;
    line-height: 1.5;
    margin: 1.5rem 0 0.6rem;
    font-variation-settings: "SOFT" 80;
  }
  .meta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ink-mute);
    margin-top: 0.4rem;
  }

  .grid { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .card-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    padding: 1.6rem 1.7rem 1.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform .2s var(--ease-soft), border-color .2s var(--ease-soft), box-shadow .2s var(--ease-soft);
  }
  .card:hover {
    border-color: var(--color-terra);
    transform: translateY(-2px);
    box-shadow: 0 4px 18px rgba(42, 31, 24, 0.08);
  }
  .card__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.8rem;
    color: var(--color-mustard-deep);
    font-variation-settings: "SOFT" 100, "WONK" 1;
    line-height: 1;
  }
  .card__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.25;
    color: var(--color-ink);
    margin: 0;
    font-weight: 500;
    font-variation-settings: "SOFT" 60;
  }
  .card__lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    line-height: 1.45;
    margin: 0;
    font-variation-settings: "SOFT" 80;
    flex: 1;
  }
  .card__meta {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-mute);
    margin-top: 0.4rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .card__cta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.7rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.55rem 0.9rem;
    border-radius: 5px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background .2s var(--ease-soft), color .2s var(--ease-soft), border-color .2s var(--ease-soft);
  }
  .cta--primary {
    background: var(--color-terra);
    color: var(--color-bg);
    border: 1px solid var(--color-terra);
  }
  .cta--primary:hover { background: var(--color-terra-deep); border-color: var(--color-terra-deep); }
  .cta--ghost {
    background: transparent;
    color: var(--color-ink-soft);
    border: 1px solid var(--color-line);
  }
  .cta--ghost:hover {
    color: var(--color-terra);
    border-color: var(--color-terra);
  }
  .cta__icon {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-mustard-soft);
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }

  .note { padding: 0 0 clamp(3rem, 6vw, 5rem); }
  .note-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-ink-mute);
    max-width: 60ch;
    line-height: 1.5;
    font-variation-settings: "SOFT" 80;
    border-top: 1px dashed var(--color-line);
    padding-top: 1.5rem;
  }
</style>
