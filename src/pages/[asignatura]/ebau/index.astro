---
/**
 * Cuaderno de preparación EBAU/PAU de una asignatura (de momento EDMN 2BACH,
 * Comunitat Valenciana). Varias secciones (colección `ebau`) renderizadas en
 * orden como un solo documento, con descarga en PDF.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURAS } from '@/lib/asignaturas';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const all = await getCollection('ebau');
  const bySlug = new Map<string, typeof all>();
  for (const e of all) {
    if (e.data.estado !== 'publicado') continue;
    const arr = bySlug.get(e.data.asignatura) ?? [];
    arr.push(e);
    bySlug.set(e.data.asignatura, arr);
  }
  return [...bySlug.entries()].map(([slug, secciones]) => {
    secciones.sort((a, b) => a.data.orden - b.data.orden);
    return { params: { asignatura: slug }, props: { secciones, asignatura: ASIGNATURAS[slug] } };
  });
}) satisfies GetStaticPaths;

const { secciones, asignatura: a } = Astro.props;
const comunidad = secciones[0]?.data.comunidad ?? 'Comunitat Valenciana';
const rendered = await Promise.all(secciones.map(async (s) => ({ s, ...(await render(s)) })));
const pdfHref = `/downloads/${a.slug}-ebau.pdf`;
---

<BaseLayout title={`Preparación EBAU — ${a.shortLabel}`} description={`Cuaderno de preparación de la prueba de acceso (EBAU/PAU) de ${a.title} en ${comunidad}: estructura, teoría, problemas resueltos y simulacros.`}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <span>Preparación EBAU</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker kicker--sentence">{a.shortLabel} · {comunidad}</span>
      <h1>Preparación de la prueba EBAU</h1>
      <p class="lede">Estructura de la prueba, teoría esencial, problemas resueltos paso a paso y simulacros completos con solucionario y baremo.</p>
      <div class="downloads">
        <a class="download-cta" href={pdfHref} download>
          <span class="download-cta__icon" aria-hidden="true">↓</span>
          <span class="download-cta__text">
            <strong>Descargar el cuaderno EBAU en PDF</strong>
            <span class="muted">Guía + teoría + problemas resueltos + simulacros</span>
          </span>
        </a>
        <a class="download-secondary" href={`/${a.slug}/ebau/imprimir/?preview=1`} target="_blank" rel="noopener">Previsualizar versión impresa</a>
      </div>
      <p class="examenes-link">
        <a href={`/${a.slug}/ebau/examenes/`}>↗ Exámenes EBAU oficiales de otras comunidades (con resolución)</a>
      </p>
      <p class="adapt-note">
        Cuaderno orientado a la prueba de acceso de la <strong>{comunidad}</strong>, según el modelo y los criterios oficiales más recientes.
        Confirma siempre el modelo vigente de tu convocatoria: la estructura puede ajustarse cada curso.
      </p>
    </div>
  </section>

  <section class="body">
    <div class="container container--narrow">
      <article class="prose">
        {rendered.map(({ Content }) => <Content />)}
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .container { max-width: 1240px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .container--narrow { max-width: 820px; }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .hero { padding: 1rem 0 clamp(1.5rem, 4vw, 3rem); }
  h1 { max-width: 22ch; margin: 1rem 0 0.6rem; }
  .lede { font-family: var(--font-serif); font-style: italic; font-size: 1.35rem; color: var(--color-ink-soft); max-width: 52ch; margin: 1rem 0 1.5rem; line-height: 1.5; font-variation-settings: "SOFT" 80; }
  .downloads { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; }
  .download-cta { display: inline-flex; align-items: center; gap: 1rem; padding: 0.9rem 1.4rem 0.9rem 1.1rem; background: var(--color-terra); color: #fff; text-decoration: none; border-radius: 6px; transition: background .2s var(--ease-soft), transform .2s var(--ease-soft); }
  .download-cta:hover { background: var(--color-terra-deep); transform: translateY(-1px); }
  .download-cta__icon { font-family: var(--font-serif); font-style: italic; font-size: 1.7rem; line-height: 1; color: var(--color-mustard-soft); font-variation-settings: "SOFT" 100, "WONK" 1; }
  .download-cta__text { display: flex; flex-direction: column; gap: 0.15rem; }
  .download-cta__text strong { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 600; }
  .download-cta__text .muted { font-family: var(--font-sans); font-size: 0.78rem; opacity: 0.75; letter-spacing: 0.04em; }
  .download-secondary { font-family: var(--font-serif); font-style: italic; font-size: 1rem; color: var(--color-ink-soft); text-decoration: none; border-bottom: 1px dashed var(--color-line); padding-bottom: 1px; font-variation-settings: "SOFT" 80; }
  .download-secondary:hover { color: var(--color-terra); border-bottom-color: var(--color-terra); }
  .adapt-note { margin: 1.6rem 0 0; font-family: var(--font-serif); font-style: italic; font-size: 1rem; color: var(--color-ink-soft); background: var(--color-mustard-soft); border-left: 4px solid var(--color-mustard); border-radius: 0 4px 4px 0; padding: 0.9rem 1.2rem; max-width: 60ch; }
  .examenes-link { margin: 0.8rem 0 0; }
  .examenes-link a { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 600; color: var(--color-terra); text-decoration: none; }
  .examenes-link a:hover { text-decoration: underline; }
  .body { padding: clamp(1.5rem, 4vw, 3rem) 0 clamp(3rem, 7vw, 6rem); }
  .prose { font-size: 1.05rem; line-height: 1.7; color: var(--color-ink); }
  .prose :global(h2) { font-family: var(--font-serif); font-size: 1.6rem; margin: 2.2em 0 0.7em; position: relative; padding-top: 1em; font-weight: 500; }
  .prose :global(h2::before) { content: ""; position: absolute; top: 0; left: 0; width: 2.5rem; height: 4px; background: var(--color-terra); border-radius: 999px; }
  .prose :global(h2:nth-of-type(2n)::before) { background: var(--color-mustard); }
  .prose :global(h3) { font-family: var(--font-serif); font-size: 1.25rem; margin: 1.6em 0 0.5em; font-weight: 500; }
  .prose :global(p) { margin: 0 0 1em; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.4rem; margin: 0 0 1em; }
  .prose :global(li) { margin-bottom: 0.4em; }
  .prose :global(ul li::marker) { color: var(--color-mustard); }
  .prose :global(strong) { color: var(--color-ink); }
  .prose :global(table) { width: 100%; border-collapse: separate; border-spacing: 0; margin: 1.4em 0; font-size: 0.92rem; }
  .prose :global(th), .prose :global(td) { text-align: left; padding: 0.55em 0.75em; border-bottom: 1px solid var(--color-line-soft); vertical-align: top; }
  .prose :global(th) { font-family: var(--font-sans); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-terra-deep); background: var(--color-terra-soft); font-weight: 700; }
  .prose :global(blockquote) { margin: 1.4em 0; padding: 0.8em 1.2em; border-left: 3px solid var(--color-mustard); background: var(--color-bg-cream); font-style: italic; color: var(--color-ink-soft); border-radius: 0 4px 4px 0; }
</style>
