        <a href="mailto:hola@profedeeconomia.es">hola@profedeeconomia.es</a>.
      </p>
    </section>

    {/* ------------------------------------------------------------ TOC */}
    <section class="toc">
      <div class="toc__kicker">Índice general · {totalUnits} unidades</div>
      <h2>Contenido</h2>
      <ol class="toc__list">
        {rendered.map(({ unit }) => (
          <li class="toc__item">
            <span class="toc__num">{String(unit.data.unidad).padStart(2, '0')}</span>
            <div class="toc__title-block">
              <a class="toc__title" href={`#cap-${unit.data.unidad}`}>{unit.data.title}</a>
              {unit.data.lema && <span class="toc__lede">{unit.data.lema}</span>}
            </div>
            <a class="toc__page" href={`#cap-${unit.data.unidad}`} aria-label="Página"></a>
          </li>
        ))}
      </ol>
    </section>

    {/* ------------------------------------------------------------ CHAPTERS */}
    {rendered.map(({ unit, Content }) => (
      <section class="chapter" id={`cap-${unit.data.unidad}`}>
        <div class="chapter__opener">
          <div>
            <div class="chapter__kicker">
              Unidad {unit.data.unidad}
              {unit.data.bloque ? ` · ${unit.data.bloque}` : ''}
            </div>
            <div class="chapter__num">{String(unit.data.unidad).padStart(2, '0')}</div>
            <h2 class="chapter__title">{unit.data.title}</h2>
            {unit.data.lema && <p class="chapter__lede">{unit.data.lema}</p>}

            <dl class="chapter__meta">
              {unit.data.duracion && (
                <div>
                  <dt>Duración</dt>
                  <dd>{unit.data.duracion}</dd>
                </div>
              )}
              {unit.data.conceptos_clave.length > 0 && (
                <div>
                  <dt>Conceptos clave</dt>
                  <dd>{unit.data.conceptos_clave.slice(0, 6).join(' · ')}</dd>
                </div>
              )}
              {unit.data.objetivos.length > 0 && (
                <div style="grid-column: 1 / -1;">
                  <dt>Objetivos de la unidad</dt>
                  <dd>
                    <ul>
                      {unit.data.objetivos.map((o) => <li>· {o}</li>)}
                    </ul>
                  </dd>
                </div>
              )}
            </dl>
          </div>
        </div>

        <div class="chapter__content" data-unit-title={`Unidad ${unit.data.unidad} · ${unit.data.title}`}>
          <Content />
        </div>
      </section>
    ))}

    {/*
      paged.js polyfill — only loaded for in-browser preview. pagedjs-cli
      injects its own polyfill, and stacking both causes a runtime conflict
      ("ProgressEvent" thrown from the second initialization). To preview
      paginated layout in a regular browser, append ?preview=1 to the URL.
    */}
    <script is:inline>
      if (new URLSearchParams(location.search).has('preview')) {
        const s = document.createElement('script');
        s.src = 'https://unpkg.com/pagedjs/dist/paged.polyfill.js';
        document.body.appendChild(s);
      }
    </script>
  </body>
