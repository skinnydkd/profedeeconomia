---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURA_SLUGS, ASIGNATURAS } from '@/lib/asignaturas';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  return ASIGNATURA_SLUGS.map((slug) => ({
    params: { asignatura: slug },
    props: { asignatura: ASIGNATURAS[slug] },
  }));
}) satisfies GetStaticPaths;

const { asignatura: a } = Astro.props;

const allUnits = await getCollection('libro');
const units = allUnits
  .filter((u) => u.data.asignatura === a.slug && u.data.estado === 'publicado')
  .sort((x, y) => x.data.unidad - y.data.unidad);

// The PDF is published to /downloads/<slug>-libro.pdf when the
// `npm run build:pdf` step has been run. We always render the CTA;
// if the file is not yet committed it will 404, which is acceptable
// during early publishing.
const pdfHref = `/downloads/${a.slug}-libro.pdf`;
---

<BaseLayout
  title={`Libro — ${a.shortLabel}`}
  description={`Las unidades del libro de ${a.title}.`}
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <span>Libro</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">{a.shortLabel} · libro</span>
      <h1>{a.title}</h1>
      <p class="subtitle">
        {units.length === 0
          ? 'Las unidades publicadas aparecerán aquí a medida que se vayan completando.'
          : `${units.length} ${units.length === 1 ? 'unidad publicada' : 'unidades publicadas'}.`}
      </p>

      {units.length > 0 && (
        <div class="downloads">
          <a class="download-cta" href={pdfHref} download>
            <span class="download-cta__icon" aria-hidden="true">↓</span>
            <span class="download-cta__text">
              <strong>Descargar libro completo</strong>
              <span class="muted">PDF · {units.length} unidades · todas las páginas</span>
            </span>
          </a>
          <a class="download-secondary" href={`/${a.slug}/libro/imprimir/?preview=1`} target="_blank" rel="noopener">
            Previsualizar versión impresa en navegador
          </a>
        </div>
      )}
    </div>
  </section>

  {units.length > 0 && (
    <section class="units">
      <div class="container">
        <ol class="unit-list">
          {units.map((u) => (
            <li>
              <span class="num">{String(u.data.unidad).padStart(2, '0')}</span>
              <a class="title" href={`/${a.slug}/libro/${u.id.split('/').pop()?.replace(/\.mdx?$/, '')}/`}>
                {u.data.title}
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hero { padding: 1rem 0 clamp(2rem, 5vw, 4rem); }
  h1 { margin: 1rem 0 0.6rem; }
  .subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-ink-soft);
    max-width: 55ch;
    line-height: 1.5;
    font-variation-settings: "SOFT" 80;
  }

  .units { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .unit-list { margin: 0; padding: 0; list-style: none; }
  .unit-list li {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px dashed var(--color-line);
    align-items: baseline;
  }
  .unit-list .num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-mustard-deep);
    min-width: 2.5rem;
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }
  .unit-list a.title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-ink);
    text-decoration: none;
  }
  .unit-list a.title:hover { color: var(--color-terra); }

  .downloads {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.2rem;
  }
  .download-cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.4rem 0.9rem 1.1rem;
    background: var(--color-terra);
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    transition: background .2s var(--ease-soft), transform .2s var(--ease-soft);
  }
  .download-cta:hover {
    background: var(--color-terra-deep);
    transform: translateY(-1px);
  }
  .download-cta__icon {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.7rem;
    line-height: 1;
    color: var(--color-mustard-soft);
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }
  .download-cta__text { display: flex; flex-direction: column; gap: 0.15rem; }
  .download-cta__text strong {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .download-cta__text .muted {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    opacity: 0.75;
    letter-spacing: 0.04em;
  }
  .download-secondary {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-ink-soft);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-line);
    padding-bottom: 1px;
    font-variation-settings: "SOFT" 80;
  }
  .download-secondary:hover { color: var(--color-terra); border-bottom-color: var(--color-terra); }
</style>
