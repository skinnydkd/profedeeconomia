---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURAS } from '@/lib/asignaturas';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const allUnits = await getCollection('libro');
  return allUnits
    .filter((u) => u.data.estado === 'publicado')
    .map((u) => {
      const slug = u.id.split('/').pop()?.replace(/\.mdx?$/, '') ?? u.id;
      return {
        params: { asignatura: u.data.asignatura, unidad: slug },
        props: { unit: u },
      };
    });
}) satisfies GetStaticPaths;

const { unit } = Astro.props;
const a = ASIGNATURAS[unit.data.asignatura];
const { Content, headings } = await render(unit);

// Adjacent units within the same asignatura
const all = (await getCollection('libro'))
  .filter((u) => u.data.asignatura === unit.data.asignatura && u.data.estado === 'publicado')
  .sort((x, y) => x.data.unidad - y.data.unidad);

const idx = all.findIndex((u) => u.id === unit.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
const idToSlug = (id: string) => id.split('/').pop()?.replace(/\.mdx?$/, '') ?? id;
---

<BaseLayout
  title={`Unidad ${unit.data.unidad}. ${unit.data.title} — ${a.shortLabel}`}
  description={unit.data.lema ?? unit.data.title}
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <a href={`/${a.slug}/libro/`}>Libro</a> <span class="sep">›</span>
      <span>Unidad {unit.data.unidad}</span>
    </nav>
  </div>

  <section class="unit-opener">
    <div class="container">
      <div class="unit-num">
        Unidad {unit.data.unidad}
        {unit.data.bloque ? ` · ${unit.data.bloque}` : ''}
        {unit.data.sabers.length > 0 ? ` · Sabers ${unit.data.sabers.join(', ')}` : ''}
      </div>
      <h1>{unit.data.title}</h1>
      {unit.data.lema && <p class="lede">{unit.data.lema}</p>}

      <dl class="unit-meta">
        {unit.data.duracion && (
          <div>
            <dt>Duración estimada</dt>
            <dd>{unit.data.duracion}</dd>
          </div>
        )}
        {unit.data.conceptos_clave.length > 0 && (
          <div>
            <dt>Conceptos clave</dt>
            <dd>
              <div class="tag-row">
                {unit.data.conceptos_clave.map((c) => <span class="tag">{c}</span>)}
              </div>
            </dd>
          </div>
        )}
        {unit.data.objetivos.length > 0 && (
          <div style="grid-column: 1 / -1;">
            <dt>Objetivos</dt>
            <dd>
              <ul class="objetivos">
                {unit.data.objetivos.map((o) => <li>{o}</li>)}
              </ul>
            </dd>
          </div>
        )}
      </dl>
    </div>
  </section>

  <div class="container">
    <div class="article-layout">
      {headings.length > 0 && (
        <aside class="article-toc" aria-label="Índice de la unidad">
          <h4>En esta unidad</h4>
          <ol>
            {headings.filter((h) => h.depth <= 3).map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
        </aside>
      )}

      <article class="article-body">
        <Content />

        <nav class="unit-nav">
          {prev ? (
            <a class="prev" href={`/${a.slug}/libro/${idToSlug(prev.id)}/`}>
              <span class="label">← Unidad {prev.data.unidad}</span>
              <span class="title">{prev.data.title}</span>
            </a>
          ) : (
            <a class="prev" href={`/${a.slug}/libro/`}>
              <span class="label">← Volver al índice</span>
              <span class="title">{a.shortLabel} · Libro</span>
            </a>
          )}
          {next ? (
            <a class="next" href={`/${a.slug}/libro/${idToSlug(next.id)}/`}>
              <span class="label">Unidad {next.data.unidad} →</span>
              <span class="title">{next.data.title}</span>
            </a>
          ) : (
            <span></span>
          )}
        </nav>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }

  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .unit-opener {
    padding: 1rem 0 4rem;
    background:
      radial-gradient(ellipse 50% 80% at 100% 0%, var(--color-terra-soft) 0%, transparent 65%),
      var(--color-bg);
  }
  .unit-num {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-terra);
    margin-bottom: 1.5rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    background: var(--color-terra-soft);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
  }
  h1 { max-width: 20ch; margin: 0 0 0.6rem; }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1.45;
    color: var(--color-ink-soft);
    max-width: 50ch;
    margin: 0 0 2.8rem;
    font-variation-settings: "SOFT" 80;
  }

  .unit-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem 2.5rem;
    padding: 1.8rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(42, 31, 24, 0.05), 0 4px 14px rgba(42, 31, 24, 0.06);
    margin: 0;
  }
  .unit-meta dt {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-mute);
    margin-bottom: 0.4rem;
    font-weight: 600;
  }
  .unit-meta dd { margin: 0; font-size: 1rem; color: var(--color-ink); }
  .tag-row { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    padding: 0.3rem 0.7rem;
    background: var(--color-terra-soft);
    color: var(--color-terra-deep);
    border-radius: 999px;
    font-weight: 500;
  }
  .objetivos { margin: 0.4rem 0 0; padding-left: 1.1rem; font-size: 1rem; color: var(--color-ink-soft); }
  .objetivos li { margin-bottom: 0.4rem; }

  /* ARTICLE LAYOUT */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 4rem 0;
  }
  @media (min-width: 1100px) {
    .article-layout {
      grid-template-columns: 220px minmax(0, var(--measure-prose)) 1fr;
      gap: 4rem;
    }
    .article-toc { order: -1; }
  }

  .article-toc {
    position: sticky;
    top: 5rem;
    align-self: start;
    font-size: 0.92rem;
    padding-left: 1.2rem;
    border-left: 3px solid var(--color-terra);
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }
  .article-toc h4 { margin: 0 0 0.8rem; font-size: 0.78rem; color: var(--color-ink-mute); letter-spacing: 0.12em; }
  .article-toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: toc;
  }
  .article-toc li {
    margin-bottom: 0.5rem;
    line-height: 1.4;
    counter-increment: toc;
    position: relative;
    padding-left: 1.6rem;
  }
  .article-toc li::before {
    content: counter(toc, decimal-leading-zero);
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-mustard-deep);
    letter-spacing: 0.04em;
    top: 0.2em;
  }
  .article-toc a { color: var(--color-ink-soft); text-decoration: none; }
  .article-toc a:hover { color: var(--color-terra); }

  .article-body {
    max-width: var(--measure-prose);
    font-size: 1.2rem;
    line-height: 1.72;
  }
  .article-body :global(h2) {
    margin-top: 3em;
    font-size: 2rem;
    position: relative;
    padding-top: 1.2em;
    letter-spacing: -0.02em;
  }
  .article-body :global(h2::before) {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 4rem; height: 4px;
    background: var(--color-terra);
    border-radius: 999px;
  }
  .article-body :global(h2:nth-of-type(2n)::before) { background: var(--color-mustard); }
  .article-body :global(h2:nth-of-type(3n)::before) { background: var(--color-eco1); }

  .article-body :global(p:first-of-type::first-letter) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 4.6em;
    line-height: 0.85;
    float: left;
    padding: 0.05em 0.12em 0 0;
    color: var(--color-terra);
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }

  .article-body :global(ul li::marker) { color: var(--color-mustard); }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.4rem;
    margin: 0 0 1.4em;
  }
  .article-body :global(li) { margin-bottom: 0.5em; }
  .article-body :global(strong) { color: var(--color-ink); }
  .article-body :global(em) { color: var(--color-ink); font-style: italic; }

  /* Tables inside MDX */
  .article-body :global(table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 2.2rem 0;
    font-size: 0.98rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    overflow: hidden;
  }
  .article-body :global(table th),
  .article-body :global(table td) {
    text-align: left;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--color-line-soft);
    vertical-align: top;
  }
  .article-body :global(table tr:last-child td) { border-bottom: none; }
  .article-body :global(table th) {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-terra-deep);
    background: var(--color-terra-soft);
    font-weight: 700;
  }

  /* Prev/next */
  .unit-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }
  .unit-nav a {
    padding: 1.7rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    color: var(--color-ink);
    text-decoration: none;
    transition: transform .2s var(--ease-soft), border-color .2s var(--ease-soft), background .2s var(--ease-soft);
  }
  .unit-nav a:hover {
    transform: translateY(-2px);
    border-color: var(--color-terra);
    background: var(--color-terra-soft);
  }
  .unit-nav .next { text-align: right; }
  .unit-nav .label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-terra);
    font-weight: 700;
  }
  .unit-nav .title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.3;
  }
</style>
