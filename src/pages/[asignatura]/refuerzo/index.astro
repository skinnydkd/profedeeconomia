---
/**
 * «Cuadernos de refuerzo y ampliación» — atención a la diversidad por asignatura.
 * Entries (collection `refuerzo`) are grouped by evaluación; within each, the
 * refuerzo blocks come first and the ampliación blocks after. Exercises show
 * their solution folded so the student self-corrects.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURA_SLUGS, ASIGNATURAS } from '@/lib/asignaturas';
import BloqueRefuerzo from '@components/refuerzo/BloqueRefuerzo.astro';
import { refuerzoPdfName } from '@/lib/refuerzo';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  return ASIGNATURA_SLUGS.map((slug) => ({
    params: { asignatura: slug },
    props: { asignatura: ASIGNATURAS[slug] },
  }));
}) satisfies GetStaticPaths;

const { asignatura: a } = Astro.props;

const all = await getCollection('refuerzo');
const items = all.filter((x) => x.data.asignatura === a.slug && x.data.estado === 'publicado');

const ORD_TIPO: Record<string, number> = { refuerzo: 0, ampliacion: 1 };
const grupos = [1, 2, 3]
  .map((ev) => ({
    evaluacion: ev,
    bloques: items
      .filter((x) => x.data.evaluacion === ev)
      .sort((x, y) => (ORD_TIPO[x.data.tipo] - ORD_TIPO[y.data.tipo]) || (x.data.orden - y.data.orden)),
  }))
  .filter((g) => g.bloques.length > 0);

const ORDINAL: Record<number, string> = { 1: '1.ª', 2: '2.ª', 3: '3.ª' };
---

<BaseLayout
  title={`Refuerzo y ampliación — ${a.shortLabel}`}
  description={`Cuadernos de refuerzo (para quien va justo) y de ampliación (para quien quiere más) de ${a.title}, organizados por evaluación, con ejercicios y solución.`}
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <span>Refuerzo y ampliación</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">{a.shortLabel} · Atención a la diversidad</span>
      <h1>Refuerzo y ampliación</h1>
      <p class="lede">
        {grupos.length === 0
          ? 'Los cuadernos de refuerzo y ampliación se publicarán por evaluación a medida que se completen.'
          : 'Por evaluación: un repaso de lo esencial con ejercicios muy guiados para quien va justo (refuerzo), y retos de más profundidad para quien quiere ir más allá (ampliación). Las soluciones van plegadas para que primero lo intentes.'}
      </p>
    </div>
  </section>

  {grupos.map((g) => (
    <section class="eval">
      <div class="container">
        <h2 class="eval__title">{ORDINAL[g.evaluacion]} evaluación</h2>
        <div class="bloques">
          {g.bloques.map((b) => (
            <article class={`bloque bloque--${b.data.tipo} c-${a.color}`}>
              <header class="bloque__head">
                <span class="bloque__tag">{b.data.tipo === 'refuerzo' ? 'Refuerzo' : 'Ampliación'}</span>
                <h3 class="bloque__title">{b.data.title}</h3>
                {b.data.descripcion && <p class="bloque__desc">{b.data.descripcion}</p>}
              </header>

              {b.data.repaso_teorico.length > 0 && (
                <p class="bloque__download">
                  <a href={`/downloads/${refuerzoPdfName(a.slug, b.data.evaluacion, b.data.tipo)}`} download>
                    ↓ Descargar este cuaderno (PDF)
                  </a>
                </p>
              )}

              <BloqueRefuerzo
                esencial={b.data.esencial}
                conceptos={b.data.conceptos_clave}
                repaso={b.data.repaso_teorico}
                ejemplos={b.data.ejemplos_resueltos}
                ejercicios={b.data.ejercicios}
                tipo={b.data.tipo}
                mode="web"
              />
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <div class="container back-link">
    <a href={`/${a.slug}/`}>← {a.title}</a>
  </div>
</BaseLayout>

<style>
  .container { max-width: 1240px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hero { padding: 1rem 0 2rem; }
  .kicker { font-family: var(--font-sans); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em; text-transform: none; color: var(--color-terra-deep); }
  h1 { margin: 0.6rem 0 0.8rem; }
  .lede { font-size: 1.18rem; color: var(--color-ink-soft); line-height: 1.6; max-width: 64ch; }

  .eval { padding: 1.2rem 0; }
  .eval__title {
    font-family: var(--font-serif); font-size: 1.6rem; font-weight: 500;
    margin: 0 0 1.1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-line);
  }
  .bloques { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.4rem; }

  .bloque {
    background: var(--color-paper); border: 1px solid var(--color-line);
    border-top: 4px solid var(--card-color, var(--color-terra)); border-radius: 10px;
    padding: 1.5rem 1.6rem;
  }
  .bloque--ampliacion { border-top-color: var(--color-mustard); }
  .bloque.c-edmn { --card-color: var(--color-edmn); }
  .bloque.c-eco1 { --card-color: var(--color-eco1); }
  .bloque.c-eco4 { --card-color: var(--color-eco4); }
  .bloque.c-fopp { --card-color: var(--color-fopp); }
  .bloque.c-taller3 { --card-color: var(--color-taller3); }
  .bloque.c-ipe1 { --card-color: var(--color-ipe1); }
  .bloque.c-ipe2 { --card-color: var(--color-ipe2); }
  .bloque.c-eeae { --card-color: var(--color-eeae); }
  .bloque.c-gpe { --card-color: var(--color-gpe); }
  .bloque--ampliacion.bloque { --card-color: var(--color-mustard); }

  .bloque__tag {
    font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--card-color);
  }
  .bloque__title { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 500; margin: 0.3rem 0 0.3rem; }
  .bloque__desc { color: var(--color-ink-soft); font-size: 0.95rem; line-height: 1.5; margin: 0; }

  .bloque__download { margin: 0.8rem 0 0; }
  .bloque__download a {
    font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600;
    color: var(--color-terra); text-decoration: none;
  }
  .bloque__download a:hover { text-decoration: underline; }

  .back-link { padding: 2rem 0 3rem; }
  .back-link a { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 500; color: var(--color-terra); text-decoration: none; }
  .back-link a:hover { text-decoration: underline; }
</style>
