---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURAS } from '@/lib/asignaturas';
import { getCollection } from 'astro:content';
import QuizPlayer from '@components/QuizPlayer.tsx';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const all = await getCollection('tests');
  return all
    .filter((t) => t.data.estado === 'publicado')
    .map((t) => {
      const slug = t.id.split('/').pop()?.replace(/\.mdx?$/, '') ?? t.id;
      return {
        params: { asignatura: t.data.asignatura, slug },
        props: { test: t },
      };
    });
}) satisfies GetStaticPaths;

const { test } = Astro.props;
const a = ASIGNATURAS[test.data.asignatura];

// Find the related libro unit so we can link back and show its lema.
const allLibro = await getCollection('libro');
const unit = allLibro.find(
  (u) => u.data.asignatura === a.slug && u.data.unidad === test.data.unidad_relacionada
);
const unitSlug = unit?.id.split('/').pop()?.replace(/\.mdx?$/, '');
---

<BaseLayout title={`${test.data.title} — ${a.shortLabel}`} description={`Test de autoevaluación de la unidad ${test.data.unidad_relacionada} de ${a.title}.`}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <a href={`/${a.slug}/tests/`}>Tests</a> <span class="sep">›</span>
      <span>Unidad {test.data.unidad_relacionada}</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">Test · Unidad {test.data.unidad_relacionada}</span>
      <h1>{test.data.title}</h1>
      {unit?.data.lema && <p class="lede">{unit.data.lema}</p>}
      <p class="meta">
        {test.data.preguntas.length} preguntas
        {test.data.duracion_estimada && <> · {test.data.duracion_estimada}</>}
        {unit && unitSlug && (
          <> ·
            <a class="link" href={`/${a.slug}/libro/${unitSlug}/`}>Volver a la unidad del libro</a>
          </>
        )}
      </p>
    </div>
  </section>

  <section class="player-wrap">
    <div class="container container--narrow">
      <QuizPlayer
        client:load
        preguntas={test.data.preguntas}
        storageKey={`test-${a.slug}-${test.data.unidad_relacionada}`}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .container--narrow { max-width: 760px; }

  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hero { padding: 1rem 0 clamp(1.5rem, 4vw, 3rem); }
  h1 { max-width: 22ch; margin: 1rem 0 0.6rem; }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--color-ink-soft);
    max-width: 50ch;
    margin: 1rem 0 1.5rem;
    line-height: 1.5;
    font-variation-settings: "SOFT" 80;
  }
  .meta {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-mute);
  }
  .meta .link { color: var(--color-terra); text-decoration: none; }
  .meta .link:hover { color: var(--color-terra-deep); border-bottom: 1px solid var(--color-terra); }

  .player-wrap { padding-bottom: clamp(3rem, 7vw, 6rem); }
</style>

{/* QuizPlayer styles now ship with the component (src/components/QuizPlayer.css). */}
