---
/**
 * «Evaluación competencial» per asignatura. Renders the subject's official
 * competencias específicas with their criterios de evaluación and a level-of-
 * achievement rubric each, plus the recommended instruments. Complements the
 * Programación (planning) with the operational evaluation toolkit.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURA_SLUGS, ASIGNATURAS } from '@/lib/asignaturas';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  return ASIGNATURA_SLUGS.map((slug) => ({
    params: { asignatura: slug },
    props: { asignatura: ASIGNATURAS[slug] },
  }));
}) satisfies GetStaticPaths;

const { asignatura: a } = Astro.props;

const all = await getCollection('evaluacion');
const entry = all.find((x) => x.data.asignatura === a.slug && x.data.estado === 'publicado');
const d = entry?.data;
---

<BaseLayout
  title={`Evaluación competencial — ${a.shortLabel}`}
  description={`Competencias específicas, criterios de evaluación y rúbricas de niveles de logro de ${a.title}, listas para evaluar por competencias.`}
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href={`/${a.slug}/`}>{a.shortLabel}</a> <span class="sep">›</span>
      <span>Evaluación competencial</span>
    </nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">{a.shortLabel} · para el profesorado</span>
      <h1>Evaluación competencial</h1>
      <p class="lede">
        {d
          ? d.descripcion
          : 'La evaluación por competencias de esta asignatura se publicará próximamente.'}
      </p>
      {d && (
        <div class="marco">
          Competencias específicas del currículo básico estatal LOMLOE ({d.marco}). Cada
          comunidad autónoma las concreta: ajusta la redacción y los criterios a tu CCAA y a
          tu Proyecto Educativo de Centro.
        </div>
      )}
    </div>
  </section>

  {d && (
    <section class="cuerpo">
      <div class="container">
        {d.competencias.map((c, i) => (
          <article class={`ce c-${a.color}`}>
            <header class="ce__head">
              <span class="ce__code">{c.codigo}</span>
              <p class="ce__desc">{c.descripcion}</p>
            </header>

            {c.criterios.length > 0 && (
              <div class="ce__sec">
                <h3 class="ce__sub">Criterios de evaluación</h3>
                <ul class="ce__crit">
                  {c.criterios.map((cr) => <li>{cr}</li>)}
                </ul>
              </div>
            )}

            {c.niveles.length > 0 && (
              <div class="ce__sec">
                <h3 class="ce__sub">Niveles de logro</h3>
                <div class="rubrica">
                  {c.niveles.map((n) => (
                    <div class="rubrica__col">
                      <span class="rubrica__nivel">{n.nivel}</span>
                      <p class="rubrica__desc">{n.descriptor}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </article>
        ))}

        {d.instrumentos.length > 0 && (
          <article class="instrumentos">
            <h2 class="instrumentos__h">Instrumentos de evaluación</h2>
            <ul class="instrumentos__list">
              {d.instrumentos.map((it) => <li>{it}</li>)}
            </ul>
          </article>
        )}
      </div>
    </section>
  )}

  <div class="container back-link">
    <a href={`/${a.slug}/`}>← {a.title}</a>
  </div>
</BaseLayout>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hero { padding: 1rem 0 1.5rem; }
  .kicker { font-family: var(--font-sans); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-terra); }
  h1 { margin: 0.6rem 0 0.8rem; }
  .lede { font-size: 1.18rem; color: var(--color-ink-soft); line-height: 1.6; max-width: 64ch; }
  .marco {
    margin-top: 1.4rem; max-width: 70ch; font-family: var(--font-serif); font-style: italic;
    font-size: 0.98rem; color: var(--color-ink-soft); line-height: 1.5;
    background: var(--color-mustard-soft); border-left: 4px solid var(--color-mustard);
    border-radius: 0 6px 6px 0; padding: 0.9rem 1.1rem;
  }

  .cuerpo { padding: 1rem 0 1.5rem; }
  .ce {
    background: var(--color-paper); border: 1px solid var(--color-line);
    border-left: 4px solid var(--card-color, var(--color-terra)); border-radius: 8px;
    padding: 1.4rem 1.6rem; margin-bottom: 1.4rem;
  }
  .ce.c-edmn { --card-color: var(--color-edmn); }
  .ce.c-eco1 { --card-color: var(--color-eco1); }
  .ce.c-eco4 { --card-color: var(--color-eco4); }
  .ce.c-fopp { --card-color: var(--color-fopp); }
  .ce.c-taller3 { --card-color: var(--color-taller3); }
  .ce.c-ipe1 { --card-color: var(--color-ipe1); }
  .ce.c-ipe2 { --card-color: var(--color-ipe2); }
  .ce.c-eeae { --card-color: var(--color-eeae); }
  .ce.c-gpe { --card-color: var(--color-gpe); }

  .ce__head { display: flex; gap: 0.9rem; align-items: baseline; }
  .ce__code {
    font-family: var(--font-mono); font-weight: 600; font-size: 0.95rem;
    color: var(--card-color); flex: none; padding-top: 0.1rem;
  }
  .ce__desc { margin: 0; font-family: var(--font-serif); font-size: 1.12rem; line-height: 1.45; color: var(--color-ink); }

  .ce__sec { margin-top: 1.1rem; }
  .ce__sub {
    font-family: var(--font-sans); font-size: 0.74rem; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--color-ink-mute); font-weight: 700; margin: 0 0 0.5rem;
  }
  .ce__crit { margin: 0; padding-left: 1.1rem; }
  .ce__crit li { margin-bottom: 0.35rem; line-height: 1.5; color: var(--color-ink-soft); }
  .ce__crit li::marker { color: var(--card-color); }

  .rubrica { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.7rem; }
  .rubrica__col { background: var(--color-bg); border: 1px solid var(--color-line); border-radius: 6px; padding: 0.7rem 0.9rem; }
  .rubrica__nivel { font-family: var(--font-sans); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 700; color: var(--card-color); }
  .rubrica__desc { margin: 0.3rem 0 0; font-size: 0.9rem; line-height: 1.5; color: var(--color-ink-soft); }

  .instrumentos { border-top: 1px dashed var(--color-line); padding-top: 1.4rem; margin-top: 0.5rem; }
  .instrumentos__h { font-size: 1.3rem; margin: 0 0 0.7rem; }
  .instrumentos__list { margin: 0; padding-left: 1.2rem; }
  .instrumentos__list li { margin-bottom: 0.4rem; line-height: 1.5; color: var(--color-ink-soft); }
  .instrumentos__list li::marker { color: var(--color-mustard); }

  .back-link { padding: 1.5rem 0 3rem; }
  .back-link a { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 500; color: var(--color-terra); text-decoration: none; }
  .back-link a:hover { text-decoration: underline; }
</style>
