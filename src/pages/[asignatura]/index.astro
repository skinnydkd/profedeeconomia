---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ASIGNATURA_SLUGS, ASIGNATURAS } from '@/lib/asignaturas';
import { breadcrumbLd } from '@/lib/seo';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (() => {
  return ASIGNATURA_SLUGS.map((slug) => ({
    params: { asignatura: slug },
    props: { asignatura: ASIGNATURAS[slug] },
  }));
}) satisfies GetStaticPaths;

const { asignatura: a } = Astro.props;
const isPublicado = a.estado === 'publicado';

// Show the EBAU card only for subjects that have published EBAU content.
const ebauAll = await getCollection('ebau');
const hasEbau = ebauAll.some((e) => e.data.asignatura === a.slug && e.data.estado === 'publicado');

// Show the project-workbook card only for subjects that have published content.
const proyectoAll = await getCollection('proyecto');
const hasProyecto = proyectoAll.some((e) => e.data.asignatura === a.slug && e.data.estado === 'publicado');

// Show the refuerzo/ampliación card only for subjects that have published content.
const refuerzoAll = await getCollection('refuerzo');
const hasRefuerzo = refuerzoAll.some((e) => e.data.asignatura === a.slug && e.data.estado === 'publicado');

// Show the evaluación competencial card only for subjects that have published content.
const evaluacionAll = await getCollection('evaluacion');
const hasEvaluacion = evaluacionAll.some((e) => e.data.asignatura === a.slug && e.data.estado === 'publicado');

const testsAll = await getCollection('tests');
const hasTests = testsAll.some((t) => t.data.asignatura === a.slug && t.data.estado === 'publicado');
const recursosAll = await getCollection('recursos');
const hasRecursos = recursosAll.some((rec) => rec.data.asignatura === a.slug && rec.data.estado === 'publicado');
const retosAll = await getCollection('retos');
const hasRetos = retosAll.some((r) => r.data.asignatura === a.slug && r.data.estado === 'publicado');

// Sections grouped by nature: the course material (book + printable), the
// interactive practice, and what's for the teacher. Programación goes last.
const material = [
  { slug: 'libro',        title: 'Libro',        desc: 'Los capítulos del curso, listos para leer en pantalla o descargar como PDF.' },
  { slug: 'diapositivas', title: 'Diapositivas', desc: 'Diapositivas derivadas automáticamente del libro. PDF al MVP, PPTX editable más adelante.' },
  { slug: 'actividades',  title: 'Actividades',  desc: 'Casos prácticos y ejercicios graduados por unidad, listos para imprimir.' },
  ...(hasRefuerzo ? [{ slug: 'refuerzo', title: 'Refuerzo y ampliación', desc: 'Por evaluación: repaso esencial con ejercicios guiados (refuerzo) y retos de más nivel (ampliación).' }] : []),
  ...(hasProyecto ? [{ slug: 'proyecto', title: 'Cuaderno de proyecto', desc: 'Guía paso a paso para que el alumnado desarrolle su propio proyecto emprendedor, fase a fase.' }] : []),
];
const interactivo = [
  ...(hasTests ? [{ slug: 'tests', title: 'Tests', desc: 'Tests autocorregibles por unidad: respuesta inmediata, nota y repaso en el navegador.' }] : []),
  ...(hasRecursos ? [{ slug: 'recursos', title: 'Simuladores', desc: 'Calculadoras y simuladores interactivos (punto muerto, VAN, equilibrio de mercado…) para experimentar con los modelos.' }] : []),
  ...(hasRetos ? [{ slug: 'retos', title: 'Retos competenciales', desc: 'Escenarios paso a paso centrados en una competencia específica; al final, tu nivel de logro.' }] : []),
  { slug: 'actividades-dinamicas', title: 'Árboles de decisión', desc: 'Casos con decisiones encadenadas: cada elección mueve unos indicadores y abre la siguiente.' },
  ...(hasEbau ? [{ slug: 'ebau', title: 'Preparación EBAU', desc: 'Estructura de la prueba, teoría esencial, problemas resueltos y simulacros con solucionario.' }] : []),
];
const profe = [
  ...(hasEvaluacion ? [{ slug: 'evaluacion', title: 'Evaluación competencial', desc: 'Competencias específicas con sus criterios de evaluación y una rúbrica de niveles de logro por competencia.' }] : []),
  { slug: 'programacion', title: 'Programación', desc: 'Programación didáctica de referencia: objetivos, temporalización y evaluación competencial, lista para adaptar.' },
];
const grupos = [
  { label: 'El material del curso', desc: 'Lo que llevas a clase: libro, diapositivas y actividades para imprimir.', sections: material },
  { label: 'Práctica interactiva',  desc: 'Para trabajar en pantalla: se autocorrige, se autoguarda y engancha al alumnado.', sections: interactivo },
  { label: 'Para el profesorado',   desc: 'La planificación del curso, lista para adaptar a tu centro.', sections: profe },
];

const breadcrumb = breadcrumbLd([
  { name: 'Inicio', path: '/' },
  { name: a.shortLabel, path: `/${a.slug}/` },
]);
---

<BaseLayout
  title={`${a.title} — ${a.level}`}
  description={`Material para impartir ${a.title} en ${a.level}: libro, diapositivas, actividades, tests y recursos. Currículo estatal LOMLOE (${a.marcoNormativo}).`}
  jsonLd={breadcrumb}
>

  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span class="sep">›</span>
      <span>{a.shortLabel}</span>
    </nav>
  </div>

  <section class="hub-hero">
    <div class="container">
      <span class="kicker">
        Asignatura · {a.level}{a.modalidad ? ` · ${a.modalidad}` : ''}
      </span>
      <h1 class={`title c-${a.color}`}>{a.title}</h1>

      {isPublicado ? (
        <>
          <p class="subtitle">{a.tagline}</p>
        </>
      ) : (
        <>
          <p class="subtitle proximamente-tag">Próximamente</p>
          <p class="desc">
            {a.tagline}
          </p>
          <p class="desc">
            Este material está en preparación. Cuando se publique tendrá la misma estructura
            que el resto: libro, diapositivas, actividades, tests y recursos.
          </p>
        </>
      )}

      <div class="curriculum-note">
        {isPublicado
          ? <>Este libro se basa en el currículo básico estatal LOMLOE para {a.title.toLowerCase()}, establecido en el {a.marcoNormativo}. Cada comunidad autónoma establece concreciones específicas: conviene consultar la de tu comunidad para ajustar la programación a tu centro.</>
          : <>El material se basará en el {a.marcoNormativo}. Si quieres estar al tanto de cuándo se publica, sigue <a class="editorial-link" href="https://instagram.com/profedeeconomia" rel="external">@profedeeconomia</a>.</>
        }
      </div>
    </div>
  </section>

  {isPublicado && (
    <section class="hub-sections">
      <div class="container">
        <h2>Todo el material, un solo curso</h2>
        <p class="hub-intro">
          Cada asignatura reúne aquí todo su material con la misma estructura.
          Lo que cambia es el contenido, no el sitio donde encontrarlo.
        </p>

        {grupos.map((g) => (
          <div class="section-group">
            <div class="section-group__head">
              <h3 class="section-group__title">{g.label}</h3>
              <p class="section-group__desc">{g.desc}</p>
            </div>
            <nav class="subject-sections" aria-label={g.label}>
              {g.sections.map((s) => (
                <a href={`/${a.slug}/${s.slug}/`} class={`section-card c-${a.color}`}>
                  <h4>{s.title}</h4>
                  <p class="desc">{s.desc}</p>
                </a>
              ))}
            </nav>
          </div>
        ))}

        {(a.slug === 'edmn-2bach' || a.slug === 'eco-1bach') && (
          <a href="/olimpiada/" class="olimpiada-card">
            <span class="ol-kicker">Competición</span>
            <h3>Olimpiada de Economía</h3>
            <p class="desc">Prepara la Olimpiada: la guía del examen, simulacros oficiales, fichas-resumen, banco de preguntas y taller de comentario de texto.</p>
            <span class="ol-cta">Preparar la Olimpiada →</span>
          </a>
        )}
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }

  .breadcrumb {
    font-size: 0.92rem;
    color: var(--color-ink-mute);
    margin: 2rem 0;
  }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hub-hero { padding: 1rem 0 3.5rem; }
  .hub-hero h1 { max-width: 22ch; margin: 0 0 0.6rem; }

  /* Per-asignatura color of the title accent — used as a soft highlight */
  .title.c-edmn { color: var(--color-ink); }
  .title.c-eco1 { color: var(--color-ink); }
  .title.c-eco4 { color: var(--color-ink); }
  .title.c-fopp { color: var(--color-ink); }

  .subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--color-ink-soft);
    font-variation-settings: "SOFT" 80;
    margin: 0;
  }
  .desc {
    max-width: 62ch;
    font-size: 1.18rem;
    color: var(--color-ink-soft);
    margin-top: 1.8rem;
    line-height: 1.65;
  }

  .curriculum-note {
    border-radius: 6px;
    padding: 1.4rem 1.6rem;
    margin: 2.5rem 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    max-width: 62ch;
    line-height: 1.55;
    background: var(--color-mustard-soft);
    border-left: 4px solid var(--color-mustard);
    position: relative;
  }
  .curriculum-note::before {
    content: "§";
    position: absolute;
    top: 1rem; right: 1.2rem;
    color: var(--color-mustard-deep);
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-style: normal;
  }

  .hub-sections { padding: 0 0 clamp(3rem, 7vw, 6rem); }
  .hub-sections h2 { margin-top: 0; }
  .hub-intro {
    max-width: 60ch;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }

  .section-group { margin-top: 2.6rem; }
  .section-group:first-of-type { margin-top: 1.5rem; }
  .section-group__head { margin-bottom: 0.9rem; }
  .section-group__title {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-terra);
    font-weight: 700;
    margin: 0 0 0.25rem;
  }
  .section-group__desc { font-size: 0.92rem; color: var(--color-ink-mute); margin: 0; max-width: 62ch; }

  .subject-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
    margin-top: 0;
  }
  .section-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 1.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--color-ink);
    text-decoration: none;
    transition: transform .2s var(--ease-soft), box-shadow .2s var(--ease-soft), border-color .2s var(--ease-soft);
    position: relative;
    overflow: hidden;
  }
  .olimpiada-card {
    display: block;
    margin-top: 1.5rem;
    padding: 1.7rem 1.9rem;
    background: var(--color-bg-cream);
    border: 1px solid var(--color-line);
    border-left: 4px solid var(--color-terra);
    border-radius: 6px;
    color: var(--color-ink);
    text-decoration: none;
    transition: transform .2s var(--ease-soft), box-shadow .2s var(--ease-soft);
  }
  .olimpiada-card:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(42, 31, 24, 0.1); }
  .olimpiada-card .ol-kicker { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-terra); }
  .olimpiada-card h3 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; margin: 0.3rem 0 0.4rem; }
  .olimpiada-card .desc { color: var(--color-ink-soft); margin: 0 0 0.6rem; }
  .olimpiada-card .ol-cta { font-family: var(--font-sans); font-weight: 600; color: var(--color-terra); }
  .section-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    background: var(--card-color);
    opacity: 0.85;
  }
  .section-card.c-edmn { --card-color: var(--color-edmn); }
  .section-card.c-eco1 { --card-color: var(--color-eco1); }
  .section-card.c-eco4 { --card-color: var(--color-eco4); }
  .section-card.c-fopp { --card-color: var(--color-fopp); }
  .section-card.c-taller3 { --card-color: var(--color-taller3); }
  .section-card.c-ipe1 { --card-color: var(--color-ipe1); }
  .section-card.c-ipe2 { --card-color: var(--color-ipe2); }
  .section-card.c-eeae { --card-color: var(--color-eeae); }
  .section-card.c-gpe { --card-color: var(--color-gpe); }

  /* Make the 5th section's stripe lighter for visual rhythm */
  .section-card:nth-child(5)::before { opacity: 0.5; }

  .section-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 1px 2px rgba(42, 31, 24, 0.05), 0 4px 14px rgba(42, 31, 24, 0.06);
    border-color: var(--card-color);
  }

  .section-card h4 { font-size: 1.3rem; margin: 0; font-weight: 500; font-family: var(--font-serif); }
  .section-card .count {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--card-color);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .section-card .desc {
    font-size: 0.95rem;
    color: var(--color-ink-mute);
    margin: 0;
    line-height: 1.5;
    max-width: none;
    margin-top: 0;
  }
</style>
