---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Juegos"
  description="Material transversal: simuladores, dinámicas, parties y un quiz competitivo. Para los días en que la teoría no sostiene la sesión."
>
  <div class="container">
    <nav class="breadcrumb"><a href="/">Inicio</a> <span class="sep">›</span> <span>Juegos</span></nav>
  </div>

  <section class="hero">
    <div class="container">
      <span class="kicker">Material transversal</span>
      <h1>Juegos para una <span class="serif-italic-wonk accent">clase activa</span>.</h1>
      <p class="lede">
        Esta sección está pendiente de migración. Los juegos viven todavía en
        <a href="https://legacy.profedeeconomia.es" class="editorial-link" rel="external">legacy.profedeeconomia.es</a>.
      </p>
      <p class="note">
        El primer juego refactorizado será <strong>Stonks</strong> (fase 0.4 del rebranding,
        enero 2027). El resto se publicarán a lo largo del 2027.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
  }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .hero { padding: 1rem 0 clamp(3rem, 7vw, 6rem); }
  h1 { max-width: 22ch; margin: 1rem 0 0.6rem; }
  .accent { color: var(--color-terra); }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-ink-soft);
    max-width: 55ch;
    margin: 1.5rem 0;
    line-height: 1.5;
    font-variation-settings: "SOFT" 80;
  }
  .note { color: var(--color-ink-soft); max-width: 60ch; }
</style>
