---
/**
 * Print-and-play version of Econopoly. Materials are derived from the game's
 * own data (board cells, sectors, news cards) so the printed set always matches
 * the digital game. Each `.print-block` is one printable sheet; the @media print
 * stylesheet hides the page chrome and prints only those blocks.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PrintButton from '@components/dinamicas/PrintButton.astro';
import { CELLS, SECTOR_LABEL, SECTOR_COLOR } from '@/lib/games/econopoly/board';
import { NEWS_CARDS } from '@/lib/games/econopoly/events';

// 28 cells laid out clockwise around the perimeter of an 8×8 grid.
function gridPos(i: number): { row: number; col: number } {
  if (i <= 7) return { row: 1, col: i + 1 };
  if (i <= 14) return { row: i - 6, col: 8 };
  if (i <= 21) return { row: 8, col: 22 - i };
  return { row: 29 - i, col: 1 };
}

const KIND_LABEL: Record<string, string> = {
  start: 'Salida', tax: 'Impuesto', news: 'Noticia', cb: 'Banco Central',
  rd: 'I+D', freemarket: 'Mercado libre',
};

const properties = CELLS.filter((c) => c.property).map((c) => c.property!);
---

<BaseLayout
  title="Econopoly — versión para imprimir"
  description="Print-and-play de Econopoly: tablero, cartas de noticia y referencia de propiedades listos para imprimir y jugar en clase sin pantallas."
>
  <div class="container">
    <nav class="breadcrumb no-print">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href="/juegos/">Juegos</a> <span class="sep">›</span>
      <a href="/juegos/econopoly/">Econopoly</a> <span class="sep">›</span>
      <span>Imprimir</span>
    </nav>

    <header class="intro no-print">
      <span class="kicker">Versión para imprimir</span>
      <h1>Econopoly <span class="serif-italic-wonk accent">en papel</span></h1>
      <p class="lede">
        Imprime el tablero, recorta las cartas de noticia y juega sin pantallas.
        Cada bloque es una hoja A4. Las reglas completas están en la
        <a href="/juegos/econopoly/" class="editorial-link">versión digital</a>.
      </p>
      <PrintButton />
    </header>

    <!-- Hoja 1: cómo se juega -->
    <section class="print-block">
      <h2>Cómo se juega</h2>
      <ul class="rules">
        <li><strong>Jugadores:</strong> 1 a 6. Cada uno coge una ficha y sale de la casilla <em>Salida</em>.</li>
        <li><strong>Objetivo:</strong> ser quien tenga <strong>mayor patrimonio neto</strong> al cabo de 20 rondas.</li>
        <li><strong>Turno:</strong> tira el dado, avanza y resuelve la casilla: compra la propiedad libre, paga renta si es de otro, o aplica la casilla especial.</li>
        <li><strong>Monopolios:</strong> tener todas las propiedades de un sector multiplica sus rentas.</li>
        <li><strong>Banco Central:</strong> ajusta el tipo de interés del crédito. <strong>Impuesto:</strong> tributación progresiva sobre el patrimonio.</li>
        <li><strong>Noticias:</strong> al caer en <em>Noticia</em>, roba una carta y aplica su efecto ese turno.</li>
      </ul>
      <p class="hint">Material derivado de la versión digital: {CELLS.length} casillas · {properties.length} propiedades · {NEWS_CARDS.length} cartas de noticia.</p>
    </section>

    <!-- Hoja 2: tablero -->
    <section class="print-block">
      <h2>Tablero</h2>
      <div class="board">
        {CELLS.map((c) => {
          const { row, col } = gridPos(c.id);
          const bg = c.property ? SECTOR_COLOR[c.property.sector] : '#fff';
          return (
            <div
              class={`cell ${c.kind}`}
              style={`grid-row:${row};grid-column:${col};${c.property ? `border-top:6px solid ${bg};` : ''}`}
            >
              <span class="cell-pos">{c.id}</span>
              <span class="cell-label">{c.property ? c.property.label : (KIND_LABEL[c.kind] ?? c.label)}</span>
              {c.property && <span class="cell-price">{c.property.basePrice} · renta {c.property.baseRent}</span>}
            </div>
          );
        })}
        <div class="board-center">ECONOPOLY</div>
      </div>
    </section>

    <!-- Hoja 3+: cartas de noticia -->
    <section class="print-block">
      <h2>Cartas de noticia <span class="count">({NEWS_CARDS.length})</span></h2>
      <div class="cards">
        {NEWS_CARDS.map((card) => (
          <div class="card">
            <span class="card-kicker">Noticia</span>
            <p class="card-text">{card.text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Hoja: referencia de propiedades -->
    <section class="print-block">
      <h2>Propiedades por sector</h2>
      <table class="ref">
        <thead><tr><th>Propiedad</th><th>Sector</th><th>Precio</th><th>Renta base</th></tr></thead>
        <tbody>
          {properties.map((p) => (
            <tr>
              <td>{p.label}</td>
              <td><span class="dot" style={`background:${SECTOR_COLOR[p.sector]}`}></span>{SECTOR_LABEL[p.sector]}</td>
              <td>{p.basePrice}</td>
              <td>{p.baseRent}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </div>
</BaseLayout>

<style>
  .container { max-width: 920px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem) 4rem; }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .intro { margin-bottom: 2.5rem; }
  .kicker { font-family: var(--font-sans); font-size: .8rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--color-terra); }
  h1 { margin: .5rem 0 .8rem; }
  .accent { color: var(--color-terra); }
  .lede { font-size: 1.15rem; color: var(--color-ink-soft); line-height: 1.55; max-width: 60ch; }

  .print-block { margin: 0 0 3rem; }
  .print-block h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; margin: 0 0 1rem; padding-bottom: .4rem; border-bottom: 2px solid var(--color-terra); }
  .print-block h2 .count, .print-block h2 .kicker { font-size: 1rem; color: var(--color-ink-mute); }

  .rules { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: .55rem; }
  .rules li { padding-left: 1.1rem; position: relative; color: var(--color-ink); line-height: 1.5; }
  .rules li::before { content: "→"; position: absolute; left: 0; color: var(--color-mustard); }
  .hint { font-family: var(--font-mono); font-size: .78rem; color: var(--color-ink-mute); }

  /* Board: 8×8 grid, cells around the perimeter. */
  .board { display: grid; grid-template-columns: repeat(8, 1fr); grid-template-rows: repeat(8, minmax(64px, 1fr)); gap: 3px; aspect-ratio: 1; max-width: 720px; border: 2px solid var(--color-ink); padding: 3px; background: var(--color-line); }
  .cell { background: #fff; padding: .35rem; display: flex; flex-direction: column; gap: .15rem; font-size: .62rem; line-height: 1.15; overflow: hidden; }
  .cell-pos { font-family: var(--font-mono); font-size: .58rem; color: var(--color-ink-mute); }
  .cell-label { font-weight: 600; color: var(--color-ink); }
  .cell-price { font-family: var(--font-mono); font-size: .56rem; color: var(--color-ink-soft); margin-top: auto; }
  .cell.start, .cell.tax, .cell.freemarket, .cell.cb, .cell.news, .cell.rd { background: var(--color-bg-cream); }
  .cell.start .cell-label, .cell.freemarket .cell-label { color: var(--color-terra); }
  .board-center { grid-row: 2 / 8; grid-column: 2 / 8; display: flex; align-items: center; justify-content: center; background: #fff; font-family: var(--font-serif); font-size: clamp(1.5rem, 5vw, 3rem); font-weight: 500; color: var(--color-terra); letter-spacing: .05em; }

  /* Cut-out cards. */
  .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: .6rem; }
  .card { border: 1.5px dashed var(--color-line); border-radius: 8px; padding: .8rem 1rem; min-height: 90px; display: flex; flex-direction: column; gap: .4rem; }
  .card-kicker { font-family: var(--font-sans); font-size: .68rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-mustard-deep); }
  .card-text { margin: 0; font-size: .85rem; line-height: 1.4; color: var(--color-ink); }

  /* Reference table. */
  .ref { width: 100%; border-collapse: collapse; font-size: .9rem; }
  .ref th, .ref td { text-align: left; padding: .45rem .6rem; border-bottom: 1px solid var(--color-line); }
  .ref th { font-family: var(--font-sans); font-size: .76rem; text-transform: uppercase; letter-spacing: .06em; color: var(--color-ink-mute); }
  .ref td:nth-child(3), .ref td:nth-child(4), .ref th:nth-child(3), .ref th:nth-child(4) { text-align: right; font-family: var(--font-mono); }
  .dot { display: inline-block; width: .7em; height: .7em; border-radius: 2px; margin-right: .4em; vertical-align: middle; }

  @media print {
    :global(.site-header), :global(.site-footer), .no-print { display: none !important; }
    .container { max-width: none; padding: 0; }
    .print-block { margin: 0; break-inside: avoid; }
    .print-block + .print-block { break-before: page; }
    .board { max-width: 100%; }
    .card { break-inside: avoid; }
    @page { margin: 1.5cm; }
  }
</style>
