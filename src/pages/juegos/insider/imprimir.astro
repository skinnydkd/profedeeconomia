---
/**
 * Print-and-play version of Insider. The role cards and word cards are derived
 * from the game's own data (WORD_BANK, CATEGORY_LABEL) so the printed set always
 * matches the digital game. Each `.print-block` is one printable sheet; the
 * @media print stylesheet hides the page chrome and prints only those blocks.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PrintButton from '@components/dinamicas/PrintButton.astro';
import { WORD_BANK, CATEGORY_LABEL } from '@/lib/games-multi/insider/words';
import type { WordCategory } from '@/lib/games-multi/insider/words';

// Stable category order for the word-card sheet.
const CATEGORY_ORDER: WordCategory[] = ['macro', 'micro', 'finances', 'empresa', 'fiscal'];

// Role cards to deal face-down: 1 Insider + 7 Ciudadano per printed sheet.
const CITIZEN_COUNT = 7;
const citizens = Array.from({ length: CITIZEN_COUNT }, (_, i) => i);
---

<BaseLayout
  title="Insider — versión para imprimir"
  description="Print-and-play de Insider: reglas, cartas de rol y banco de palabras económicas listos para recortar y jugar en clase sin pantallas."
  noindex
>
  <div class="container">
    <nav class="breadcrumb no-print">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href="/juegos/">Juegos</a> <span class="sep">›</span>
      <a href="/juegos/insider/">Insider</a> <span class="sep">›</span>
      <span>Imprimir</span>
    </nav>

    <header class="intro no-print">
      <span class="kicker">Versión para imprimir</span>
      <h1>Insider <span class="serif-italic-wonk accent">en papel</span></h1>
      <p class="lede">
        Imprime las cartas de rol y el banco de palabras, recorta y juega sin
        pantallas. Cada bloque es una hoja A4. Las reglas completas están en la
        <a href="/juegos/insider/" class="editorial-link">versión digital</a>.
      </p>
      <PrintButton />
    </header>

    <!-- Hoja 1: cómo se juega -->
    <section class="print-block">
      <h2>Cómo se juega</h2>
      <ul class="rules">
        <li><strong>Roles:</strong> un <strong>Master</strong> (sabe la palabra y responde), un <strong>Insider</strong> (también la sabe, pero juega de incógnito) y el resto, <strong>ciudadanos</strong> (no la conocen).</li>
        <li><strong>Preparación:</strong> reparte una carta de rol boca abajo a cada jugador. El Master roba una carta de palabra del banco y se la enseña en secreto solo al Insider.</li>
        <li><strong>Objetivo del grupo:</strong> adivinar la palabra secreta haciendo preguntas de <em>sí o no</em> al Master dentro del tiempo límite (p. ej. 5 minutos).</li>
        <li><strong>El Insider:</strong> guía al grupo hacia la palabra sin delatarse, para que la acierten pero crean que ha sido cosa de todos.</li>
        <li><strong>Si aciertan la palabra:</strong> el grupo vota quién cree que es el Insider. <strong>Ganan los ciudadanos</strong> si lo descubren; <strong>gana el Insider</strong> si pasa desapercibido.</li>
        <li><strong>Si no aciertan</strong> a tiempo, pierden todos: también el Insider.</li>
      </ul>
      <p class="hint">Material derivado de la versión digital: 70 palabras · 5 categorías.</p>
    </section>

    <!-- Hoja 2: cartas de rol -->
    <section class="print-block">
      <h2>Cartas de rol <span class="count">(1 Insider · {CITIZEN_COUNT} ciudadanos)</span></h2>
      <div class="cards roles-grid">
        <div class="card role-card insider">
          <span class="card-kicker">Rol</span>
          <p class="role-name">Insider</p>
          <p class="role-note">Conoces la palabra. Guía sin delatarte.</p>
        </div>
        {citizens.map(() => (
          <div class="card role-card">
            <span class="card-kicker">Rol</span>
            <p class="role-name">Ciudadano</p>
            <p class="role-note">No conoces la palabra. Descúbrela.</p>
          </div>
        ))}
      </div>
      <p class="hint">Reimprime o recorta para ajustar la proporción al tamaño del grupo: siempre 1 Insider y el resto ciudadanos. El Master se elige aparte (no necesita carta).</p>
    </section>

    <!-- Hoja 3+: cartas de palabra, agrupadas por categoría -->
    <section class="print-block">
      <h2>Cartas de palabra <span class="count">({WORD_BANK.length})</span></h2>
      <p class="hint">El Master roba una palabra secreta por ronda y la enseña solo al Insider.</p>
      {CATEGORY_ORDER.map((cat) => (
        <div class="word-group">
          <span class="kicker word-group-kicker">{CATEGORY_LABEL[cat]}</span>
          <div class="cards words-grid">
            {WORD_BANK.filter((w) => w.cat === cat).map((w) => (
              <div class="card word-card">
                <span class="word-term">{w.term}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .container { max-width: 920px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem) 4rem; }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }
  .intro { margin-bottom: 2.5rem; }
  .kicker { font-family: var(--font-sans); font-size: .8rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--color-terra); }
  h1 { margin: .5rem 0 .8rem; }
  .accent { color: var(--color-terra); }
  .lede { font-size: 1.15rem; color: var(--color-ink-soft); line-height: 1.55; max-width: 60ch; }

  .print-block { margin: 0 0 3rem; }
  .print-block h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; margin: 0 0 1rem; padding-bottom: .4rem; border-bottom: 2px solid var(--color-terra); }
  .print-block h2 .count, .print-block h2 .kicker { font-size: 1rem; color: var(--color-ink-mute); }

  .rules { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: .55rem; }
  .rules li { padding-left: 1.1rem; position: relative; color: var(--color-ink); line-height: 1.5; }
  .rules li::before { content: "→"; position: absolute; left: 0; color: var(--color-mustard); }
  .hint { font-family: var(--font-mono); font-size: .78rem; color: var(--color-ink-mute); }

  /* Cut-out cards. */
  .cards { display: grid; gap: .6rem; }
  .card { border: 1.5px dashed var(--color-line); border-radius: 8px; padding: .8rem 1rem; display: flex; flex-direction: column; gap: .4rem; }
  .card-kicker { font-family: var(--font-sans); font-size: .68rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-mustard-deep); }

  /* Role cards. */
  .roles-grid { grid-template-columns: repeat(2, 1fr); }
  .role-card { min-height: 110px; justify-content: center; align-items: center; text-align: center; }
  .role-card.insider { border-top: 6px solid var(--color-terra); border-radius: 0 0 8px 8px; }
  .role-card.insider .card-kicker { color: var(--color-terra); }
  .role-name { margin: 0; font-family: var(--font-serif); font-size: 1.4rem; font-weight: 500; color: var(--color-ink); }
  .role-card.insider .role-name { color: var(--color-terra); }
  .role-note { margin: 0; font-size: .82rem; line-height: 1.35; color: var(--color-ink-soft); }

  /* Word cards, grouped by category. */
  .word-group { margin-bottom: 1.4rem; }
  .word-group-kicker { display: block; color: var(--color-mustard-deep); margin-bottom: .55rem; }
  .words-grid { grid-template-columns: repeat(4, 1fr); gap: .45rem; }
  .word-card { min-height: 56px; padding: .5rem .6rem; align-items: center; justify-content: center; text-align: center; }
  .word-term { font-family: var(--font-serif); font-size: .9rem; font-weight: 500; color: var(--color-ink); line-height: 1.2; }

  @media (max-width: 640px) {
    .words-grid { grid-template-columns: repeat(2, 1fr); }
    .roles-grid { grid-template-columns: 1fr; }
  }

  @media print {
    :global(.site-header), :global(.site-footer), .no-print { display: none !important; }
    .container { max-width: none; padding: 0; }
    .print-block { margin: 0; break-inside: avoid; }
    .print-block + .print-block { break-before: page; }
    .card { break-inside: avoid; }
    @page { margin: 1.5cm; }
  }
</style>
