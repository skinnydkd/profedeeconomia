---
/**
 * Single ficha-resumen detail page.
 * Route param: slug = entry id stripped of "olimpiada/fichas/" prefix.
 * Conditionally embeds a calculator island when `herramienta` is set.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { bloqueMeta } from '@/lib/olimpiada';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const all = (await getCollection('olimpiadaFichas')).filter((e) => e.data.estado === 'publicado');
  return all.map((entry) => ({
    params: { slug: entry.id.replace(/^olimpiada\/fichas\//, '').replace(/\.(md|mdx)$/, '') },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const bloque = bloqueMeta(d.bloque);

// Calculator dispatch — only the matching component is imported to keep bundles small.
// PuntoMuertoCalc, EquilibrioCalc, ElasticidadCalc and ADASSimulator are Preact islands.
import PuntoMuertoCalc from '@components/calculadoras/PuntoMuertoCalc.tsx';
import EquilibrioCalc from '@components/calculadoras/EquilibrioCalc.tsx';
import ElasticidadCalc from '@components/calculadoras/ElasticidadCalc.tsx';
import ADASSimulator from '@components/calculadoras/ADASSimulator.tsx';
---

<BaseLayout title={`${d.title} — Fichas Olimpiada`} description={d.resumen}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> <span class="sep">›</span>
      <a href="/olimpiada/">Olimpiada</a> <span class="sep">›</span>
      <a href="/olimpiada/fichas/">Fichas</a> <span class="sep">›</span>
      <span>{d.title}</span>
    </nav>
  </div>

  <section class="body">
    <div class="container container--narrow">
      <span class="kicker" style={`color: var(${bloque.colorVar}-ink)`}>{bloque.label}</span>
      <h1>{d.title}</h1>
      <p class="lede">{d.resumen}</p>

      {d.conceptos_clave.length > 0 && (
        <p class="conceptos"><strong>Conceptos:</strong> {d.conceptos_clave.join(' · ')}</p>
      )}

      <article class="prose">
        <Content />
      </article>

      {d.herramienta && (
        <section class="calculadora-section">
          <h2>Practícalo</h2>
          {d.herramienta === 'PuntoMuerto' && <PuntoMuertoCalc client:load />}
          {d.herramienta === 'Equilibrio' && <EquilibrioCalc client:load />}
          {d.herramienta === 'Elasticidad' && <ElasticidadCalc client:load />}
          {d.herramienta === 'ADASSimulator' && <ADASSimulator client:load />}
        </section>
      )}

      {d.preguntas_tipicas.length > 0 && (
        <section class="block">
          <h2>Preguntas típicas de examen</h2>
          <ol class="preguntas-list">
            {d.preguntas_tipicas.map((p) => <li>{p}</li>)}
          </ol>
        </section>
      )}

      <nav class="back"><a href="/olimpiada/fichas/">← Todas las fichas</a></nav>
    </div>
  </section>
</BaseLayout>

<style>
  .container { max-width: 1240px; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .container--narrow { max-width: 820px; }
  .breadcrumb { font-size: 0.92rem; color: var(--color-ink-mute); margin: 2rem 0; }
  .breadcrumb a { color: var(--color-ink-mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-terra); }
  .breadcrumb .sep { margin: 0 0.5em; color: var(--color-mustard); }

  .body { padding: 1rem 0 clamp(3rem, 7vw, 6rem); }
  .kicker { font-family: var(--font-sans); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
  h1 { margin: 0.6rem 0 0.4rem; max-width: 32ch; }
  .lede { font-size: 1.2rem; color: var(--color-ink-soft); line-height: 1.5; margin: 0 0 0.8rem; }
  .conceptos { color: var(--color-ink-soft); font-size: 0.95rem; margin: 0 0 1.2rem; }
  .conceptos strong { color: var(--color-ink); }

  .prose { font-size: 1.05rem; line-height: 1.7; color: var(--color-ink); }
  .prose :global(h2) { font-family: var(--font-serif); font-size: 1.6rem; margin: 2.2em 0 0.7em; position: relative; padding-top: 1em; font-weight: 500; }
  .prose :global(h2::before) { content: ""; position: absolute; top: 0; left: 0; width: 2.5rem; height: 4px; background: var(--color-terra); border-radius: 999px; }
  .prose :global(h3) { font-family: var(--font-serif); font-size: 1.25rem; margin: 1.6em 0 0.5em; font-weight: 500; }
  .prose :global(p) { margin: 0 0 1em; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.4rem; margin: 0 0 1em; }
  .prose :global(ul li::marker) { color: var(--color-mustard); }
  .prose :global(strong) { color: var(--color-ink); }

  .calculadora-section { margin: 2rem 0; padding: 1.5rem; background: var(--color-bg-soft); border-radius: 10px; border: 1px solid var(--color-line); }
  .calculadora-section h2 { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 500; margin: 0 0 1rem; }

  .block { margin: 2rem 0; }
  .block h2 { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 500; margin: 0 0 0.7rem; }
  .preguntas-list { padding-left: 1.4rem; margin: 0; }
  .preguntas-list li { margin-bottom: 0.5em; line-height: 1.55; color: var(--color-ink-soft); }
  .preguntas-list li::marker { color: var(--color-terra); font-weight: 700; }

  .back { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-line); font-family: var(--font-sans); }
  .back a { color: var(--color-terra); text-decoration: none; font-weight: 500; }
  .back a:hover { text-decoration: underline; }
</style>
